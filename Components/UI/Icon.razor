@* 
    Icon Component - Displays SVG icons with consistent styling
    Usage: <Icon Name="check" Size="20" Color="#10b981" />
*@

@if (!string.IsNullOrEmpty(Name))
{
    var svg = GetIconSvg();
    if (!string.IsNullOrEmpty(svg))
    {
        <span class="icon-wrapper" style="@GetWrapperStyle()">
            @((MarkupString)svg)
        </span>
    }
    else
    {
        <span style="color: #ef4444; font-size: 0.75rem;" title="Icon '@Name' not found">[?]</span>
    }
}

@code {
    [Parameter]
    public string Name { get; set; } = "";

    [Parameter]
    public string Size { get; set; } = "20";

    [Parameter]
    public string Color { get; set; } = "currentColor";

    [Parameter]
    public string Class { get; set; } = "";

    private string GetWrapperStyle()
    {
        return $"display: inline-flex; align-items: center; justify-content: center; width: {Size}px; height: {Size}px; flex-shrink: 0;";
    }

