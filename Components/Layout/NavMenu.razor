@using Microsoft.AspNetCore.Components.Authorization
@using DV.Web.Services
@using System.Security.Claims
@inject ProjectSelectionState ProjectSelection
@inject AuthenticationStateProvider AuthStateProvider
@inject DocumentRepository Repo
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">DV.Web</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <!-- Home - Available to all roles -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <AuthorizeView Roles="DV_Global_Admins">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/sessions">
                        <span class="bi bi-shield-lock" aria-hidden="true"></span> Sessions
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        @if (canEditProject && ProjectSelection.SelectedProjectId.HasValue)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="@($"/project/{ProjectSelection.SelectedProjectId}/edit")">
                    <span class="bi bi-pencil-square" aria-hidden="true"></span> Edit Project
                </NavLink>
            </div>
        }
    </nav>
</div>

<style>
    .role-indicator {
        padding: 0.5rem;
        margin-top: 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .role-indicator .badge {
        font-size: 0.75rem;
        padding: 0.4rem 0.6rem;
        font-weight: normal;
    }

    .nav-scrollable {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 3.5rem);
    }

    .nav-scrollable nav {
        flex: 1;
        display: flex;
        flex-direction: column;
    }
</style>

@code {
    private bool canEditProject = false;
    private ClaimsPrincipal? user;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        user = state.User;
        ProjectSelection.OnChange += StateHasChanged;
        ProjectSelection.OnChange += OnProjectChanged;
    }

    private void OnProjectChanged()
    {
        _ = InvokeAsync(CheckEditPermissionAsync);
    }

    private async Task CheckEditPermissionAsync()
    {
        canEditProject = false;
        if (ProjectSelection.SelectedProjectId.HasValue && !string.IsNullOrEmpty(ProjectSelection.EditPrincipal) && user != null)
        {
             if (user.IsInRole("DV_Global_Admins") || 
                 user.HasClaim(c => (c.Type == "groups" || c.Type == "role" || c.Type == ClaimTypes.Role) && c.Value == "DV_Global_Admins"))
             {
                 canEditProject = true;
             }
             else
             {
                 var editPrincipal = ProjectSelection.EditPrincipal;
                 // Check AD claims AND app-managed groups
                 canEditProject = await Repo.IsUserInGroupAsync(user, editPrincipal);
             }
        }
        StateHasChanged();
    }

    public void Dispose()
    {
        ProjectSelection.OnChange -= StateHasChanged;
        ProjectSelection.OnChange -= OnProjectChanged;
    }
}