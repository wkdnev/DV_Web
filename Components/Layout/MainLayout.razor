@using DV.Web.Components.Layout
@using DV.Web.Components.Documents
@using DV.Web.Services
@using DV.Web.Security
@inject PersistentComponentState ApplicationState
@inject TokenProvider TokenProvider
@inherits LayoutComponentBase

<div class="page">
    <!-- New Header System -->
    <header class="app-header">
        <!-- Left Section (30%): Logo and Version -->
        <div class="header-branding">
            <a href="/" class="d-flex align-items-center gap-2 text-decoration-none">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                </svg>
                <span class="h4 mb-0 text-white">DocViewer</span>
            </a>
            <div class="text-white-50">v1.0.0</div>
        </div>

        <!-- Right Section (70%): Menu Bar -->
        <div class="header-menu">
            <nav class="d-flex w-100 align-items-center justify-content-between px-3">
                <!-- Left-aligned Menu Items -->
                <div class="d-flex align-items-center gap-3">
                    <a href="" class="menu-link">Browse</a>
                    <ManageLink @rendermode="InteractiveServer" />
                    <div class="d-flex align-items-center">
                        <BadFileButton />
                    </div>
                </div>

                <!-- Right-aligned Menu Items -->
                <div class="d-flex align-items-center gap-2">
                    <ThemeToggle @rendermode="InteractiveServer" />
                    <NotificationBell @rendermode="InteractiveServer" />
                    <a href="about" class="menu-link">About</a>
                    <a href="/logout" class="menu-link" style="color: #fbbf24;">
                        <i class="bi bi-box-arrow-right me-1"></i>Sign Out
                    </a>
                </div>
            </nav>
        </div>
    </header>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    protected override void OnInitialized()
    {
        if (ApplicationState.TryTakeFromJson<string>("AccessToken", out var savedToken))
        {
            TokenProvider.AccessToken = savedToken;
        }
    }
}