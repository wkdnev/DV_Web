@using DV.Shared.Models
@using DV.Web.Services
@inject DocumentRepository Repo
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="blob-document-viewer">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @errorMessage
        </div>
    }
    else if (pages == null || !pages.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-file-x me-2"></i>
            No pages found for this document.
        </div>
    }
    else
    {
        <!-- Document Header -->
        <div class="card mb-3">
            <div class="card-header">
                <div class="row align-items-center">
                    <div class="col">
                        <h5 class="mb-0">Document Viewer - Document ID: @DocumentId</h5>
                        <small class="text-muted">@pages.Count page(s) ï¿½ Storage: @(pages.First().UsesBlobStorage ? "BLOB" : "File System")</small>
                    </div>
                    <div class="col-auto">
                        <div class="btn-group">
                            <button class="btn btn-outline-secondary btn-sm" @onclick="ZoomOut" disabled="@(zoomLevel <= 50)">
                                <i class="bi bi-zoom-out"></i>
                            </button>
                            <button class="btn btn-outline-secondary btn-sm disabled">
                                @zoomLevel%
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="ZoomIn" disabled="@(zoomLevel >= 200)">
                                <i class="bi bi-zoom-in"></i>
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="ResetZoom">
                                <i class="bi bi-aspect-ratio"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Page Navigation -->
        @if (pages.Count > 1)
        {
            <div class="card mb-3">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <button class="btn btn-outline-primary btn-sm" 
                                    @onclick="PreviousPage" 
                                    disabled="@(currentPageIndex <= 0)">
                                <i class="bi bi-chevron-left"></i> Previous
                            </button>
                            <button class="btn btn-outline-primary btn-sm ms-2" 
                                    @onclick="NextPage" 
                                    disabled="@(currentPageIndex >= pages.Count - 1)">
                                Next <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                        
                        <div>
                            <span class="me-2">Page:</span>
                            <div class="btn-group">
                                @for (int i = 0; i < pages.Count; i++)
                                {
                                    int pageIndex = i; // Capture for closure
                                    <button class="btn btn-sm @(i == currentPageIndex ? "btn-primary" : "btn-outline-secondary")"
                                            @onclick="() => GoToPage(pageIndex)">
                                        @pages[i].PageNumber
                                    </button>
                                }
                            </div>
                        </div>

                        <div>
                            <span class="text-muted">
                                Page @(currentPageIndex + 1) of @pages.Count
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Document Display -->
        <div class="card">
            <div class="card-body p-0">
                <div class="document-display-area" style="height: calc(100vh - 300px); overflow: auto;">
                    @if (currentPage != null)
                    {
                        <div class="text-center p-3">
                            @if (IsPdfFile(currentPage))
                            {
                                <!-- Display PDF in iframe -->
                                <iframe src="@GetPageUrl(currentPage.PageId)" 
                                        width="100%" 
                                        height="600px"
                                        style="transform: scale(@(zoomLevel/100.0)); transform-origin: top left;"
                                        frameborder="0">
                                    Your browser does not support PDFs. 
                                    <a href="@GetPageUrl(currentPage.PageId)" target="_blank">Download the PDF</a>
                                </iframe>
                            }
                            else if (IsImageFile(currentPage))
                            {
                                <!-- Display as image -->
                                <img src="@GetPageUrl(currentPage.PageId)" 
                                     alt="Page @currentPage.PageNumber"
                                     class="img-fluid border shadow"
                                     style="max-width: @(zoomLevel)%; height: auto;" 
                                     @onclick="ToggleFullscreen" />
                            }
                            else
                            {
                                <!-- Unsupported file type -->
                                <div class="alert alert-info">
                                    <i class="bi bi-file-earmark me-2"></i>
                                    <strong>@currentPage.FileType file</strong>
                                    <p class="mb-2">This file type cannot be displayed in the browser.</p>
                                    <a href="@GetDownloadUrl(currentPage.PageId)" class="btn btn-primary" target="_blank">
                                        <i class="bi bi-download me-2"></i>Download @currentPage.FileName
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Page Information -->
        @if (currentPage != null)
        {
            <div class="card mt-3">
                <div class="card-header">
                    <h6 class="mb-0">Page Information</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">File Name:</dt>
                                <dd class="col-sm-8">@currentPage.FileName</dd>
                                <dt class="col-sm-4">File Type:</dt>
                                <dd class="col-sm-8">@currentPage.FileType</dd>
                                <dt class="col-sm-4">Page Number:</dt>
                                <dd class="col-sm-8">@currentPage.PageNumber</dd>
                                @if (!string.IsNullOrEmpty(currentPage.PageReference))
                                {
                                    <dt class="col-sm-4">Reference:</dt>
                                    <dd class="col-sm-8">@currentPage.PageReference</dd>
                                }
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">Storage:</dt>
                                <dd class="col-sm-8">
                                    @if (currentPage.UsesBlobStorage)
                                    {
                                        <span class="badge bg-success">BLOB Storage</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">File System</span>
                                    }
                                </dd>
                                @if (currentPage.FileSize.HasValue)
                                {
                                    <dt class="col-sm-4">File Size:</dt>
                                    <dd class="col-sm-8">@FormatFileSize(currentPage.FileSize.Value)</dd>
                                }
                                @if (currentPage.UploadedDate.HasValue)
                                {
                                    <dt class="col-sm-4">Uploaded:</dt>
                                    <dd class="col-sm-8">@currentPage.UploadedDate.Value.ToString("MMM dd, yyyy HH:mm")</dd>
                                }
                            </dl>
                        </div>
                    </div>
                    
                    <div class="mt-3">
                        <div class="btn-group">
                            <a href="@GetDownloadUrl(currentPage.PageId)" class="btn btn-outline-primary btn-sm" target="_blank">
                                <i class="bi bi-download me-2"></i>Download
                            </a>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => OpenInNewTab(currentPage.PageId)">
                                <i class="bi bi-box-arrow-up-right me-2"></i>Open in New Tab
                            </button>
                            @if (IsImageFile(currentPage))
                            {
                                <button class="btn btn-outline-info btn-sm" @onclick="ToggleFullscreen">
                                    <i class="bi bi-arrows-fullscreen me-2"></i>Fullscreen
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int DocumentId { get; set; }

    private List<DocumentPage>? pages;
    private DocumentPage? currentPage => pages?[currentPageIndex];
    private int currentPageIndex = 0;
    private int zoomLevel = 100;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        await LoadDocumentPages();
    }

    private async Task LoadDocumentPages()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            pages = await Repo.GetDocumentPagesAsync("DefaultConnection", DocumentId);
            
            if (pages == null || !pages.Any())
            {
                errorMessage = "No pages found for this document.";
            }
            else
            {
                // Sort pages by page number
                pages = pages.OrderBy(p => p.PageNumber).ToList();
                currentPageIndex = 0;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading document pages: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NextPage()
    {
        if (pages != null && currentPageIndex < pages.Count - 1)
        {
            currentPageIndex++;
        }
    }

    private void PreviousPage()
    {
        if (currentPageIndex > 0)
        {
            currentPageIndex--;
        }
    }

    private void GoToPage(int pageIndex)
    {
        if (pages != null && pageIndex >= 0 && pageIndex < pages.Count)
        {
            currentPageIndex = pageIndex;
        }
    }

    private void ZoomIn()
    {
        if (zoomLevel < 200)
        {
            zoomLevel += 25;
        }
    }

    private void ZoomOut()
    {
        if (zoomLevel > 50)
        {
            zoomLevel -= 25;
        }
    }

    private void ResetZoom()
    {
        zoomLevel = 100;
    }

    private async Task ToggleFullscreen()
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.documentElement.requestFullscreen()");
    }

    private async Task OpenInNewTab(int pageId)
    {
        var url = GetPageUrl(pageId);
        await JSRuntime.InvokeVoidAsync("window.open", url, "_blank");
    }

    private string GetPageUrl(int pageId)
    {
        return $"/api/DocumentBlob/page/{pageId}";
    }

    private string GetDownloadUrl(int pageId)
    {
        return $"/api/DocumentBlob/page/{pageId}/download";
    }

    private static bool IsImageFile(DocumentPage page)
    {
        // Check both ContentType and FileType to determine if it's an image
        var imageContentTypes = new[] { "image/tiff", "image/tif", "image/jpeg", "image/jpg", "image/png", "image/bmp", "image/gif" };
        var imageFileTypes = new[] { "TIFF", "TIF", "JPEG", "JPG", "PNG", "BMP", "GIF" };
        
        if (!string.IsNullOrEmpty(page.ContentType))
        {
            return imageContentTypes.Any(ct => page.ContentType.Contains(ct, StringComparison.OrdinalIgnoreCase));
        }
        
        return imageFileTypes.Contains(page.FileType.ToUpperInvariant());
    }

    private static bool IsPdfFile(DocumentPage page)
    {
        // Check ContentType first (more reliable), then fall back to FileType
        if (!string.IsNullOrEmpty(page.ContentType))
        {
            return page.ContentType.Contains("pdf", StringComparison.OrdinalIgnoreCase);
        }
        
        return page.FileType.Equals("PDF", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}