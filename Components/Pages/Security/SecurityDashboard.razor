@page "/security/dashboard"
@attribute [RoleBasedAuthorization("Security")]
@using DV.Shared.Security
@rendermode InteractiveServer

<PageTitle>Security Dashboard</PageTitle>

<div class="container mt-4">
    <h3 class="mb-4">Security Dashboard</h3>
    <div class="card">
        <div class="card-body">
            <p class="text-muted">This is the Security Dashboard. Future cybersecurity options and tools will appear here.</p>
            <ul>
                <li>Security Reports (coming soon)</li>
                <li>Threat Monitoring (coming soon)</li>
                <li>Incident Response (coming soon)</li>
                <li>Other security tools...</li>
            </ul>
        </div>
    </div>
</div>
