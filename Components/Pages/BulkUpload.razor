@page "/manage/bulk-upload"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using DV.Shared.Models
@using System.IO
@using System.IO.Compression
@using System.Text
@inject DocumentRepository Repo
@inject BulkUploadApiService BulkUploadApi
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ProjectSelectionState ProjectSelectionState
@inject UserService UserService
@inject AuditService AuditService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@attribute [Authorize]
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Bulk Upload - @(ProjectSelectionState.SelectedProjectName ?? "Document Viewer")</PageTitle>

@if (!hasAccess)
{
    <div class="bu-page">
        <div class="bu-empty">
            @if (isLoading)
            {
                <div class="bu-spinner"></div>
                <p>Verifying access...</p>
            }
            else
            {
                <i class="bi bi-shield-lock" style="font-size:2.5rem;opacity:0.3;color:var(--red);"></i>
                <h3 style="color:var(--text-bright);">Access Denied</h3>
                <p style="color:var(--text-secondary);">@accessDeniedMessage</p>
                <a href="/manage" class="bu-btn primary" style="margin-top:8px;">
                    <i class="bi bi-arrow-left"></i>Back to Manage
                </a>
            }
        </div>
    </div>
}
else
{
    <div class="bu-page">
        <!-- Header Banner -->
        <div class="bu-header">
            <div class="bu-header-inner">
                <div class="bu-header-left">
                    <div class="bu-header-icon">
                        <i class="bi bi-cloud-arrow-up"></i>
                    </div>
                    <div>
                        <div class="bu-header-title">Bulk Upload</div>
                        <div class="bu-header-sub">
                            <i class="bi bi-database"></i> @ProjectSelectionState.SelectedSchemaName
                            <span style="margin:0 6px;">•</span>
                            @ProjectSelectionState.SelectedProjectName
                        </div>
                    </div>
                </div>
                <div style="display:flex;gap:8px;">
                    <button class="bu-btn secondary" @onclick="DownloadCsvTemplate">
                        <i class="bi bi-download"></i>CSV Template
                    </button>
                    <a href="/manage" class="bu-btn secondary">
                        <i class="bi bi-arrow-left"></i>Back
                    </a>
                </div>
            </div>
        </div>

        <!-- Step Indicator -->
        <div class="bu-steps">
            <div class="bu-step @(currentStep == 1 ? "active" : currentStep > 1 ? "done" : "")">
                <div class="bu-step-num">@(currentStep > 1 ? "✓" : "1")</div>
                <span>Select Files</span>
            </div>
            <div class="bu-step-line @(currentStep > 1 ? "done" : "")"></div>
            <div class="bu-step @(currentStep == 2 ? "active" : currentStep > 2 ? "done" : "")">
                <div class="bu-step-num">@(currentStep > 2 ? "✓" : "2")</div>
                <span>Edit Metadata</span>
            </div>
            <div class="bu-step-line @(currentStep > 2 ? "done" : "")"></div>
            <div class="bu-step @(currentStep == 3 ? "active" : "")">
                <div class="bu-step-num">3</div>
                <span>Upload</span>
            </div>
        </div>

        @* ─── STEP 1: Select Files ─── *@
        @if (currentStep == 1)
        {
            <!-- Import Mode Tabs -->
            <div class="bu-mode-tabs">
                <button class="bu-mode-tab @(importMode == ImportMode.Files ? "active" : "")"
                        @onclick="() => SetImportMode(ImportMode.Files)">
                    <i class="bi bi-files"></i>Multiple Files
                </button>
                <button class="bu-mode-tab @(importMode == ImportMode.Zip ? "active" : "")"
                        @onclick="() => SetImportMode(ImportMode.Zip)">
                    <i class="bi bi-file-zip"></i>ZIP Archive
                </button>
                <button class="bu-mode-tab @(importMode == ImportMode.Csv ? "active" : "")"
                        @onclick="() => SetImportMode(ImportMode.Csv)">
                    <i class="bi bi-filetype-csv"></i>CSV-Driven
                </button>
            </div>

            <div class="bu-card">
                @if (importMode == ImportMode.Files)
                {
                    <!-- Multi-File Upload -->
                    <div class="bu-card-header">
                        <i class="bi bi-files" style="color:var(--accent);"></i>
                        <strong>Select Multiple Files</strong>
                    </div>
                    <div class="bu-card-body">
                        <p class="bu-hint">
                            Select 2 or more document files. Supported formats: PDF, TIFF, JPG, PNG, BMP, GIF.
                            Maximum 100 files per batch, 500 MB total.
                        </p>
                        <div class="bu-drop-zone" @ref="dropZoneRef">
                            <i class="bi bi-cloud-arrow-up" style="font-size:2.5rem;opacity:0.3;"></i>
                            <p>Drag &amp; drop files here, or click to browse</p>
                            <InputFile class="bu-file-input" OnChange="OnMultipleFilesSelected"
                                       multiple accept=".pdf,.tiff,.tif,.jpg,.jpeg,.png,.bmp,.gif" />
                            <span class="bu-file-hint">PDF, TIFF, JPG, PNG, BMP, GIF — max 100 files / 500 MB</span>
                        </div>
                    </div>
                }
                else if (importMode == ImportMode.Zip)
                {
                    <!-- ZIP Upload -->
                    <div class="bu-card-header">
                        <i class="bi bi-file-zip" style="color:var(--gold);"></i>
                        <strong>Upload ZIP Archive</strong>
                    </div>
                    <div class="bu-card-body">
                        <p class="bu-hint">
                            Upload a ZIP file containing 2 or more document files. The archive will be extracted
                            and each file added to the staging list for metadata assignment.
                        </p>
                        <div class="bu-drop-zone">
                            <i class="bi bi-file-earmark-zip" style="font-size:2.5rem;opacity:0.3;"></i>
                            <p>Select a ZIP archive</p>
                            <InputFile class="bu-file-input" OnChange="OnZipFileSelected"
                                       accept=".zip" />
                            <span class="bu-file-hint">ZIP archive — max 500 MB</span>
                        </div>
                        @if (isExtractingZip)
                        {
                            <div class="bu-alert info" style="margin-top:12px;">
                                <span class="bu-spinner-sm"></span>
                                Extracting archive...
                            </div>
                        }
                    </div>
                }
                else if (importMode == ImportMode.Csv)
                {
                    <!-- CSV-Driven Upload -->
                    <div class="bu-card-header">
                        <i class="bi bi-filetype-csv" style="color:var(--green-bright);"></i>
                        <strong>CSV-Driven Import</strong>
                    </div>
                    <div class="bu-card-body">
                        <p class="bu-hint">
                            Upload a CSV manifest file that maps filenames to metadata, then upload the
                            matching document files. The CSV must have a <code>FileName</code> column.
                            <button class="bu-link-btn" @onclick="DownloadCsvTemplate">Download CSV template</button>
                        </p>

                        <div class="bu-field">
                            <label class="bu-label">Step 1 — CSV Manifest</label>
                            <InputFile class="bu-input" OnChange="OnCsvFileSelected"
                                       accept=".csv" />
                        </div>

                        @if (csvParseMessage != null)
                        {
                            <div class="bu-alert @(csvParseSuccess ? "success" : "error")">
                                <i class="bi @(csvParseSuccess ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
                                @csvParseMessage
                            </div>
                        }

                        @if (csvParsedCount > 0)
                        {
                            <div class="bu-field" style="margin-top:12px;">
                                <label class="bu-label">Step 2 — Upload matching files (@csvParsedCount files expected)</label>
                                <InputFile class="bu-input" OnChange="OnCsvMatchingFilesSelected"
                                           multiple accept=".pdf,.tiff,.tif,.jpg,.jpeg,.png,.bmp,.gif" />
                            </div>
                        }
                    </div>
                }

                <!-- Staged Files List -->
                @if (stagedFiles.Count > 0)
                {
                    <div class="bu-staged-section">
                        <div class="bu-staged-header">
                            <div>
                                <strong>@stagedFiles.Count files staged</strong>
                                <span class="bu-text-muted"> — @FormatFileSize(stagedFiles.Sum(f => f.Metadata.FileSize)) total</span>
                            </div>
                            <div style="display:flex;gap:8px;">
                                <button class="bu-btn danger-outline" @onclick="ClearStagedFiles">
                                    <i class="bi bi-trash3"></i>Clear All
                                </button>
                            </div>
                        </div>
                        <div class="bu-staged-list">
                            @foreach (var entry in stagedFiles)
                            {
                                <div class="bu-staged-item @(!entry.Metadata.IsValid ? "invalid" : "")">
                                    <div class="bu-staged-info">
                                        <i class="bi @GetFileIcon(entry.File.Name)"></i>
                                        <span class="bu-staged-name" title="@entry.File.Name">@entry.File.Name</span>
                                        <span class="bu-staged-size">@FormatFileSize(entry.File.Size)</span>
                                        <span class="bu-type-chip">@GetFileExtension(entry.File.Name)</span>
                                    </div>
                                    @if (!entry.Metadata.IsValid)
                                    {
                                        <span class="bu-staged-error">
                                            <i class="bi bi-exclamation-triangle"></i>@entry.Metadata.ValidationError
                                        </span>
                                    }
                                    <button class="bu-staged-remove" @onclick="() => RemoveStagedFile(entry)"
                                            title="Remove">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (step1Error != null)
                {
                    <div class="bu-alert error" style="margin:12px 16px;">
                        <i class="bi bi-exclamation-triangle"></i>@step1Error
                    </div>
                }

                <!-- Step 1 Actions -->
                @if (stagedFiles.Count >= 2)
                {
                    <div class="bu-card-footer">
                        <button class="bu-btn primary" @onclick="ProceedToMetadata">
                            <span>Next: Edit Metadata</span>
                            <i class="bi bi-arrow-right"></i>
                        </button>
                    </div>
                }
                else if (stagedFiles.Count == 1)
                {
                    <div class="bu-alert info" style="margin:12px 16px;">
                        <i class="bi bi-info-circle"></i>
                        Bulk upload requires at least 2 files. Add more files to continue.
                    </div>
                }
            </div>
        }

        @* ─── STEP 2: Edit Metadata ─── *@
        @if (currentStep == 2)
        {
            <div class="bu-card">
                <div class="bu-card-header" style="justify-content:space-between;">
                    <div style="display:flex;align-items:center;gap:8px;">
                        <i class="bi bi-pencil-square" style="color:var(--accent);"></i>
                        <strong>Edit Metadata</strong>
                        <span class="bu-badge">@stagedFiles.Count files</span>
                    </div>
                    <div style="display:flex;gap:8px;align-items:center;">
                        <button class="bu-btn secondary small" @onclick="ApplyToAll"
                                title="Apply the first file's metadata to all files">
                            <i class="bi bi-clipboard-check"></i>Apply First to All
                        </button>
                    </div>
                </div>

                <!-- Batch Default Fields -->
                <div class="bu-batch-defaults">
                    <div class="bu-batch-label">
                        <i class="bi bi-lightning"></i> Quick Apply — Set defaults for all files:
                    </div>
                    <div class="bu-batch-fields">
                        <div class="bu-mini-field">
                            <label>Status</label>
                            <select class="bu-input small" @bind="batchStatus">
                                <option value="">—</option>
                                <option>Draft</option>
                                <option>Final</option>
                                <option>Approved</option>
                                <option>Archived</option>
                            </select>
                        </div>
                        <div class="bu-mini-field">
                            <label>Classification</label>
                            <select class="bu-input small" @bind="batchClassification">
                                <option value="">—</option>
                                <option>Public</option>
                                <option>Internal</option>
                                <option>Confidential</option>
                                <option>Restricted</option>
                            </select>
                        </div>
                        <div class="bu-mini-field">
                            <label>Author</label>
                            <input class="bu-input small" @bind="batchAuthor" placeholder="Author name" />
                        </div>
                        <div class="bu-mini-field">
                            <label>Version</label>
                            <input class="bu-input small" @bind="batchVersion" placeholder="e.g. 1.0" />
                        </div>
                        <button class="bu-btn accent small" @onclick="ApplyBatchDefaults">
                            <i class="bi bi-check2-all"></i>Apply
                        </button>
                    </div>
                </div>

                <!-- Metadata Table -->
                <div class="bu-meta-table-wrap">
                    <table class="bu-meta-table">
                        <thead>
                            <tr>
                                <th class="col-file">File</th>
                                <th class="col-idx">Doc Index</th>
                                <th class="col-title">Title</th>
                                <th class="col-author">Author</th>
                                <th class="col-status">Status</th>
                                <th class="col-class">Classification</th>
                                <th class="col-kw">Keywords</th>
                                <th class="col-expand"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < stagedFiles.Count; i++)
                            {
                                var idx = i;
                                var entry = stagedFiles[idx];
                                <tr class="@(expandedRow == idx ? "expanded" : "")">
                                    <td class="col-file">
                                        <div class="bu-file-cell">
                                            <i class="bi @GetFileIcon(entry.File.Name)"></i>
                                            <span title="@entry.File.Name">@TruncateFileName(entry.File.Name, 30)</span>
                                        </div>
                                    </td>
                                    <td><input class="bu-cell-input" @bind="entry.Metadata.DocumentIndex" placeholder="—" /></td>
                                    <td><input class="bu-cell-input" @bind="entry.Metadata.Title" placeholder="@Path.GetFileNameWithoutExtension(entry.File.Name)" /></td>
                                    <td><input class="bu-cell-input" @bind="entry.Metadata.Author" placeholder="—" /></td>
                                    <td>
                                        <select class="bu-cell-input" @bind="entry.Metadata.Status">
                                            <option value="">—</option>
                                            <option>Draft</option>
                                            <option>Final</option>
                                            <option>Approved</option>
                                            <option>Archived</option>
                                        </select>
                                    </td>
                                    <td>
                                        <select class="bu-cell-input" @bind="entry.Metadata.Classification">
                                            <option value="">—</option>
                                            <option>Public</option>
                                            <option>Internal</option>
                                            <option>Confidential</option>
                                            <option>Restricted</option>
                                        </select>
                                    </td>
                                    <td><input class="bu-cell-input" @bind="entry.Metadata.Keywords" placeholder="kw1;kw2" /></td>
                                    <td>
                                        <button class="bu-expand-btn" @onclick="() => ToggleExpandRow(idx)"
                                                title="Show all fields">
                                            <i class="bi @(expandedRow == idx ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                        </button>
                                    </td>
                                </tr>
                                @if (expandedRow == idx)
                                {
                                    <tr class="bu-expanded-row">
                                        <td colspan="8">
                                            <div class="bu-expanded-grid">
                                                <div class="bu-exp-field">
                                                    <label>Memo</label>
                                                    <textarea class="bu-cell-input" rows="2" @bind="entry.Metadata.Memo"></textarea>
                                                </div>
                                                <div class="bu-exp-field">
                                                    <label>Version</label>
                                                    <input class="bu-cell-input" @bind="entry.Metadata.Version" />
                                                </div>
                                                <div class="bu-exp-field">
                                                    <label>Issue</label>
                                                    <input class="bu-cell-input" @bind="entry.Metadata.Issue" />
                                                </div>
                                                <div class="bu-exp-field">
                                                    <label>Document Date</label>
                                                    <input class="bu-cell-input" type="date" @bind="entry.Metadata.DocumentDate" />
                                                </div>
                                                @for (int t = 1; t <= 12; t++)
                                                {
                                                    var tIdx = t;
                                                    <div class="bu-exp-field">
                                                        <label>Text@(tIdx.ToString("00"))</label>
                                                        <input class="bu-cell-input" value="@GetTextValue(entry.Metadata, tIdx)"
                                                               @onchange="(e) => SetTextValue(entry.Metadata, tIdx, e.Value?.ToString())" />
                                                    </div>
                                                }
                                                @for (int d = 1; d <= 4; d++)
                                                {
                                                    var dIdx = d;
                                                    <div class="bu-exp-field">
                                                        <label>Date@(dIdx.ToString("00"))</label>
                                                        <input class="bu-cell-input" type="date" value="@GetDateValue(entry.Metadata, dIdx)?.ToString("yyyy-MM-dd")"
                                                               @onchange="(e) => SetDateValue(entry.Metadata, dIdx, e.Value?.ToString())" />
                                                    </div>
                                                }
                                                @for (int b = 1; b <= 3; b++)
                                                {
                                                    var bIdx = b;
                                                    <div class="bu-exp-field">
                                                        <label>Boolean@(bIdx.ToString("00"))</label>
                                                        <select class="bu-cell-input" value="@GetBoolValue(entry.Metadata, bIdx)"
                                                                @onchange="(e) => SetBoolValue(entry.Metadata, bIdx, e.Value?.ToString())">
                                                            <option value="">—</option>
                                                            <option value="True">Yes</option>
                                                            <option value="False">No</option>
                                                        </select>
                                                    </div>
                                                }
                                                @for (int n = 1; n <= 3; n++)
                                                {
                                                    var nIdx = n;
                                                    <div class="bu-exp-field">
                                                        <label>Number@(nIdx.ToString("00"))</label>
                                                        <input class="bu-cell-input" type="number" step="any"
                                                               value="@GetNumberValue(entry.Metadata, nIdx)"
                                                               @onchange="(e) => SetNumberValue(entry.Metadata, nIdx, e.Value?.ToString())" />
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Step 2 Actions -->
                <div class="bu-card-footer">
                    <button class="bu-btn secondary" @onclick="() => currentStep = 1">
                        <i class="bi bi-arrow-left"></i>Back
                    </button>
                    <button class="bu-btn primary" @onclick="ProceedToUpload">
                        <i class="bi bi-cloud-upload"></i>
                        <span>Upload @stagedFiles.Count Files</span>
                    </button>
                </div>
            </div>
        }

        @* ─── STEP 3: Uploading / Results ─── *@
        @if (currentStep == 3)
        {
            <div class="bu-card">
                <div class="bu-card-header">
                    <i class="bi @(uploadComplete ? (uploadResult?.FailedCount == 0 ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") : "bi-cloud-arrow-up")"
                       style="color:@(uploadComplete ? (uploadResult?.FailedCount == 0 ? "var(--green-bright)" : "var(--gold)") : "var(--accent)");"></i>
                    <strong>
                        @if (isUploading)
                        {
                            @:Uploading...
                        }
                        else if (uploadComplete && uploadResult != null)
                        {
                            @if (uploadResult.FailedCount == 0)
                            {
                                @:Upload Complete
                            }
                            else
                            {
                                @:Upload Complete — @uploadResult.FailedCount Failed
                            }
                        }
                    </strong>
                </div>
                <div class="bu-card-body">
                    @if (isUploading)
                    {
                        <div class="bu-progress-section">
                            <div class="bu-progress-bar">
                                <div class="bu-progress-fill" style="width:@uploadProgressPct%"></div>
                            </div>
                            <div class="bu-progress-text">
                                @uploadProgressPhase — @uploadProgressCurrent of @stagedFiles.Count
                            </div>
                        </div>
                    }

                    @if (uploadComplete && uploadResult != null)
                    {
                        <!-- Summary Stats -->
                        <div class="bu-result-stats">
                            <div class="bu-stat">
                                <div class="bu-stat-num">@uploadResult.TotalFiles</div>
                                <div class="bu-stat-label">Total</div>
                            </div>
                            <div class="bu-stat success">
                                <div class="bu-stat-num">@uploadResult.SuccessCount</div>
                                <div class="bu-stat-label">Succeeded</div>
                            </div>
                            @if (uploadResult.FailedCount > 0)
                            {
                                <div class="bu-stat error">
                                    <div class="bu-stat-num">@uploadResult.FailedCount</div>
                                    <div class="bu-stat-label">Failed</div>
                                </div>
                            }
                            <div class="bu-stat">
                                <div class="bu-stat-num">@uploadResult.Duration.TotalSeconds.ToString("F1")s</div>
                                <div class="bu-stat-label">Duration</div>
                            </div>
                        </div>

                        <!-- Per-file results -->
                        <div class="bu-results-list">
                            @foreach (var fr in uploadResult.FileResults)
                            {
                                <div class="bu-result-item @(fr.Success ? "success" : "error")">
                                    <i class="bi @(fr.Success ? "bi-check-circle" : "bi-x-circle")"></i>
                                    <span class="bu-result-name">@fr.FileName</span>
                                    @if (fr.Success)
                                    {
                                        <span class="bu-result-detail">Doc #@fr.DocumentId</span>
                                    }
                                    else
                                    {
                                        <span class="bu-result-error">@fr.Error</span>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (uploadError != null)
                    {
                        <div class="bu-alert error" style="margin-top:12px;">
                            <i class="bi bi-exclamation-triangle"></i>@uploadError
                        </div>
                    }
                </div>

                @if (uploadComplete)
                {
                    <div class="bu-card-footer">
                        <button class="bu-btn secondary" @onclick="StartNewBatch">
                            <i class="bi bi-plus-lg"></i>New Batch
                        </button>
                        <a href="/manage" class="bu-btn primary">
                            <i class="bi bi-arrow-left"></i>Back to Manage
                        </a>
                    </div>
                }
            </div>
        }
    </div>
}

<style>
    /* ── Layout ── */
    .bu-page {
        padding: 1rem;
        max-width: 1400px;
        margin: 0 auto;
        color: var(--text);
    }

    .bu-empty {
        display: flex; flex-direction: column; align-items: center;
        gap: 8px; color: var(--text-muted); padding: 3rem;
    }
    .bu-spinner {
        width: 36px; height: 36px;
        border: 3px solid var(--border);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: bu-spin .8s linear infinite;
    }
    .bu-spinner-sm {
        display: inline-block;
        width: 14px; height: 14px;
        border: 2px solid var(--border);
        border-top-color: currentColor;
        border-radius: 50%;
        animation: bu-spin .8s linear infinite;
    }
    @@keyframes bu-spin { to { transform: rotate(360deg); } }

    /* ── Header Banner ── */
    .bu-header {
        background: linear-gradient(135deg, rgb(5,39,103) 0%, #3a0647 100%);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1rem;
        box-shadow: 0 4px 12px rgba(0,0,0,.25);
    }
    .bu-header-inner {
        display: flex; align-items: center; justify-content: space-between;
    }
    .bu-header-left { display: flex; align-items: center; gap: 14px; }
    .bu-header-icon {
        width: 48px; height: 48px; border-radius: 12px;
        background: rgba(255,255,255,.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; color: #fff;
    }
    .bu-header-title { font-size: 1.25rem; font-weight: 600; color: #fff; }
    .bu-header-sub { font-size: .82rem; color: rgba(255,255,255,.55); margin-top: 2px; }

    /* ── Step Indicator ── */
    .bu-steps {
        display: flex; align-items: center; justify-content: center;
        gap: 0; margin-bottom: 1.25rem;
    }
    .bu-step {
        display: flex; align-items: center; gap: 6px;
        font-size: .82rem; color: var(--text-muted);
        padding: 6px 16px; border-radius: 20px;
        transition: all .2s;
    }
    .bu-step.active {
        background: var(--accent); color: #fff; font-weight: 600;
    }
    .bu-step.done { color: var(--green-bright); }
    .bu-step-num {
        width: 22px; height: 22px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: .72rem; font-weight: 700;
