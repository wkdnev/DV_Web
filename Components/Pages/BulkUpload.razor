    // ── Helpers ──
    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1048576) return (bytes / 1048576.0).ToString("F1") + " MB";
        if (bytes >= 1024) return (bytes / 1024.0).ToString("F1") + " KB";
        return bytes + " B";
    }

    private static string GetFileIcon(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLowerInvariant();
        return ext switch
        {
            ".pdf" => "bi-file-pdf",
            ".tiff" or ".tif" => "bi-file-image",
            ".jpg" or ".jpeg" => "bi-file-image",
            ".png" => "bi-file-image",
            ".bmp" or ".gif" => "bi-file-image",
            _ => "bi-file-earmark"
        };
    }

    private static string GetFileExtension(string fileName) =>
        Path.GetExtension(fileName).TrimStart('.').ToUpperInvariant();

    private static string TruncateFileName(string name, int max) =>
        name.Length <= max ? name : name[..(max - 3)] + "...";

    private static string GetMimeType(string fileName) => Path.GetExtension(fileName).ToLowerInvariant() switch
    {
        ".pdf" => "application/pdf",
        ".tiff" or ".tif" => "image/tiff",
        ".jpg" or ".jpeg" => "image/jpeg",
        ".png" => "image/png",
        ".bmp" => "image/bmp",
        ".gif" => "image/gif",
        _ => "application/octet-stream"
    };

    private static string[] ParseCsvLine(string line)
    {
        var fields = new List<string>();
        bool inQuotes = false;
        var current = new StringBuilder();

        for (int i = 0; i < line.Length; i++)
        {
            char c = line[i];
            if (c == '"')
            {
                if (inQuotes && i + 1 < line.Length && line[i + 1] == '"')
                {
                    current.Append('"');
                    i++;
                }
                else
                {
                    inQuotes = !inQuotes;
                }
            }
            else if (c == ',' && !inQuotes)
            {
                fields.Add(current.ToString());
                current.Clear();
            }
            else
            {
                current.Append(c);
            }
        }
        fields.Add(current.ToString());
        return fields.ToArray();
    }

    private static string GetCsvValue(string[] values, int index) =>
        index >= 0 && index < values.Length ? values[index].Trim() : string.Empty;

    private async void OnProjectChanged()
    {
        await InvokeAsync(async () =>
        {
            StartNewBatch();
            await VerifyAccess();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ProjectSelectionState.OnChange -= OnProjectChanged;
    }

    /// <summary>
    /// In-memory IBrowserFile wrapper for files extracted from a ZIP archive.
    /// </summary>
    private sealed class ZipEntryBrowserFile : IBrowserFile
    {
        private readonly byte[] _data;

        public ZipEntryBrowserFile(string name, byte[] data, long size)
        {
            Name = name;
            _data = data;
            Size = size;
            ContentType = name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) ? "application/pdf"
                : name.EndsWith(".tiff", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".tif", StringComparison.OrdinalIgnoreCase) ? "image/tiff"
                : name.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || name.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) ? "image/jpeg"
                : name.EndsWith(".png", StringComparison.OrdinalIgnoreCase) ? "image/png"
                : name.EndsWith(".bmp", StringComparison.OrdinalIgnoreCase) ? "image/bmp"
                : name.EndsWith(".gif", StringComparison.OrdinalIgnoreCase) ? "image/gif"
                : "application/octet-stream";
        }

        public string Name { get; }
        public DateTimeOffset LastModified { get; } = DateTimeOffset.UtcNow;
        public long Size { get; }
        public string ContentType { get; }

        public Stream OpenReadStream(long maxAllowedSize = 512000, CancellationToken cancellationToken = default)
        {
            return new MemoryStream(_data);
        }
    }
