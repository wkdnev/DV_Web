@code {
    // ── Enums ──
    private enum ImportMode { Files, Zip, Csv }

    // ── Access Control ──
    private bool isLoading = true;
    private bool hasAccess = false;
    private string accessDeniedMessage = "You do not have edit access to the selected project.";
    private string? currentUsername;

    // ── Wizard State ──
    private int currentStep = 1;
    private ImportMode importMode = ImportMode.Files;

    // ── Staged Files ──
    private readonly List<BulkUploadFileEntry> stagedFiles = new();
    private string? step1Error;
    private ElementReference dropZoneRef;

    // ── ZIP ──
    private bool isExtractingZip = false;

    // ── CSV ──
    private int csvParsedCount = 0;
    private string? csvParseMessage;
    private bool csvParseSuccess;
    private readonly List<BulkUploadFileMetadata> csvMetadataEntries = new();

    // ── Metadata (Step 2) ──
    private int? expandedRow;
    private string? batchStatus;
    private string? batchClassification;
    private string? batchAuthor;
    private string? batchVersion;

    // ── Upload (Step 3) ──
    private bool isUploading = false;
    private bool uploadComplete = false;
    private BulkUploadResult? uploadResult;
    private string? uploadError;
    private int uploadProgressPct = 0;
    private string uploadProgressPhase = "";
    private int uploadProgressCurrent = 0;

    // ── Allowed extensions ──
    private static readonly HashSet<string> AllowedExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".pdf", ".tiff", ".tif", ".jpg", ".jpeg", ".png", ".bmp", ".gif"
    };

    protected override async Task OnInitializedAsync()
    {
        ProjectSelectionState.OnChange += OnProjectChanged;
        await VerifyAccess();
    }

    private async Task VerifyAccess()
    {
        isLoading = true;
        hasAccess = false;

        try
        {
            if (!ProjectSelectionState.SelectedProjectId.HasValue)
            {
                accessDeniedMessage = "No project selected. Please select a project from Browse, then navigate to Manage > Bulk Upload.";
                isLoading = false;
                return;
            }

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            currentUsername = user.Identity?.Name;

            if (string.IsNullOrEmpty(currentUsername))
            {
                accessDeniedMessage = "User not authenticated.";
                isLoading = false;
                return;
            }

            var projectId = ProjectSelectionState.SelectedProjectId.Value;
            var canEdit = await Repo.HasProjectEditAccessAsync(user, projectId);

            if (!canEdit)
            {
                accessDeniedMessage = $"You do not have edit access to project '{ProjectSelectionState.SelectedProjectName}'.";
                await AuditService.LogProjectAccessAsync(
                    currentUsername, 0, projectId, "PROJECT_ACCESS_DENIED", "DENIED",
                    $"Edit access denied to Bulk Upload page");
                isLoading = false;
                return;
            }

            hasAccess = true;
            await AuditService.LogProjectAccessAsync(
                currentUsername, 0, projectId, "ACCESS_PROJECT", "SUCCESS",
                $"Bulk Upload page opened for project '{ProjectSelectionState.SelectedProjectName}'");
        }
        catch (Exception ex)
        {
            accessDeniedMessage = $"Error verifying access: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    // ── Import Mode ──
    private void SetImportMode(ImportMode mode)
    {
        importMode = mode;
        step1Error = null;
    }

    // ── Multi-File Selection ──
    private void OnMultipleFilesSelected(InputFileChangeEventArgs e)
    {
        step1Error = null;
        var files = e.GetMultipleFiles(maximumFileCount: 100);

        foreach (var file in files)
        {
            var ext = Path.GetExtension(file.Name);
            if (!AllowedExtensions.Contains(ext))
            {
                step1Error = $"File '{file.Name}' has unsupported extension '{ext}'.";
                continue;
            }

            if (stagedFiles.Any(f => f.File.Name == file.Name))
                continue; // skip duplicates

            var clientId = Guid.NewGuid().ToString("N")[..12];
            stagedFiles.Add(new BulkUploadFileEntry
            {
                File = file,
                Metadata = new BulkUploadFileMetadata
                {
                    ClientFileId = clientId,
                    FileName = file.Name,
                    FileSize = file.Size,
                    ContentType = file.ContentType,
                    Title = Path.GetFileNameWithoutExtension(file.Name),
                    Status = "Draft"
                }
            });
        }

        if (stagedFiles.Count > 100)
        {
            step1Error = "Maximum 100 files per batch. Remove some files.";
            stagedFiles.RemoveRange(100, stagedFiles.Count - 100);
        }

        var totalSize = stagedFiles.Sum(f => f.Metadata.FileSize);
        if (totalSize > 500 * 1024 * 1024)
        {
            step1Error = $"Total size ({FormatFileSize(totalSize)}) exceeds 500 MB limit.";
        }
    }

    // ── ZIP Selection ──
    private async Task OnZipFileSelected(InputFileChangeEventArgs e)
    {
        step1Error = null;
        var zipFile = e.File;

        if (zipFile.Size > 500 * 1024 * 1024)
        {
            step1Error = "ZIP file exceeds 500 MB limit.";
            return;
        }

        isExtractingZip = true;
        StateHasChanged();

        try
        {
            using var stream = zipFile.OpenReadStream(maxAllowedSize: 500 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            using var archive = new ZipArchive(ms, ZipArchiveMode.Read);
            var validEntries = archive.Entries
                .Where(entry => !string.IsNullOrEmpty(entry.Name) &&
                                !entry.FullName.Contains("__MACOSX") &&
                                AllowedExtensions.Contains(Path.GetExtension(entry.Name)))
                .ToList();

            if (validEntries.Count < 2)
            {
                step1Error = "ZIP must contain at least 2 supported document files.";
                return;
            }

            stagedFiles.Clear();
            foreach (var entry in validEntries.Take(100))
            {
                using var entryStream = entry.Open();
                using var entryMs = new MemoryStream();
                await entryStream.CopyToAsync(entryMs);
                entryMs.Position = 0;

                var clientId = Guid.NewGuid().ToString("N")[..12];
                var browserFile = new ZipEntryBrowserFile(entry.Name, entryMs.ToArray(), entry.Length);

                stagedFiles.Add(new BulkUploadFileEntry
                {
                    File = browserFile,
                    Metadata = new BulkUploadFileMetadata
                    {
                        ClientFileId = clientId,
                        FileName = entry.Name,
                        FileSize = entry.Length,
                        ContentType = GetMimeType(entry.Name),
                        Title = Path.GetFileNameWithoutExtension(entry.Name),
                        Status = "Draft"
                    }
                });
            }
        }
        catch (InvalidDataException)
        {
            step1Error = "Invalid or corrupt ZIP file.";
        }
        catch (Exception ex)
        {
            step1Error = $"Error extracting ZIP: {ex.Message}";
        }
        finally
        {
            isExtractingZip = false;
        }
    }

    // ── CSV Selection ──
    private async Task OnCsvFileSelected(InputFileChangeEventArgs e)
    {
        csvParseMessage = null;
        csvParsedCount = 0;
        csvMetadataEntries.Clear();

        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
            var headerLine = await reader.ReadLineAsync();
            if (string.IsNullOrWhiteSpace(headerLine))
            {
                csvParseMessage = "CSV file is empty.";
                csvParseSuccess = false;
                return;
            }

            var headers = ParseCsvLine(headerLine);
            var fileNameIdx = Array.FindIndex(headers, h => h.Equals("FileName", StringComparison.OrdinalIgnoreCase));
            if (fileNameIdx < 0)
            {
                csvParseMessage = "CSV must contain a 'FileName' column.";
                csvParseSuccess = false;
                return;
            }

            int lineNum = 1;
            while (!reader.EndOfStream && lineNum <= 100)
            {
                var line = await reader.ReadLineAsync();
                if (string.IsNullOrWhiteSpace(line)) continue;
                lineNum++;

                var values = ParseCsvLine(line);
                var meta = new BulkUploadFileMetadata
                {
                    ClientFileId = Guid.NewGuid().ToString("N")[..12],
                    FileName = GetCsvValue(values, fileNameIdx),
                    Status = "Draft"
                };

                // Map each known column
                for (int i = 0; i < headers.Length; i++)
                {
                    if (i >= values.Length) break;
                    var val = values[i].Trim();
                    if (string.IsNullOrEmpty(val)) continue;

                    switch (headers[i].Trim().ToLowerInvariant())
                    {
                        case "documentindex": meta.DocumentIndex = val; break;
                        case "title": meta.Title = val; break;
                        case "author": meta.Author = val; break;
                        case "documentdate":
                            if (DateTime.TryParse(val, out var dd)) meta.DocumentDate = dd;
                            break;
                        case "keywords": meta.Keywords = val; break;
                        case "memo": meta.Memo = val; break;
                        case "status": meta.Status = val; break;
                        case "classification": meta.Classification = val; break;
                        case "version": meta.Version = val; break;
                        case "issue": meta.Issue = val; break;
                        case "text01": meta.Text01 = val; break;
                        case "text02": meta.Text02 = val; break;
                        case "text03": meta.Text03 = val; break;
                        case "text04": meta.Text04 = val; break;
                        case "text05": meta.Text05 = val; break;
                        case "text06": meta.Text06 = val; break;
                        case "text07": meta.Text07 = val; break;
                        case "text08": meta.Text08 = val; break;
                        case "text09": meta.Text09 = val; break;
                        case "text10": meta.Text10 = val; break;
                        case "text11": meta.Text11 = val; break;
                        case "text12": meta.Text12 = val; break;
                        case "date01":
                            if (DateTime.TryParse(val, out var d1)) meta.Date01 = d1; break;
                        case "date02":
                            if (DateTime.TryParse(val, out var d2)) meta.Date02 = d2; break;
                        case "date03":
                            if (DateTime.TryParse(val, out var d3)) meta.Date03 = d3; break;
                        case "date04":
                            if (DateTime.TryParse(val, out var d4)) meta.Date04 = d4; break;
                        case "boolean01":
                            if (bool.TryParse(val, out var b1)) meta.Boolean01 = b1; break;
                        case "boolean02":
                            if (bool.TryParse(val, out var b2)) meta.Boolean02 = b2; break;
                        case "boolean03":
                            if (bool.TryParse(val, out var b3)) meta.Boolean03 = b3; break;
                        case "number01":
                            if (double.TryParse(val, out var n1)) meta.Number01 = n1; break;
                        case "number02":
                            if (double.TryParse(val, out var n2)) meta.Number02 = n2; break;
                        case "number03":
                            if (double.TryParse(val, out var n3)) meta.Number03 = n3; break;
                    }
                }

                if (!string.IsNullOrEmpty(meta.FileName))
                {
                    if (string.IsNullOrEmpty(meta.Title))
                        meta.Title = Path.GetFileNameWithoutExtension(meta.FileName);
                    csvMetadataEntries.Add(meta);
                }
            }

            csvParsedCount = csvMetadataEntries.Count;
            if (csvParsedCount < 2)
            {
                csvParseMessage = "CSV must contain at least 2 file entries.";
                csvParseSuccess = false;
            }
            else
            {
                csvParseMessage = $"Parsed {csvParsedCount} entries. Now upload the matching files.";
                csvParseSuccess = true;
            }
        }
        catch (Exception ex)
        {
            csvParseMessage = $"CSV parse error: {ex.Message}";
            csvParseSuccess = false;
        }
    }

    private void OnCsvMatchingFilesSelected(InputFileChangeEventArgs e)
    {
        step1Error = null;
        var files = e.GetMultipleFiles(maximumFileCount: 100);
        stagedFiles.Clear();

        int matched = 0;
        foreach (var file in files)
        {
            var csvEntry = csvMetadataEntries.FirstOrDefault(
                m => m.FileName.Equals(file.Name, StringComparison.OrdinalIgnoreCase));

            if (csvEntry != null)
            {
                csvEntry.FileSize = file.Size;
                csvEntry.ContentType = file.ContentType;
                stagedFiles.Add(new BulkUploadFileEntry
                {
                    File = file,
                    Metadata = csvEntry
                });
                matched++;
            }
            else
            {
                // File not in CSV — add with default metadata
                var clientId = Guid.NewGuid().ToString("N")[..12];
                stagedFiles.Add(new BulkUploadFileEntry
                {
                    File = file,
                    Metadata = new BulkUploadFileMetadata
                    {
                        ClientFileId = clientId,
                        FileName = file.Name,
                        FileSize = file.Size,
                        ContentType = file.ContentType,
                        Title = Path.GetFileNameWithoutExtension(file.Name),
                        Status = "Draft",
                        ValidationError = "Not found in CSV manifest — using defaults",
                        IsValid = true
                    }
                });
            }
        }

        var unmatched = csvMetadataEntries.Where(
            m => !stagedFiles.Any(f => f.File.Name.Equals(m.FileName, StringComparison.OrdinalIgnoreCase))).ToList();

        if (unmatched.Count > 0)
        {
            step1Error = $"{unmatched.Count} CSV entries have no matching file: {string.Join(", ", unmatched.Take(5).Select(u => u.FileName))}";
        }
    }

    // ── Stage Management ──
    private void RemoveStagedFile(BulkUploadFileEntry entry)
    {
        stagedFiles.Remove(entry);
    }

    private void ClearStagedFiles()
    {
        stagedFiles.Clear();
        step1Error = null;
    }

    // ── Step Navigation ──
    private void ProceedToMetadata()
    {
        if (stagedFiles.Count < 2)
        {
            step1Error = "At least 2 files are required.";
            return;
        }

        step1Error = null;
        currentStep = 2;
        expandedRow = null;
    }

    private async Task ProceedToUpload()
    {
        if (!ProjectSelectionState.SelectedProjectId.HasValue ||
            string.IsNullOrEmpty(ProjectSelectionState.SelectedSchemaName))
            return;

        currentStep = 3;
        isUploading = true;
        uploadComplete = false;
        uploadResult = null;
        uploadError = null;
        uploadProgressPct = 0;
        StateHasChanged();

        try
        {
            var progress = new Progress<BulkUploadProgress>(p =>
            {
                uploadProgressPhase = p.Phase;
                uploadProgressCurrent = p.CurrentIndex;
                if (p.TotalFiles > 0)
                    uploadProgressPct = (int)((double)p.CurrentIndex / p.TotalFiles * 100);
                InvokeAsync(StateHasChanged);
            });

            uploadResult = await BulkUploadApi.UploadBatchAsync(
                ProjectSelectionState.SelectedSchemaName,
                ProjectSelectionState.SelectedProjectId.Value,
                stagedFiles,
                progress);

            if (uploadResult != null)
            {
                await AuditService.LogSecurityEventAsync(
                    currentUsername ?? "Unknown", null,
                    "BULK_UPLOAD",
                    $"Bulk uploaded {uploadResult.SuccessCount}/{uploadResult.TotalFiles} files to project '{ProjectSelectionState.SelectedProjectName}'",
                    ProjectSelectionState.SelectedProjectId);
            }
        }
        catch (Exception ex)
        {
            uploadError = $"Upload failed: {ex.Message}";
        }
        finally
        {
            isUploading = false;
            uploadComplete = true;
            uploadProgressPct = 100;
            StateHasChanged();
        }
    }

    private void StartNewBatch()
    {
        stagedFiles.Clear();
        csvMetadataEntries.Clear();
        currentStep = 1;
        uploadResult = null;
        uploadError = null;
        uploadComplete = false;
        csvParsedCount = 0;
        csvParseMessage = null;
        step1Error = null;
        expandedRow = null;
    }

    // ── Batch Defaults ──
    private void ApplyBatchDefaults()
    {
        foreach (var entry in stagedFiles)
        {
            if (!string.IsNullOrEmpty(batchStatus)) entry.Metadata.Status = batchStatus;
            if (!string.IsNullOrEmpty(batchClassification)) entry.Metadata.Classification = batchClassification;
            if (!string.IsNullOrEmpty(batchAuthor)) entry.Metadata.Author = batchAuthor;
            if (!string.IsNullOrEmpty(batchVersion)) entry.Metadata.Version = batchVersion;
        }
    }

    private void ApplyToAll()
    {
        if (stagedFiles.Count < 2) return;
        var src = stagedFiles[0].Metadata;
        foreach (var entry in stagedFiles.Skip(1))
        {
            var m = entry.Metadata;
            m.DocumentIndex = src.DocumentIndex;
            m.Author = src.Author;
            m.Status = src.Status;
            m.Classification = src.Classification;
            m.Keywords = src.Keywords;
            m.Version = src.Version;
            m.Issue = src.Issue;
            m.Memo = src.Memo;
            m.DocumentDate = src.DocumentDate;
            // copy custom fields
            m.Text01 = src.Text01; m.Text02 = src.Text02; m.Text03 = src.Text03;
            m.Text04 = src.Text04; m.Text05 = src.Text05; m.Text06 = src.Text06;
            m.Text07 = src.Text07; m.Text08 = src.Text08; m.Text09 = src.Text09;
            m.Text10 = src.Text10; m.Text11 = src.Text11; m.Text12 = src.Text12;
            m.Date01 = src.Date01; m.Date02 = src.Date02; m.Date03 = src.Date03; m.Date04 = src.Date04;
            m.Boolean01 = src.Boolean01; m.Boolean02 = src.Boolean02; m.Boolean03 = src.Boolean03;
            m.Number01 = src.Number01; m.Number02 = src.Number02; m.Number03 = src.Number03;
        }
    }

    private void ToggleExpandRow(int idx)
    {
        expandedRow = expandedRow == idx ? null : idx;
    }

    // ── CSV Template Download ──
    private async Task DownloadCsvTemplate()
    {
        var templateBytes = await BulkUploadApi.DownloadCsvTemplateAsync();
