@using DocViewer_Proto.Security
@using DocViewer_Proto.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject UserService UserService
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>User Management - DocViewer Proto</PageTitle>

<div class="enterprise-apps-container">
    <div class="header-section">
        <div class="page-header">
            <div class="header-icon">
                👤
            </div>
            <div class="header-content">
                <h1>User Management</h1>
                <p>Manage users in the system. User roles are managed through Project Role Management.</p>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading users...</span>
            </div>
            <p class="mt-3 text-muted">Loading users...</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="alert-container">
            <div class="alert alert-danger custom-alert">@errorMessage</div>
        </div>
    }
    else
    {
        <!-- Stats Grid -->
        <div class="applications-grid" style="margin-bottom: 2rem;">
            <div class="application-card" style="cursor: default;">
                <div class="app-card-header">
                    <h5>👥</h5>
                </div>
                <div style="margin-bottom: 0.5rem;">
                    <div style="font-size: 2rem; font-weight: 700; color: #1f2937;">@(users?.Count ?? 0)</div>
                    <div style="color: #6b7280; font-size: 0.9rem;">Total Users</div>
                </div>
            </div>

            <div class="application-card" style="cursor: default;">
                <div class="app-card-header">
                    <h5>✅</h5>
                </div>
                <div style="margin-bottom: 0.5rem;">
                    <div style="font-size: 2rem; font-weight: 700; color: #1f2937;">@(users?.Count(u => u.IsActive) ?? 0)</div>
                    <div style="color: #6b7280; font-size: 0.9rem;">Active Users</div>
                </div>
            </div>

            <div class="application-card" style="cursor: default;">
                <div class="app-card-header">
                    <h5>🚫</h5>
                </div>
                <div style="margin-bottom: 0.5rem;">
                    <div style="font-size: 2rem; font-weight: 700; color: #1f2937;">@(users?.Count(u => !u.IsActive) ?? 0)</div>
                    <div style="color: #6b7280; font-size: 0.9rem;">Inactive Users</div>
                </div>
            </div>

            <div class="application-card" style="cursor: default;">
                <div class="app-card-header">
                    <h5>🔍</h5>
                </div>
                <div style="margin-bottom: 0.5rem;">
                    <div style="font-size: 2rem; font-weight: 700; color: #1f2937;">@filteredUsers.Count</div>
                    <div style="color: #6b7280; font-size: 0.9rem;">Filtered Results</div>
                </div>
            </div>
        </div>

        <div class="controls-section">
            <div class="controls-row">
                <div class="control-item">
                    <button class="btn btn-success" @onclick="RefreshUsers">
                        <i class="bi bi-arrow-clockwise"></i> Refresh Users
                    </button>
                </div>
                <div class="control-item">
                    <label for="searchText" class="form-label visually-hidden">Search Users</label>
                    <div class="search-input-group input-group">
                        <input id="searchText" type="text" class="form-control search-input" placeholder="Search users..." 
                               value="@searchTerm" @oninput="@(async (e) => await OnSearchInput(e))" />
                        @if (!string.IsNullOrWhiteSpace(searchTerm))
                        {
                            <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                                <i class="bi bi-x"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (users == null || users.Count == 0)
        {
            <div class="empty-state">
                <h5>ℹ️ No users found</h5>
                <p>Users will be automatically added when they log in for the first time.</p>
            </div>
        }
        else
        {
            <!-- Info Alert -->
            <div class="alert-container">
                <div class="alert alert-info custom-alert">
                    <strong>ℹ️ Project-Based Access Control:</strong> User roles are now managed through <a href="/admin/project-roles" style="color: #1d4ed8; text-decoration: underline;">Project Role Management</a>. Users are assigned roles within specific projects rather than global roles.
                </div>
            </div>

            <div class="table-container">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Username</th>
                                <th>Display Name</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in filteredUsers)
                            {
                                <tr>
                                    <td><strong>@user.Username</strong></td>
                                    <td>@user.DisplayName</td>
                                    <td style="color: #6b7280;">@user.Email</td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td style="color: #6b7280;">@user.CreatedDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <div class="action-buttons">
                                            <button class="btn btn-@(user.IsActive ? "warning" : "success") btn-sm action-btn" 
                                                    @onclick="() => ToggleUserStatus(user)" 
                                                    title="@(user.IsActive ? "Disable" : "Enable")">
                                                <i class="bi bi-@(user.IsActive ? "pause-fill" : "play-fill")"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (filteredUsers.Count == 0 && !string.IsNullOrWhiteSpace(searchTerm))
            {
                <div class="empty-state">
                    <h5>No users match your search criteria</h5>
                    <p>Try adjusting your search terms or <button class="btn btn-link p-0" @onclick="ClearSearch">clear the search</button>.</p>
                </div>
            }
        }
    }
</div>

@code {
    private List<ApplicationUser>? users;
    private List<ApplicationUser> filteredUsers = new();
    private string searchTerm = "";
    private string? currentUsername;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            currentUsername = authState.User.Identity?.Name;

            await LoadUsersData();
            ApplySearch();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error initializing: {ex.Message}";
            await JSRuntime.InvokeVoidAsync("console.error", "UserManagement initialization error:", ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadUsersData()
    {
        try { users = await UserService.GetAllUsersAsync(); }
        catch (Exception ex) { errorMessage = $"Error loading users: {ex.Message}"; users = new List<ApplicationUser>(); }
    }

    private void ApplySearch()
    {
        if (users == null) { filteredUsers = new List<ApplicationUser>(); return; }
        if (string.IsNullOrWhiteSpace(searchTerm)) { filteredUsers = users.ToList(); return; }
        filteredUsers = users.Where(u =>
            u.Username.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            u.DisplayName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            u.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        ApplySearch();
        await Task.CompletedTask;
    }

    private async Task ClearSearch()
    {
        searchTerm = string.Empty;
        ApplySearch();
        await Task.CompletedTask;
    }

    private async Task RefreshUsers()
    {
        try { isLoading = true; errorMessage = null; await LoadUsersData(); ApplySearch(); await JSRuntime.InvokeVoidAsync("alert", "User list refreshed!"); }
        catch (Exception ex) { errorMessage = $"Error refreshing users: {ex.Message}"; }
        finally { isLoading = false; }
    }

    private async Task ToggleUserStatus(ApplicationUser user)
    {
        try
        {
            user.IsActive = !user.IsActive;
            await UserService.UpdateUserAsync(user);
            await JSRuntime.InvokeVoidAsync("alert", $"User {user.Username} is now {(user.IsActive ? "enabled" : "disabled")}." );
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating user status: {ex.Message}";
        }
    }
}