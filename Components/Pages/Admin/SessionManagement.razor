@page "/admin/sessions"
@using DV.Web.Services
@using DV.Shared.Security
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "DV_Global_Admins")]
@inject SessionManagementService SessionService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Session Management</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h2>Session Management</h2>
            <p class="text-muted">Monitor and manage active user sessions.</p>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-primary" @onclick="LoadDataAsync">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center p-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Statistics Cards -->
        @if (statistics != null)
        {
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card h-100 border-primary">
                        <div class="card-body text-center">
                            <h5 class="card-title text-primary">Active Sessions</h5>
                            <h2 class="display-4 fw-bold">@statistics.TotalActiveSessions</h2>
                            <p class="card-text text-muted">Currently connected</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card h-100">
                        <div class="card-body text-center">
                            <h5 class="card-title">Unique Users</h5>
                            <h2 class="display-4">@statistics.UniqueUsersToday</h2>
                            <p class="card-text text-muted">Today</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card h-100">
                        <div class="card-body text-center">
                            <h5 class="card-title">Total Sessions</h5>
                            <h2 class="display-4">@statistics.TotalSessionsToday</h2>
                            <p class="card-text text-muted">Created today</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card h-100 border-danger">
                        <div class="card-body text-center">
                            <h5 class="card-title text-danger">Terminated</h5>
                            <h2 class="display-4 fw-bold">@statistics.AdminTerminatedSessions</h2>
                            <p class="card-text text-muted">By Admin</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Active Sessions Table -->
        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">Active Sessions</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>User</th>
                                <th>Role</th>
                                <th>IP Address</th>
                                <th>Started</th>
                                <th>Last Active</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (activeSessions != null && activeSessions.Any())
                            {
                                @foreach (var session in activeSessions)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-bold">@session.Username</div>
                                            <small class="text-muted">ID: @session.UserId</small>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(session.CurrentRole))
                                            {
                                                <span class="badge bg-info text-dark">@session.CurrentRole</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">None</span>
                                            }
                                        </td>
                                        <td>
                                            <code>@session.IpAddress</code>
                                            @if (!string.IsNullOrEmpty(session.UserAgent))
                                            {
                                                <div class="small text-truncate" style="max-width: 200px;" title="@session.UserAgent">
                                                    @GetShortUserAgent(session.UserAgent)
                                                </div>
                                            }
                                        </td>
                                        <td>@session.CreatedAt.ToLocalTime().ToString("g")</td>
                                        <td>
                                            @session.LastActivity.ToLocalTime().ToString("g")
                                            <br />
                                            <small class="text-muted">@GetTimeAgo(session.LastActivity)</small>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger" 
                                                    @onclick="() => TerminateSessionAsync(session.SessionKey, session.Username)">
                                                <i class="bi bi-stop-circle"></i> Terminate
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">
                                        No active sessions found.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<UserSession> activeSessions = new();
    private SessionStatistics? statistics;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            StateHasChanged(); // Force re-render for spinner

            activeSessions = await SessionService.GetActiveSessionsAsync();
            statistics = await SessionService.GetSessionStatisticsAsync();
        }
        catch (Exception ex)
        {
            // Allow error boundary to handle or log
            Console.WriteLine($"Error loading session data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task TerminateSessionAsync(string sessionKey, string username)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to terminate the session for {username}?"))
        {
            return;
        }

        try
        {
            // Assuming current user is "System Admin" or get from AuthenticationState
            // Since this runs in Blazor context, we can hardcode "Global Admin" for the log
            // or inject AuthenticationStateProvider to get real name.
            var success = await SessionService.TerminateSessionAsync(sessionKey, "Global Admin", true);

            if (success)
            {
                await LoadDataAsync();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Failed to terminate session. It may have already ended.");
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
    }

    private string GetTimeAgo(DateTime date)
    {
        var span = DateTime.UtcNow - date;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{Math.Floor(span.TotalMinutes)}m ago";
        if (span.TotalHours < 24) return $"{Math.Floor(span.TotalHours)}h ago";
        return $"{Math.Floor(span.TotalDays)}d ago";
    }

    private string GetShortUserAgent(string userAgent)
    {
        if (string.IsNullOrEmpty(userAgent)) return "";
        if (userAgent.Contains("Chrome")) return "Chrome";
        if (userAgent.Contains("Firefox")) return "Firefox";
        if (userAgent.Contains("Edge") || userAgent.Contains("Edg")) return "Edge";
        if (userAgent.Contains("Safari")) return "Safari";
        return "Other Browser";
    }
}
