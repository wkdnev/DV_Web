@page "/admin/user-project-access"
@using DV.Shared.Security
@using DV.Shared.Models
@using DV.Web.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "GlobalAdminOnly")]
@inject UserService UserService
@inject ProjectService ProjectService
@inject UserProjectAccessService UserProjectAccessService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>User Project Access Management</PageTitle>

<div class="lgreeny-dashboard">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <div>
            <h2 style="margin: 0; color: #1e293b; font-size: 1.75rem; font-weight: 600;">ðŸ” User Project Access Management</h2>
            <p style="margin: 0.5rem 0 0 0; color: #64748b; font-size: 0.875rem;">Control which users can access specific projects</p>
        </div>
        <button class="lgreeny-btn-primary" style="width: auto;" @onclick="OpenGrantAccessDialog">
            âž• Grant Project Access
        </button>
    </div>

@if (isLoading)
{
    <div style="text-align: center; padding: 2rem;">
        <div style="color: #3b82f6; font-size: 1.5rem;">â³</div>
        <p style="color: #64748b; margin-top: 0.5rem;">Loading user project access...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div style="padding: 1rem; background: #fee2e2; border: 1px solid #fecaca; border-radius: 0.5rem; margin-bottom: 1.5rem; color: #991b1b;">
        âš ï¸ @errorMessage
    </div>
}
else
{
    <!-- Warning Box -->
    <div style="padding: 1rem; background: #dbeafe; border: 1px solid #bfdbfe; border-radius: 0.5rem; margin-bottom: 1.5rem; color: #1e40af;">
        <h6 style="margin: 0 0 0.5rem 0; color: #1e40af; font-weight: 600;">â„¹ï¸ User-Project Access Control</h6>
        <p style="margin: 0; font-size: 0.875rem;">
            Users must be granted access to specific projects before they can be assigned project roles.
            This provides an additional layer of security by controlling which projects users can even see or access.
        </p>
    </div>

    <!-- Project Selection for Viewing -->
    <div class="lgreeny-panel" style="margin-bottom: 1.5rem; max-width: 600px;">
        <div class="panel-header">
            <h3 class="panel-title">ðŸ” Filter by Project</h3>
        </div>
        <div class="panel-body">
            <div style="margin-bottom: 0.5rem;">
                <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                    Search and select a project to view its users:
                </label>
                <input type="text" 
                       list="projectList" 
                       @bind="projectSearchText"
                       @bind:event="oninput"
                       @onchange="OnProjectSelected"
                       placeholder="Type to search projects..."
                       style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                <datalist id="projectList">
                    @if (allProjects != null)
                    {
                        @foreach (var project in allProjects)
                        {
                            <option value="@project.ProjectName (@project.SchemaName)" data-id="@project.ProjectId">
                                @project.ProjectName (@project.SchemaName)
                            </option>
                        }
                    }
                </datalist>
            </div>
            @if (selectedProjectId.HasValue)
            {
                var selectedProject = allProjects?.FirstOrDefault(p => p.ProjectId == selectedProjectId.Value);
                <div style="margin-top: 0.75rem; padding: 0.5rem; background: #dbeafe; border-radius: 0.375rem; display: flex; justify-content: space-between; align-items: center;">
                    <span style="color: #1e40af; font-size: 0.875rem; font-weight: 500;">
                        ðŸ“ Viewing: @selectedProject?.ProjectName
                    </span>
                    <button style="padding: 0.25rem 0.5rem; background: #3b82f6; color: white; border: none; border-radius: 0.25rem; font-size: 0.75rem; cursor: pointer;" 
                            @onclick="ClearProjectFilter">
                        âœ– Clear
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- Users Table -->
    @if (selectedProjectId.HasValue)
    {
        <div class="lgreeny-panel">
            <div class="panel-header">
                <h3 class="panel-title">
                    @{
                        var project = allProjects?.FirstOrDefault(p => p.ProjectId == selectedProjectId.Value);
                    }
                    <span>ðŸ‘¥ Users with Access to @(project?.ProjectName ?? "Selected Project")</span>
                </h3>
            </div>
            <div class="panel-body">
                <!-- Search/Filter Box -->
                @if (projectUsers != null && projectUsers.Count > 0)
                {
                    <div style="margin-bottom: 1rem;">
                        <div style="position: relative;">
                            <span style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 1rem;">ðŸ”</span>
                            <input type="text" 
                                   @bind="userSearchText"
                                   @bind:event="oninput"
                                   placeholder="Search users by name or username..."
                                   style="width: 100%; padding: 0.5rem 0.5rem 0.5rem 2.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                            @if (!string.IsNullOrWhiteSpace(userSearchText))
                            {
                                <button @onclick="ClearUserSearch"
                                        style="position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%); padding: 0.25rem 0.5rem; background: #f1f5f9; color: #64748b; border: none; border-radius: 0.25rem; font-size: 0.75rem; cursor: pointer;">
                                    âœ– Clear
                                </button>
                            }
                        </div>
                        @{
                            var filteredUsers = FilterUsers(projectUsers);
                        }
                        <div style="margin-top: 0.5rem; color: #64748b; font-size: 0.875rem;">
                            Showing @filteredUsers.Count of @projectUsers.Count users
                        </div>
                    </div>
                }
                
                <!-- Project-specific view -->
                @if (projectUsers == null || projectUsers.Count == 0)
                {
                    <div style="padding: 1rem; background: #fef3c7; border: 1px solid #fde68a; border-radius: 0.5rem; color: #92400e;">
                        âš ï¸ No users have access to this project yet.
                    </div>
                }
                else
                {
                    var displayUsers = FilterUsers(projectUsers);
                    
                    if (displayUsers.Count == 0)
                    {
                        <div style="padding: 1rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.5rem; text-align: center; color: #64748b;">
                            ðŸ” No users match your search criteria
                        </div>
                    }
                    else
                    {
                        <table class="lgreeny-table">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Access Granted</th>
                                    <th>Granted By</th>
                                    <th>Reason</th>
                                    <th>Expires</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var access in displayUsers)
                                {
                                    <tr>
                                        <td>
                                            <strong style="color: #1e293b;">@access.User.DisplayName</strong><br>
                                            <small style="color: #64748b;">@access.User.Username</small>
                                        </td>
                                        <td>
                                            <small style="color: #64748b;">@access.GrantedDate.ToString("MMM dd, yyyy")</small>
                                        </td>
                                        <td>
                                            <small style="color: #64748b;">@(access.GrantedBy ?? "System")</small>
                                        </td>
                                        <td>
                                            <small style="color: #64748b;">@(access.AccessReason ?? "N/A")</small>
                                        </td>
                                        <td>
                                            @if (access.ExpiresDate.HasValue)
                                            {
                                                <small style="color: #f59e0b;">@access.ExpiresDate.Value.ToString("MMM dd, yyyy")</small>
                                            }
                                            else
                                            {
                                                <small style="color: #64748b;">Never</small>
                                            }
                                        </td>
                                        <td>
                                            <button style="padding: 0.375rem 0.75rem; background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; border-radius: 0.375rem; font-size: 0.875rem; cursor: pointer;" 
                                                    @onclick="() => RevokeProjectAccess(access.UserId, access.ProjectId)"
                                                    title="Revoke Access">
                                                âŒ Revoke
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
            </div>
        </div>
    }
    else
    {
        <!-- No project selected message -->
        <div class="lgreeny-panel">
            <div class="panel-body" style="text-align: center; padding: 3rem 1.5rem;">
                <div style="color: #94a3b8; font-size: 3rem; margin-bottom: 1rem;">ï¿½</div>
                <h4 style="color: #1e293b; margin-bottom: 0.5rem;">Select a Project to View Users</h4>
                <p style="color: #64748b; margin: 0;">Use the filter above to search and select a project to see which users have access.</p>
            </div>
        </div>
    }
}
</div>

<!-- Grant Access Modal -->
@if (showGrantAccessDialog)
{
    <div style="position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5); display: flex; align-items: center; justify-content: center; z-index: 1000;">
        <div style="background: white; border-radius: 0.5rem; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); max-width: 500px; width: 100%; margin: 1rem;">
            <div style="padding: 1.5rem; border-bottom: 1px solid #e2e8f0;">
                <h3 style="margin: 0; color: #1e293b; font-size: 1.25rem; font-weight: 600;">âž• Grant Project Access</h3>
            </div>
            <div style="padding: 1.5rem;">
                    <div style="margin-bottom: 1rem;">
                        <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500;">Select User</label>
                        <select style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" 
                                @bind="newAccess.UserId">
                            <option value="">-- Select User --</option>
                            @if (allUsers != null)
                            {
                                @foreach (var user in allUsers.Where(u => u.IsActive))
                                {
                                    <option value="@user.UserId">@user.DisplayName (@user.Username)</option>
                                }
                            }
                        </select>
                    </div>
                    <div style="margin-bottom: 1rem;">
                        <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500;">Select Project</label>
                        <select style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" 
                                @bind="newAccess.ProjectId">
                            <option value="">-- Select Project --</option>
                            @if (allProjects != null)
                            {
                                @foreach (var project in allProjects.Where(p => p.IsActive))
                                {
                                    <option value="@project.ProjectId">@project.ProjectName (@project.SchemaName)</option>
                                }
                            }
                        </select>
                    </div>
                    <div style="margin-bottom: 1rem;">
                        <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500;">Reason for Access (Optional)</label>
                        <textarea style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem; font-family: inherit;" 
                                  @bind="newAccess.AccessReason" rows="3" placeholder="Business justification for granting access..."></textarea>
                    </div>
                    <div style="margin-bottom: 1rem;">
                        <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500;">Expiration Date (Optional)</label>
                        <input type="date" 
                               style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" 
                               @bind="newAccess.ExpiresDate" />
                        <div style="color: #64748b; font-size: 0.75rem; margin-top: 0.25rem;">Leave blank for permanent access</div>
                    </div>
                </div>
                <div style="padding: 1rem 1.5rem; border-top: 1px solid #e2e8f0; display: flex; gap: 0.75rem; justify-content: flex-end;">
                    <button class="lgreeny-btn-secondary" @onclick="CloseGrantAccessDialog">Cancel</button>
                    <button class="lgreeny-btn-primary" @onclick="GrantProjectAccess">âœ… Grant Access</button>
                </div>
        </div>
    </div>
}

<!-- Manage User Access Modal -->
@if (showManageUserAccessDialog && selectedUser != null)
{
    <div style="position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5); display: flex; align-items: center; justify-content: center; z-index: 1000;">
        <div style="background: white; border-radius: 0.5rem; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); max-width: 700px; width: 100%; margin: 1rem; max-height: 80vh; display: flex; flex-direction: column;">
            <div style="padding: 1.5rem; border-bottom: 1px solid #e2e8f0;">
                <h3 style="margin: 0; color: #1e293b; font-size: 1.25rem; font-weight: 600;">âš™ï¸ Manage Project Access - @selectedUser.DisplayName</h3>
            </div>
            <div style="padding: 1.5rem; overflow-y: auto; flex: 1;">
                <p style="color: #64748b; margin-bottom: 1rem;">Manage which projects <strong>@selectedUser.DisplayName</strong> can access:</p>
                @if (allProjects != null)
                {
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;">
                        @foreach (var project in allProjects)
                        {
                            var hasAccess = selectedUserAccess.Any(ua => ua.ProjectId == project.ProjectId);
                            <div style="padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; background: #f8fafc;">
                                <label style="display: flex; align-items: start; gap: 0.5rem; cursor: pointer;">
                                    <input type="checkbox" 
                                           style="margin-top: 0.25rem;"
                                           id="project-@project.ProjectId"
                                           checked="@hasAccess"
                                           @onchange="(e) => ToggleUserProjectAccess(project.ProjectId, (bool)e.Value!)" />
                                    <div>
                                        <strong style="color: #1e293b;">@project.ProjectName</strong><br>
                                        <small style="color: #64748b;">@project.SchemaName</small>
                                    </div>
                                </label>
                            </div>
                        }
                    </div>
                }
            </div>
            <div style="padding: 1rem 1.5rem; border-top: 1px solid #e2e8f0; display: flex; gap: 0.75rem; justify-content: flex-end;">
                <button class="lgreeny-btn-secondary" @onclick="CloseManageUserAccessDialog">Close</button>
                <button class="lgreeny-btn-primary" @onclick="SaveUserProjectAccess">ðŸ’¾ Save Changes</button>
            </div>
        </div>
    </div>
}

@code {
    private List<ApplicationUser>? allUsers;
    private List<Project>? allProjects;
    private List<UserProjectAccessInfo> userProjectAccess = new();
    private List<UserProjectAccessInfo> projectUsers = new();
    private bool isLoading = true;
    private string? errorMessage;
    
    private int? selectedProjectId;
    private string projectSearchText = string.Empty;
    private string userSearchText = string.Empty;
    private int totalAccessRecords = 0;
    private int usersWithProjectAccess = 0;

    // Dialog states
    private bool showGrantAccessDialog = false;
    private bool showManageUserAccessDialog = false;
    
    // Selected items
    private ApplicationUser? selectedUser;
    private List<UserProjectAccessInfo> selectedUserAccess = new();
    
    // New access data
    private NewAccessModel newAccess = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // Load all users and projects
            allUsers = await UserService.GetAllUsersAsync();
            allProjects = (await ProjectService.GetAllProjectsAsync()).ToList();

            // Load all user project access records
            userProjectAccess.Clear();
            foreach (var user in allUsers)
            {
                var userAccess = await UserProjectAccessService.GetUserProjectAccessAsync(user.UserId);
                userProjectAccess.AddRange(userAccess);
            }

            // Calculate statistics
            totalAccessRecords = userProjectAccess.Count;
            usersWithProjectAccess = userProjectAccess.Select(upa => upa.UserId).Distinct().Count();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadProjectUsers()
    {
        if (!selectedProjectId.HasValue) 
        {
            projectUsers.Clear();
            return;
        }

        try
        {
            projectUsers = await UserProjectAccessService.GetProjectUsersAsync(selectedProjectId.Value);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task OnProjectSelected()
    {
        if (string.IsNullOrWhiteSpace(projectSearchText))
        {
            selectedProjectId = null;
            projectUsers.Clear();
            return;
        }

        // Try to find the project by matching the search text format: "ProjectName (SchemaName)"
        var matchedProject = allProjects?.FirstOrDefault(p => 
            $"{p.ProjectName} ({p.SchemaName})" == projectSearchText);

        if (matchedProject != null)
        {
            selectedProjectId = matchedProject.ProjectId;
            await LoadProjectUsers();
        }
        else
        {
            // If no exact match, clear the selection
            selectedProjectId = null;
            projectUsers.Clear();
        }
    }

    private void ClearProjectFilter()
    {
        selectedProjectId = null;
        projectSearchText = string.Empty;
        projectUsers.Clear();
        userSearchText = string.Empty;
    }

    private void ClearUserSearch()
    {
        userSearchText = string.Empty;
    }

    private List<UserProjectAccessInfo> FilterUsers(List<UserProjectAccessInfo> users)
    {
        if (string.IsNullOrWhiteSpace(userSearchText))
        {
            return users;
        }

        var searchTerm = userSearchText.ToLower();
        return users.Where(u => 
            (u.User.DisplayName?.ToLower().Contains(searchTerm) ?? false) ||
            (u.User.Username?.ToLower().Contains(searchTerm) ?? false)
        ).ToList();
    }

    private void OpenGrantAccessDialog()
    {
        newAccess = new NewAccessModel();
        showGrantAccessDialog = true;
    }

    private void CloseGrantAccessDialog()
    {
        showGrantAccessDialog = false;
        newAccess = new();
    }

    private async Task GrantProjectAccess()
    {
        if (newAccess.UserId == 0 || newAccess.ProjectId == 0)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Please select both a user and a project.");
            return;
        }

        try
        {
            await UserProjectAccessService.GrantProjectAccessAsync(
                newAccess.UserId,
                newAccess.ProjectId,
                "System Admin", // Could get current user here
                newAccess.AccessReason,
                newAccess.ExpiresDate);

            await LoadData();
            if (selectedProjectId.HasValue)
            {
                await LoadProjectUsers();
            }
            CloseGrantAccessDialog();
            await JSRuntime.InvokeVoidAsync("alert", "Project access granted successfully!");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error granting access: {ex.Message}");
        }
    }

    private async Task RevokeProjectAccess(int userId, int projectId)
    {
        var user = allUsers?.FirstOrDefault(u => u.UserId == userId);
        var project = allProjects?.FirstOrDefault(p => p.ProjectId == projectId);
        
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            $"Revoke project access for {user?.DisplayName} from {project?.ProjectName}?");

        if (confirmed)
        {
            try
            {
                await UserProjectAccessService.RevokeProjectAccessAsync(userId, projectId);
                await LoadData();
                if (selectedProjectId.HasValue)
                {
                    await LoadProjectUsers();
                }
                await JSRuntime.InvokeVoidAsync("alert", "Project access revoked successfully!");
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Error revoking access: {ex.Message}");
            }
        }
    }

    private async Task OpenManageUserAccessDialog(ApplicationUser user)
    {
        selectedUser = user;
        selectedUserAccess = await UserProjectAccessService.GetUserProjectAccessAsync(user.UserId);
        showManageUserAccessDialog = true;
    }

    private void CloseManageUserAccessDialog()
    {
        showManageUserAccessDialog = false;
        selectedUser = null;
        selectedUserAccess.Clear();
    }

    private void ToggleUserProjectAccess(int projectId, bool hasAccess)
    {
        if (hasAccess)
        {
            // Add access if not already present
            if (!selectedUserAccess.Any(ua => ua.ProjectId == projectId))
            {
                var project = allProjects?.FirstOrDefault(p => p.ProjectId == projectId);
                if (project != null)
                {
                    selectedUserAccess.Add(new UserProjectAccessInfo
                    {
                        UserId = selectedUser!.UserId,
                        ProjectId = projectId,
                        User = selectedUser!,
                        Project = project,
                        GrantedDate = DateTime.UtcNow
                    });
                }
            }
        }
        else
        {
            // Remove access
            selectedUserAccess.RemoveAll(ua => ua.ProjectId == projectId);
        }
    }

    private async Task SaveUserProjectAccess()
    {
        if (selectedUser == null) return;

        try
        {
            var currentAccess = await UserProjectAccessService.GetUserProjectAccessAsync(selectedUser.UserId);
            var currentProjectIds = currentAccess.Select(ua => ua.ProjectId).ToHashSet();
            var newProjectIds = selectedUserAccess.Select(ua => ua.ProjectId).ToHashSet();

            // Revoke access for projects not in the new list
            foreach (var projectId in currentProjectIds)
            {
                if (!newProjectIds.Contains(projectId))
                {
                    await UserProjectAccessService.RevokeProjectAccessAsync(selectedUser.UserId, projectId);
                }
            }

            // Grant access for new projects
            foreach (var projectId in newProjectIds)
            {
                if (!currentProjectIds.Contains(projectId))
                {
                    await UserProjectAccessService.GrantProjectAccessAsync(
                        selectedUser.UserId,
                        projectId,
                        "System Admin",
                        "Assigned via User Project Access Management");
                }
            }

            await LoadData();
            CloseManageUserAccessDialog();
            await JSRuntime.InvokeVoidAsync("alert", "User project access updated successfully!");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error updating access: {ex.Message}");
        }
    }

    public class NewAccessModel
    {
        public int UserId { get; set; }
        public int ProjectId { get; set; }
        public string? AccessReason { get; set; }
        public DateTime? ExpiresDate { get; set; }
    }
}