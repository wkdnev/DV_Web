@page "/admin/document-import"
@attribute [Authorize(Policy = "GlobalAdminOnly")]
@using DV.Web.Services
@using DV.Shared.Models
@using DV.Web.Components.Documents
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@inject DocumentUploadService DocumentUploadService
@inject ProjectService ProjectService
@inject DocumentRepository DocumentRepository
@inject AppDbContext DbContext
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject IDbContextFactory<SecurityDbContext> SecurityDbContextFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@rendermode InteractiveServer

<PageTitle>Document Management</PageTitle>

<div class="lgreeny-dashboard">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <div>
            <h2 style="margin: 0; color: #1e293b; font-size: 1.75rem; font-weight: 600;">ðŸ“¦ Document Management</h2>
            <p style="margin: 0.5rem 0 0 0; color: #64748b; font-size: 0.875rem;">Manage, upload, and organize documents across projects</p>
        </div>
        <button class="lgreeny-btn-secondary" style="width: auto;" @onclick="GoBackToDashboard">
            â† Back to Dashboard
        </button>
    </div>

    <!-- Upload Instructions Card (Full Width) -->
    <div class="lgreeny-panel" style="margin-bottom: 1.5rem;">
        <div class="panel-header">
            <h3 class="panel-title">ðŸ“‹ Document Upload Instructions</h3>
        </div>
        <div class="panel-body">
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">
                <div>
                    <h6 style="color: #1e293b; font-weight: 600; margin-bottom: 0.75rem;">âœ… Supported File Types:</h6>
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        <li style="padding: 0.375rem 0; color: #64748b; font-size: 0.875rem;">ðŸ“„ PDF Documents</li>
                        <li style="padding: 0.375rem 0; color: #64748b; font-size: 0.875rem;">ðŸ–¼ï¸ TIFF Images</li>
                        <li style="padding: 0.375rem 0; color: #64748b; font-size: 0.875rem;">ðŸ–¼ï¸ JPEG/PNG/BMP/GIF Images</li>
                    </ul>
                </div>
                <div>
                    <h6 style="color: #1e293b; font-weight: 600; margin-bottom: 0.75rem;">ðŸ“Š File Limits:</h6>
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        <li style="padding: 0.375rem 0; color: #64748b; font-size: 0.875rem;">â€¢ Maximum size: 50MB per file</li>
                        <li style="padding: 0.375rem 0; color: #64748b; font-size: 0.875rem;">â€¢ Stored as BLOB in database</li>
                        <li style="padding: 0.375rem 0; color: #64748b; font-size: 0.875rem;">â€¢ Automatic checksum verification</li>
                    </ul>
                </div>
                <div>
                    <h6 style="color: #1e293b; font-weight: 600; margin-bottom: 0.75rem;">ðŸ”§ Available Actions:</h6>
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        <li style="padding: 0.375rem 0; color: #64748b; font-size: 0.875rem;">â€¢ View document details and pages</li>
                        <li style="padding: 0.375rem 0; color: #64748b; font-size: 0.875rem;">â€¢ Edit metadata and properties</li>
                        <li style="padding: 0.375rem 0; color: #64748b; font-size: 0.875rem;">â€¢ Upload additional pages</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Project/Schema Selection -->
    <div class="lgreeny-panel" style="margin-bottom: 1.5rem;">
        <div class="panel-header">
            <h3 class="panel-title">ï¿½ï¸ Select Project / Schema</h3>
        </div>
        <div class="panel-body">
            <div style="display: grid; grid-template-columns: 1fr auto; gap: 1rem; align-items: end;">
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                        Select a project to view and manage its documents:
                    </label>
                    <select @bind="selectedProjectId" 
                            @bind:after="OnProjectSelected"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;">
                        <option value="0">-- Select a Project --</option>
                        @if (allProjects != null)
                        {
                            @foreach (var project in allProjects)
                            {
                                <option value="@project.ProjectId">@project.ProjectName (@project.SchemaName)</option>
                            }
                        }
                    </select>
                </div>
                <button class="lgreeny-btn-primary" style="width: auto;" @onclick="OpenUploadDialog" disabled="@(selectedProjectId == 0)">
                    âž• Upload New Document
                </button>
            </div>
            
            @if (selectedProjectId > 0 && selectedProject != null)
            {
                <div style="margin-top: 1rem; padding: 0.75rem; background: #dbeafe; border-radius: 0.375rem;">
                    <span style="color: #1e40af; font-size: 0.875rem; font-weight: 500;">
                        ðŸ“ Selected Project: @selectedProject.ProjectName
                    </span>
                    <span style="color: #64748b; font-size: 0.875rem; margin-left: 1rem;">
                        Schema: @selectedProject.SchemaName
                    </span>
                </div>
            }
        </div>
    </div>

    <!-- Documents Table -->
    @if (selectedProjectId > 0)
    {
        @if (isLoadingDocuments)
        {
            <div style="text-align: center; padding: 3rem;">
                <div style="color: #3b82f6; font-size: 2rem;">â³</div>
                <p style="color: #64748b; margin-top: 1rem;">Loading documents...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="padding: 1rem; background: #fee2e2; border: 1px solid #fecaca; border-radius: 0.5rem; margin-bottom: 1.5rem; color: #991b1b;">
                âš ï¸ @errorMessage
            </div>
        }
        else
        {
            <div class="lgreeny-panel">
                <div class="panel-header">
                    <h3 class="panel-title">ï¿½ Documents in @selectedProject?.ProjectName</h3>
                </div>
                <div class="panel-body">
                    <!-- Search/Filter Box -->
                    <div style="margin-bottom: 1rem;">
                        <div style="position: relative;">
                            <span style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 1rem;">ðŸ”</span>
                            <input type="text" 
                                   @bind="searchText"
                                   @bind:event="oninput"
                                   @bind:after="OnSearchChanged"
                                   placeholder="Search by document number, title, author, or keywords..."
                                   style="width: 100%; padding: 0.5rem 0.5rem 0.5rem 2.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                            @if (!string.IsNullOrWhiteSpace(searchText))
                            {
                                <button @onclick="ClearSearch"
                                        style="position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%); padding: 0.25rem 0.5rem; background: #f1f5f9; color: #64748b; border: none; border-radius: 0.25rem; font-size: 0.75rem; cursor: pointer;">
                                    âœ– Clear
                                </button>
                            }
                        </div>
                        @if (filteredDocuments != null)
                        {
                            <div style="margin-top: 0.5rem; color: #64748b; font-size: 0.875rem;">
                                Showing @filteredDocuments.Count of @allDocuments.Count documents
                            </div>
                        }
                    </div>

                    <!-- Documents Table -->
                    @if (filteredDocuments == null || filteredDocuments.Count == 0)
                    {
                        <div style="padding: 2rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.5rem; text-align: center; color: #64748b;">
                            @if (string.IsNullOrWhiteSpace(searchText))
                            {
                                <div style="font-size: 2rem; margin-bottom: 0.5rem;">ðŸ“­</div>
                                <p>No documents found in this project.</p>
                                <button class="lgreeny-btn-primary" style="margin-top: 1rem;" @onclick="OpenUploadDialog">
                                    âž• Upload First Document
                                </button>
                            }
                            else
                            {
                                <div style="font-size: 2rem; margin-bottom: 0.5rem;">ðŸ”</div>
                                <p>No documents match your search criteria.</p>
                            }
                        </div>
                    }
                    else
                    {
                        <table class="lgreeny-table">
                            <thead>
                                <tr>
                                    <th>Document #</th>
                                    <th>Title</th>
                                    <th>Type</th>
                                    <th>Author</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                    <th style="text-align: right;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in filteredDocuments)
                                {
                                    <tr>
                                        <td>
                                            <strong style="color: #1e293b; font-family: monospace;">@doc.DocumentNumber</strong>
                                        </td>
                                        <td>
                                            <strong style="color: #1e293b;">@doc.Title</strong>
                                            @if (!string.IsNullOrEmpty(doc.Keywords))
                                            {
                                                <br>
                                                <small style="color: #94a3b8;">ðŸ·ï¸ @doc.Keywords</small>
                                            }
                                        </td>
                                        <td>
                                            <span style="padding: 0.25rem 0.5rem; background: #dbeafe; color: #1e40af; border-radius: 0.25rem; font-size: 0.75rem; font-weight: 500;">
                                                @doc.DocumentType
                                            </span>
                                        </td>
                                        <td>
                                            <small style="color: #64748b;">@doc.Author</small>
                                        </td>
                                        <td>
                                            <span style="padding: 0.25rem 0.5rem; background: @GetStatusColor(doc.DocumentStatus); border-radius: 0.25rem; font-size: 0.75rem; font-weight: 500;">
                                                @doc.DocumentStatus
                                            </span>
                                        </td>
                                        <td>
                                            <small style="color: #64748b;">@doc.CreatedOn.ToString("MMM dd, yyyy")</small>
                                        </td>
                                        <td>
                                            <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                                                <button style="padding: 0.375rem 0.75rem; background: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe; border-radius: 0.375rem; font-size: 0.75rem; cursor: pointer;" 
                                                        @onclick="() => ViewDocument(doc)"
                                                        title="View Document">
                                                    ðŸ‘ï¸ View
                                                </button>
                                                <button style="padding: 0.375rem 0.75rem; background: #fef3c7; color: #92400e; border: 1px solid #fde68a; border-radius: 0.375rem; font-size: 0.75rem; cursor: pointer;" 
                                                        @onclick="() => EditDocument(doc)"
                                                        title="Edit Metadata">
                                                    âœï¸ Edit
                                                </button>
                                                <button style="padding: 0.375rem 0.75rem; background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; border-radius: 0.375rem; font-size: 0.75rem; cursor: pointer;" 
                                                        @onclick="() => UploadPages(doc)"
                                                        title="Upload Pages">
                                                    ðŸ“„ Pages
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="lgreeny-panel">
            <div class="panel-body" style="text-align: center; padding: 3rem;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">ðŸ“‚</div>
                <h4 style="color: #1e293b; margin-bottom: 0.5rem;">Select a Project to Begin</h4>
                <p style="color: #64748b; max-width: 600px; margin: 0 auto;">
                    Choose a project from the dropdown above to view and manage its documents. You can upload new documents, edit existing ones, and manage document pages.
                </p>
            </div>
        </div>
    }

    <!-- Upload Dialog Modal -->
    @if (showUploadDialog)
    {
        <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;" @onclick="CloseUploadDialog">
            <div style="background: white; border-radius: 0.5rem; padding: 2rem; max-width: 800px; width: 90%; max-height: 90vh; overflow-y: auto;" @onclick:stopPropagation>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <h3 style="margin: 0; color: #1e293b;">ðŸ“¤ Upload Document to @selectedProject?.ProjectName</h3>
                    <button @onclick="CloseUploadDialog" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #64748b;">âœ–</button>
                </div>
                <DocumentUpload OnUploadCompleted="OnDocumentUploaded" />
            </div>
        </div>
    }

    <!-- Upload Pages Dialog Modal -->
    @if (showUploadPagesDialog && selectedDocumentForPages != null)
    {
        <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;" @onclick="CloseUploadPagesDialog">
            <div style="background: white; border-radius: 0.5rem; padding: 2rem; max-width: 800px; width: 90%; max-height: 90vh; overflow-y: auto;" @onclick:stopPropagation>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <div>
                        <h3 style="margin: 0; color: #1e293b;">ðŸ“„ Upload Pages</h3>
                        <p style="margin: 0.5rem 0 0 0; color: #64748b; font-size: 0.875rem;">
                            Document: <strong>@selectedDocumentForPages.DocumentNumber</strong> - @selectedDocumentForPages.Title
                        </p>
                    </div>
                    <button @onclick="CloseUploadPagesDialog" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #64748b;">âœ–</button>
                </div>

                @if (isLoadingPages)
                {
                    <div style="text-align: center; padding: 2rem; color: #64748b;">
                        <div style="font-size: 2rem; margin-bottom: 0.5rem;">â³</div>
                        <p>Loading existing pages...</p>
                    </div>
                }
                else
                {
                    @if (existingPages != null && existingPages.Any())
                    {
                        <div style="padding: 1rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.375rem; margin-bottom: 1rem;">
                            <h6 style="margin: 0 0 0.5rem 0; color: #1e293b; font-size: 0.875rem; font-weight: 600;">
                                ðŸ“‹ Existing Pages (@existingPages.Count)
                            </h6>
                            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                                @foreach (var page in existingPages.OrderBy(p => p.PageNumber))
                                {
                                    var pageInfo = string.IsNullOrEmpty(page.PageReference) ? $"Page {page.PageNumber}" : $"Page {page.PageNumber}: {page.PageReference}";
                                    <button type="button"
                                            @onclick="() => OpenEditPageDialog(page)"
                                            style="padding: 0.25rem 0.5rem; background: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe; border-radius: 0.25rem; font-size: 0.75rem; font-weight: 500; cursor: pointer; transition: all 0.2s;"
                                            title="Click to edit this page">
                                        @pageInfo âœï¸
                                    </button>
                                }
                            </div>
                            <div style="margin-top: 0.5rem; color: #64748b; font-size: 0.75rem;">
                                ðŸ’¡ Next available page number: <strong>@suggestedPageNumber</strong> | Click any page badge to edit
                            </div>
                        </div>
                    }
                    else
                    {
                        <div style="padding: 1rem; background: #fef3c7; border: 1px solid #fde68a; border-radius: 0.375rem; margin-bottom: 1rem;">
                            <div style="color: #92400e; font-size: 0.875rem;">
                                ðŸ“­ No pages uploaded yet. This will be the first page.
                            </div>
                        </div>
                    }
                }

                @if (!string.IsNullOrEmpty(pageUploadErrorMessage))
                {
                    <div style="padding: 1rem; background: #fee2e2; border: 1px solid #fecaca; border-radius: 0.5rem; margin-bottom: 1rem; color: #991b1b;">
                        âš ï¸ @pageUploadErrorMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(pageUploadSuccessMessage))
                    {
                        <div style="padding: 1rem; background: #d1fae5; border: 1px solid #a7f3d0; border-radius: 0.5rem; margin-bottom: 1rem; color: #065f46;">
                            âœ… @pageUploadSuccessMessage
                        </div>
                    }

                    <div style="display: grid; gap: 1rem;">
                        <!-- Page Number -->
                        <div>
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                <label style="color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                                    Page Number *
                                </label>
                                @if (existingPages != null && existingPages.Any() && newPageNumber != suggestedPageNumber)
                                {
                                    <button type="button" 
                                            @onclick="() => newPageNumber = suggestedPageNumber"
                                            style="padding: 0.25rem 0.5rem; background: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe; border-radius: 0.25rem; font-size: 0.75rem; cursor: pointer;">
                                        Use Suggested (@suggestedPageNumber)
                                    </button>
                                }
                            </div>
                            <input type="number" 
                                   @bind="newPageNumber"
                                   min="1"
                                   style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                            <small style="color: #64748b; font-size: 0.75rem;">
                                @if (existingPages != null && existingPages.Any(p => p.PageNumber == newPageNumber))
                                {
                                    <span style="color: #dc2626; font-weight: 500;">âš ï¸ Page @newPageNumber already exists! Use a different number.</span>
                                }
                                else if (existingPages != null && existingPages.Any())
                                {
                                    <span>ðŸ’¡ Suggested next page: <strong>@suggestedPageNumber</strong></span>
                                }
                                else
                                {
                                    <span>Specify the page number for this document page</span>
                                }
                            </small>
                        </div>

                    <!-- Page Reference -->
                    <div>
                        <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                            Page Reference (Optional)
                        </label>
                        <input type="text" 
                               @bind="newPageReference"
                               placeholder="e.g., 'Cover Page', 'Appendix A'"
                               style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                        <small style="color: #64748b; font-size: 0.75rem;">Optional description or reference for this page</small>
                    </div>

                    <!-- File Upload -->
                    <div>
                        <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                            Select File *
                        </label>
                        <InputFile OnChange="HandlePageFileSelected" 
                                   accept=".pdf,.tiff,.tif,.jpg,.jpeg,.png,.bmp,.gif"
                                   style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                        <small style="color: #64748b; font-size: 0.75rem;">
                            Supported: PDF, TIFF, JPEG, PNG, BMP, GIF (Max: 50MB)
                        </small>
                    </div>

                    @if (selectedPageFile != null)
                    {
                        <div style="padding: 1rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.375rem;">
                            <h6 style="margin: 0 0 0.5rem 0; color: #1e293b; font-size: 0.875rem; font-weight: 600;">Selected File:</h6>
                            <div style="display: grid; grid-template-columns: auto 1fr; gap: 0.5rem; font-size: 0.875rem;">
                                <span style="color: #64748b;">Name:</span>
                                <span style="color: #1e293b; font-weight: 500;">@selectedPageFile.Name</span>
                                <span style="color: #64748b;">Size:</span>
                                <span style="color: #1e293b; font-weight: 500;">@FormatFileSize(selectedPageFile.Size)</span>
                                <span style="color: #64748b;">Type:</span>
                                <span style="color: #1e293b; font-weight: 500;">@selectedPageFile.ContentType</span>
                            </div>
                        </div>
                    }
                </div>

                <!-- Action Buttons -->
                <div style="display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 1.5rem;">
                    <button class="lgreeny-btn-secondary" @onclick="CloseUploadPagesDialog" disabled="@isUploadingPage">
                        Cancel
                    </button>
                    <button class="lgreeny-btn-primary" @onclick="UploadPageToDocument" disabled="@(!CanUploadPage() || isUploadingPage)">
                        @if (isUploadingPage)
                        {
                            <span>â³ Uploading...</span>
                        }
                        else
                        {
                            <span>ðŸ“¤ Upload Page</span>
                        }
                    </button>
                </div>
                }
            </div>
        </div>
    }

    <!-- Edit Page Dialog Modal -->
    @if (showEditPageDialog && editingPage != null)
    {
        <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1001; display: flex; align-items: center; justify-content: center;" @onclick="CloseEditPageDialog">
            <div style="background: white; border-radius: 0.5rem; padding: 2rem; max-width: 700px; width: 90%; max-height: 90vh; overflow-y: auto;" @onclick:stopPropagation>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <div>
                        <h3 style="margin: 0; color: #1e293b;">âœï¸ Edit Page Details</h3>
                        <p style="margin: 0.5rem 0 0 0; color: #64748b; font-size: 0.875rem;">
                            Document: <strong>@selectedDocumentForPages?.DocumentNumber</strong>
                        </p>
                    </div>
                    <button @onclick="CloseEditPageDialog" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #64748b;">âœ–</button>
                </div>

                @if (!string.IsNullOrEmpty(pageEditErrorMessage))
                {
                    <div style="padding: 1rem; background: #fee2e2; border: 1px solid #fecaca; border-radius: 0.5rem; margin-bottom: 1rem; color: #991b1b;">
                        âš ï¸ @pageEditErrorMessage
                    </div>
                }

                @if (!string.IsNullOrEmpty(pageEditSuccessMessage))
                {
                    <div style="padding: 1rem; background: #d1fae5; border: 1px solid #a7f3d0; border-radius: 0.5rem; margin-bottom: 1rem; color: #065f46;">
                        âœ… @pageEditSuccessMessage
                    </div>
                }

                <div style="display: grid; gap: 1rem;">
                    <!-- Current Page Info -->
                    <div style="padding: 1rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.375rem;">
                        <div style="display: grid; grid-template-columns: auto 1fr; gap: 0.5rem; font-size: 0.875rem;">
                            <span style="color: #64748b;">Page ID:</span>
                            <span style="color: #1e293b; font-weight: 500;">@editingPage.PageId</span>
                            <span style="color: #64748b;">Current Page Number:</span>
                            <span style="color: #1e293b; font-weight: 500;">@editingPage.PageNumber</span>
                            <span style="color: #64748b;">File Size:</span>
                            <span style="color: #1e293b; font-weight: 500;">@FormatFileSize(editingPage.FileSize ?? 0)</span>
                            <span style="color: #64748b;">Content Type:</span>
                            <span style="color: #1e293b; font-weight: 500;">@editingPage.ContentType</span>
                        </div>
                    </div>

                    <!-- Page Number -->
                    <div>
                        <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                            Page Number *
                        </label>
                        <input type="number" 
                               @bind="editPageNumber"
                               min="1"
                               style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                        <small style="color: #64748b; font-size: 0.75rem;">
                            @if (existingPages != null && existingPages.Any(p => p.PageNumber == editPageNumber && p.PageId != editingPage.PageId))
                            {
