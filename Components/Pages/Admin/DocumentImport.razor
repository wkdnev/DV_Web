@code {
    // Project selection
    private int selectedProjectId = 0;
    private Project? selectedProject;
    private IEnumerable<Project>? allProjects;

    // Document management
    private List<Document> allDocuments = new();
    private List<Document> filteredDocuments = new();
    private bool isLoadingDocuments = false;
    private string searchText = string.Empty;
    private string? errorMessage;

    // Upload dialog
    private bool showUploadDialog = false;

    // Edit dialog
    private bool showEditDialog = false;
    private EditableDocument? editingDocument = null;
    private bool isSaving = false;
    private string? editErrorMessage;
    private string? editSuccessMessage;

    // Editable document class for two-way binding
    private class EditableDocument
    {
        public int DocumentId { get; set; }
        public string DocumentNumber { get; set; } = string.Empty;
        public string? Title { get; set; }
        public string? Author { get; set; }
        public string DocumentType { get; set; } = "PDF";
        public string? DocumentStatus { get; set; }
        public string? Classification { get; set; }
        public string? Keywords { get; set; }
        public string? DocumentIndex { get; set; }
        public string? Issue { get; set; }
        public string? Memo { get; set; }
    }

    // Page upload dialog
    private bool showUploadPagesDialog = false;
    private Document? selectedDocumentForPages = null;
    private int newPageNumber = 1;
    private int suggestedPageNumber = 1;
    private string newPageReference = string.Empty;
    private IBrowserFile? selectedPageFile = null;
    private bool isUploadingPage = false;
    private bool isLoadingPages = false;
    private List<DocumentPage>? existingPages = null;
    private string? pageUploadErrorMessage;
    private string? pageUploadSuccessMessage;

    // Page edit dialog
    private bool showEditPageDialog = false;
    private DocumentPage? editingPage = null;
    private int editPageNumber = 1;
    private string editPageReference = string.Empty;
    private IBrowserFile? editPageFile = null;
    private bool isEditingPage = false;
    private string? pageEditErrorMessage;
    private string? pageEditSuccessMessage;

    // Migration related (kept for backward compatibility - not used in this redesigned interface)
    private int? migrationDocumentId;
    #pragma warning disable CS0414 // Field is assigned but its value is never used - reserved for future migration features
    private bool isMigrating = false;
    #pragma warning restore CS0414
    private string? migrationError;
    private DocumentMigrationResult? migrationResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        try
        {
            allProjects = await ProjectService.GetActiveProjectsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading projects: {ex.Message}";
        }
    }

    private async Task OnProjectSelected()
    {
        if (selectedProjectId > 0)
        {
            selectedProject = allProjects?.FirstOrDefault(p => p.ProjectId == selectedProjectId);
            await LoadDocumentsForProject();
        }
        else
        {
            selectedProject = null;
            allDocuments.Clear();
            filteredDocuments.Clear();
        }
    }

    private async Task LoadDocumentsForProject()
    {
        if (selectedProject == null || string.IsNullOrEmpty(selectedProject.SchemaName))
        {
            return;
        }

        isLoadingDocuments = true;
        errorMessage = null;

        try
        {
            // Load documents from the selected project's schema
            var documents = await DocumentRepository.SearchAsync("DefaultConnection", null, 1, 1000, selectedProjectId);
            allDocuments = documents.ToList();
            filteredDocuments = allDocuments;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading documents: {ex.Message}";
            allDocuments.Clear();
            filteredDocuments.Clear();
        }
        finally
        {
            isLoadingDocuments = false;
        }
    }

    private void OnSearchChanged()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredDocuments = allDocuments;
        }
        else
        {
            var searchLower = searchText.ToLower();
            filteredDocuments = allDocuments.Where(d =>
                (d.DocumentNumber?.ToLower().Contains(searchLower) ?? false) ||
                (d.Title?.ToLower().Contains(searchLower) ?? false) ||
                (d.Author?.ToLower().Contains(searchLower) ?? false) ||
                (d.Keywords?.ToLower().Contains(searchLower) ?? false)
            ).ToList();
        }
    }

    private void ClearSearch()
    {
        searchText = string.Empty;
        OnSearchChanged();
    }

    private string GetStatusColor(string? status)
    {
        return status?.ToLower() switch
        {
            "active" or "approved" or "final" => "#d1fae5", // green
            "draft" or "pending" => "#fef3c7", // yellow
            "archived" or "superseded" => "#f3f4f6", // gray
            "cancelled" or "rejected" => "#fee2e2", // red
            _ => "#dbeafe" // blue default
        };
    }

    private void ViewDocument(Document doc)
    {
        if (selectedProject != null)
        {
            Navigation.NavigateTo($"/viewdoc/DefaultConnection/{doc.DocumentId}");
        }
    }

    private void EditDocument(Document doc)
    {
        // Create an editable copy of the document
        editingDocument = new EditableDocument
        {
            DocumentId = doc.DocumentId,
            DocumentNumber = doc.DocumentNumber,
            Title = doc.Title,
            Author = doc.Author,
            DocumentType = doc.DocumentType ?? "PDF",
            DocumentStatus = doc.DocumentStatus,
            Classification = doc.Classification,
            Keywords = doc.Keywords,
            DocumentIndex = doc.DocumentIndex,
            Issue = doc.Issue,
            Memo = doc.Memo
        };
        editErrorMessage = null;
        editSuccessMessage = null;
        showEditDialog = true;
    }

    private void CloseEditDialog()
    {
        showEditDialog = false;
        editingDocument = null;
        editErrorMessage = null;
        editSuccessMessage = null;
    }

    private async Task SaveDocumentChanges()
    {
        if (editingDocument == null || selectedProject == null)
        {
            return;
        }

        // Validate required fields
        if (string.IsNullOrWhiteSpace(editingDocument.DocumentNumber))
        {
            editErrorMessage = "Document Number is required.";
            return;
        }

        isSaving = true;
        editErrorMessage = null;
        editSuccessMessage = null;

        try
        {
            // Update the document in the database using raw SQL
            var sql = $@"
                UPDATE [{selectedProject.SchemaName}].[Document]
                SET 
                    DocumentNumber = {{0}},
                    Title = {{1}},
                    Author = {{2}},
                    DocumentType = {{3}},
                    DocumentStatus = {{4}},
                    Classification = {{5}},
                    Keywords = {{6}},
                    DocumentIndex = {{7}},
                    Issue = {{8}},
                    Memo = {{9}},
                    ModifiedOn = {{10}}
                WHERE DocumentId = {{11}}";

            var rowsAffected = await DbContext.Database.ExecuteSqlRawAsync(
                sql,
                editingDocument.DocumentNumber!,
                editingDocument.Title!,
                editingDocument.Author!,
                editingDocument.DocumentType!,
                editingDocument.DocumentStatus!,
                editingDocument.Classification!,
                editingDocument.Keywords!,
                editingDocument.DocumentIndex!,
                editingDocument.Issue!,
                editingDocument.Memo!,
                DateTime.UtcNow,
                editingDocument.DocumentId
            );

            if (rowsAffected > 0)
            {
                editSuccessMessage = "Document updated successfully!";
                
                // Reload the documents list to show updated data
                await LoadDocumentsForProject();
                
                // Close dialog after a short delay
                await Task.Delay(1500);
                CloseEditDialog();
            }
            else
            {
                editErrorMessage = "No changes were made to the document.";
            }
        }
        catch (Exception ex)
        {
            editErrorMessage = $"Error saving document: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task UploadPages(Document doc)
    {
        selectedDocumentForPages = doc;
        newPageNumber = 1;
        suggestedPageNumber = 1;
        newPageReference = string.Empty;
        selectedPageFile = null;
        pageUploadErrorMessage = null;
        pageUploadSuccessMessage = null;
        existingPages = null;
        showUploadPagesDialog = true;
        
        // Load existing pages for this document
        await LoadExistingPages();
    }

    private async Task LoadExistingPages()
    {
        if (selectedDocumentForPages == null)
        {
            return;
        }

        isLoadingPages = true;
        
        try
        {
            var pages = await DocumentRepository.GetPagesAsync("DefaultConnection", selectedDocumentForPages.DocumentId);
            existingPages = pages.ToList();
            
            // Calculate next available page number
            if (existingPages.Any())
            {
                suggestedPageNumber = existingPages.Max(p => p.PageNumber) + 1;
                newPageNumber = suggestedPageNumber;
            }
            else
            {
                suggestedPageNumber = 1;
                newPageNumber = 1;
            }
        }
        catch (Exception ex)
        {
            pageUploadErrorMessage = $"Error loading existing pages: {ex.Message}";
            existingPages = new List<DocumentPage>();
        }
        finally
        {
            isLoadingPages = false;
        }
    }

    private void CloseUploadPagesDialog()
    {
        showUploadPagesDialog = false;
        selectedDocumentForPages = null;
        selectedPageFile = null;
        pageUploadErrorMessage = null;
        pageUploadSuccessMessage = null;
    }

    private void HandlePageFileSelected(InputFileChangeEventArgs e)
    {
        selectedPageFile = e.File;
        pageUploadErrorMessage = null;
        pageUploadSuccessMessage = null;
    }

    private bool CanUploadPage()
    {
        // Check basic requirements
        if (selectedPageFile == null || newPageNumber <= 0 || selectedDocumentForPages == null)
        {
            return false;
        }
        
        // Check for duplicate page number
        if (existingPages != null && existingPages.Any(p => p.PageNumber == newPageNumber))
        {
            return false;
        }
        
        return true;
    }

    private async Task UploadPageToDocument()
    {
        if (selectedPageFile == null || selectedDocumentForPages == null || selectedProject == null)
        {
            return;
        }

        // Double-check for duplicate page number
        if (existingPages != null && existingPages.Any(p => p.PageNumber == newPageNumber))
        {
            pageUploadErrorMessage = $"Page {newPageNumber} already exists. Please choose a different page number.";
            return;
        }

        isUploadingPage = true;
        pageUploadErrorMessage = null;
        pageUploadSuccessMessage = null;

        try
        {
            // Validate file size (50MB limit)
            const long maxFileSize = 50 * 1024 * 1024; // 50MB
            if (selectedPageFile.Size > maxFileSize)
            {
                pageUploadErrorMessage = "File size exceeds 50MB limit.";
                return;
            }

            // Create a FormFile wrapper for the upload service
            var formFile = new FormFileWrapper(selectedPageFile);

            // Upload the page using DocumentUploadService
            var currentUserId = await ResolveCurrentUserIdAsync();
            var uploadedPage = await DocumentUploadService.UploadFileAsync(
                selectedDocumentForPages.DocumentId,
                newPageNumber,
                formFile,
                string.IsNullOrWhiteSpace(newPageReference) ? null : newPageReference,
                userId: currentUserId,
                documentIndex: selectedDocumentForPages.DocumentIndex ?? ""
            );

            pageUploadSuccessMessage = $"Page {newPageNumber} uploaded successfully!";
            
            // Reload existing pages to update the list
            await LoadExistingPages();
            
            // Reset form fields
            selectedPageFile = null;
            newPageReference = string.Empty;
            // newPageNumber is already set to next available by LoadExistingPages

            // Auto-close after delay (optional - you can keep dialog open for multiple uploads)
            await Task.Delay(1500);
            // CloseUploadPagesDialog(); // Comment out to allow multiple uploads
        }
        catch (Exception ex)
        {
            // Check if it's a duplicate key error
            if (ex.Message.Contains("duplicate key") || ex.Message.Contains("unique index"))
            {
                pageUploadErrorMessage = $"Page {newPageNumber} already exists in the database. Please choose a different page number.";
            }
            else
            {
                pageUploadErrorMessage = $"Error uploading page: {ex.Message}";
            }
        }
        finally
        {
            isUploadingPage = false;
        }
    }

    private async Task<int> ResolveCurrentUserIdAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var username = authState.User?.Identity?.Name;
            if (!string.IsNullOrEmpty(username))
            {
                using var secCtx = await SecurityDbContextFactory.CreateDbContextAsync();
                var user = await secCtx.Users.FirstOrDefaultAsync(u => u.Username == username);
                if (user != null)
                    return user.UserId;
            }
        }
        catch
        {
            // Ignore
        }

        return 0;
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private void OpenUploadDialog()
    {
        showUploadDialog = true;
    }

    private void CloseUploadDialog()
    {
        showUploadDialog = false;
    }

    private async Task OnDocumentUploaded(DocumentPage uploadedPage)
    {
        // Reload documents after upload
        await LoadDocumentsForProject();
        CloseUploadDialog();
        StateHasChanged();
    }

    private async Task StartMigration()
    {
        isMigrating = true;
        migrationError = null;
        migrationResult = null;

        try
        {
            // Use the default connection string
            var connectionString = "DefaultConnection"; // This could be made configurable
            
            migrationResult = await DocumentUploadService.MigrateFilePathToBlobAsync(connectionString, migrationDocumentId);
            
            if (!migrationResult.Success)
            {
                migrationError = migrationResult.ErrorMessage ?? "Migration failed with unknown error";
            }
        }
        catch (Exception ex)
        {
            migrationError = $"Migration error: {ex.Message}";
        }
        finally
        {
            isMigrating = false;
        }
    }

    private void ClearMigrationResults()
    {
        migrationResult = null;
        migrationError = null;
        migrationDocumentId = null;
    }

    private void GoBackToDashboard()
    {
        Navigation.NavigateTo("/admin");
    }

    // Page editing methods
    private void OpenEditPageDialog(DocumentPage page)
    {
        editingPage = page;
        editPageNumber = page.PageNumber;
        editPageReference = page.PageReference ?? string.Empty;
        editPageFile = null;
        pageEditErrorMessage = null;
        pageEditSuccessMessage = null;
        showEditPageDialog = true;
    }

    private void CloseEditPageDialog()
    {
        showEditPageDialog = false;
        editingPage = null;
        editPageFile = null;
        pageEditErrorMessage = null;
        pageEditSuccessMessage = null;
    }

    private void HandleEditPageFileSelected(InputFileChangeEventArgs e)
    {
        editPageFile = e.File;
        pageEditErrorMessage = null;
        pageEditSuccessMessage = null;
    }

    private bool CanSavePageEdit()
    {
        if (editingPage == null || editPageNumber <= 0)
        {
            return false;
        }

        // Check for duplicate page number (excluding current page)
        if (existingPages != null && existingPages.Any(p => p.PageNumber == editPageNumber && p.PageId != editingPage.PageId))
        {
            return false;
        }

        return true;
    }

    private async Task SavePageChanges()
    {
        if (editingPage == null || selectedProject == null || selectedDocumentForPages == null)
        {
            return;
        }

        isEditingPage = true;
        pageEditErrorMessage = null;
        pageEditSuccessMessage = null;

        try
        {
            // If a new file is provided, validate it first
            if (editPageFile != null)
            {
                const long maxFileSize = 50 * 1024 * 1024; // 50MB
                if (editPageFile.Size > maxFileSize)
                {
                    pageEditErrorMessage = "File size exceeds 50MB limit.";
                    return;
                }
            }

            // If file is being replaced, upload the new file and get the new blob data
            byte[]? newBlobData = null;
            long? newFileSize = null;
            string? newContentType = null;
            string? newChecksum = null;

            if (editPageFile != null)
            {
                // Read the file into memory
                using var ms = new MemoryStream();
                await editPageFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
                newBlobData = ms.ToArray();
                newFileSize = newBlobData.Length;
                newContentType = editPageFile.ContentType;

                // Calculate MD5 checksum (32 characters to match database column)
                using var md5 = System.Security.Cryptography.MD5.Create();
                var hashBytes = md5.ComputeHash(newBlobData);
                newChecksum = BitConverter.ToString(hashBytes).Replace("-", "").ToLowerInvariant();
            }

            // Update the page in the database
            var sql = $@"
                UPDATE [{selectedProject.SchemaName}].[DocumentPage]
                SET 
                    PageNumber = {{0}},
                    PageReference = {{1}},
                    ModifiedOn = {{2}}";

            var parameters = new List<object>
            {
                editPageNumber,
                string.IsNullOrWhiteSpace(editPageReference) ? (object?)null! : editPageReference,
                DateTime.UtcNow
            };

            int paramIndex = 3;
            
            // Add blob data parameters if file is being replaced
            if (newBlobData != null)
            {
                sql += $@",
                    FileContent = {{{paramIndex}}},
                    FileSize = {{{paramIndex + 1}}},
                    ContentType = {{{paramIndex + 2}}},
                    ChecksumMD5 = {{{paramIndex + 3}}}";
                
                parameters.Add(newBlobData);
                parameters.Add(newFileSize!);
                parameters.Add(newContentType!);
                parameters.Add(newChecksum!);
            }

            sql += $@"
                WHERE PageId = {{{parameters.Count}}}";
            
            parameters.Add(editingPage.PageId);

            var rowsAffected = await DbContext.Database.ExecuteSqlRawAsync(sql, parameters.ToArray()!);

            if (rowsAffected > 0)
            {
                pageEditSuccessMessage = editPageFile != null 
                    ? "Page updated successfully with new file!" 
                    : "Page details updated successfully!";
                
                // Reload existing pages
                await LoadExistingPages();
                
                // Close dialog after delay
                await Task.Delay(1500);
                CloseEditPageDialog();
            }
            else
            {
                pageEditErrorMessage = "No changes were made to the page.";
            }
        }
        catch (Exception ex)
        {
            if (ex.Message.Contains("duplicate key") || ex.Message.Contains("unique index"))
            {
                pageEditErrorMessage = $"Page {editPageNumber} already exists. Please choose a different page number.";
            }
            else
            {
                pageEditErrorMessage = $"Error updating page: {ex.Message}";
            }
        }
        finally
        {
            isEditingPage = false;
        }
    }

    private async Task DeletePage()
    {
        if (editingPage == null || selectedProject == null)
        {
            return;
        }

        // Confirm deletion
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            $"Are you sure you want to delete Page {editingPage.PageNumber}? This action cannot be undone.");
        
        if (!confirmed)
        {
            return;
        }

        isEditingPage = true;
        pageEditErrorMessage = null;
        pageEditSuccessMessage = null;

        try
        {
            var sql = $@"
                DELETE FROM [{selectedProject.SchemaName}].[DocumentPage]
                WHERE PageId = {{0}}";

            var rowsAffected = await DbContext.Database.ExecuteSqlRawAsync(sql, editingPage.PageId);

            if (rowsAffected > 0)
            {
                pageEditSuccessMessage = $"Page {editingPage.PageNumber} deleted successfully!";
                
                // Reload existing pages
                await LoadExistingPages();
                
                // Close dialog after delay
                await Task.Delay(1500);
                CloseEditPageDialog();
            }
            else
            {
                pageEditErrorMessage = "Failed to delete page.";
            }
        }
        catch (Exception ex)
        {
            pageEditErrorMessage = $"Error deleting page: {ex.Message}";
        }
        finally
        {
            isEditingPage = false;
        }
    }
}