</div>

@code {
    private string activeLayout = "horizontal";
    
    private int[] revenueData = { 45, 75, 55, 60, 80, 65, 55, 70, 75, 60, 80, 65 };
    private int[] lineData = { 50, 60, 65, 55, 60, 70, 65, 55, 45, 60, 55, 50 };
    
    private List<SourceItem> sources = new()
    {
        new SourceItem { Name = "Source 1", Value = "7,524", Color = "#3b82f6", ChartData = new[] { 40, 60, 50, 70, 45, 80, 60 } },
        new SourceItem { Name = "Source 2", Value = "5,742", Color = "#8b5cf6", ChartData = new[] { 50, 40, 60, 55, 70, 50, 65 } },
        new SourceItem { Name = "Source 3", Value = "5,700", Color = "#fbbf24", ChartData = new[] { 60, 50, 40, 65, 55, 70, 55 } }
    };

    private List<ActivityItem> activities = new()
    {
        new ActivityItem { Avatar = "ðŸ‘¤", Date = "04 Apr, 2020 10:15 am", Text = "Responded to need \"Volunteer Activities\"" },
        new ActivityItem { Avatar = "ðŸ‘¤", Date = "21 Mar, 2020 05:24 am", Text = "Added an interest \"Volunteer Activities\"" },
        new ActivityItem { Avatar = "ðŸ‘¤", Date = "17 Mar, 2019 09:32 am", Text = "Joined the group \"Boardsmanship Forum\"" },
        new ActivityItem { Avatar = "ðŸ‘¤", Date = "19 Feb, 2019 12:00 am", Text = "Responded to need \"In-Kind Opportunity\"" }
    };

    private List<TransactionItem> transactions = new()
    {
        new TransactionItem { OrderId = "NZ1563", Date = "28 Mar, 2020", BillingName = "Frank Dean", Total = "164", Status = "Paid", StatusClass = "paid" },
        new TransactionItem { OrderId = "NZ1564", Date = "28 Mar, 2020", BillingName = "Eddy Torres", Total = "141", Status = "Paid", StatusClass = "paid" },
        new TransactionItem { OrderId = "NZ1565", Date = "29 Mar, 2020", BillingName = "Jamison Clark", Total = "123", Status = "Paid", StatusClass = "paid" },
        new TransactionItem { OrderId = "NZ1566", Date = "30 Mar, 2020", BillingName = "Jewel Buckley", Total = "112", Status = "Paid", StatusClass = "paid" },
        new TransactionItem { OrderId = "NZ1567", Date = "31 Mar, 2020", BillingName = "Jeffrey Waltz", Total = "105", Status = "Paid", StatusClass = "paid" }
    };

    private string GetLinePoints()
    {
        var points = new List<string>();
        for (int i = 0; i < lineData.Length; i++)
        {
            double x = (i * 100.0 / (lineData.Length - 1));
            double y = 100 - lineData[i];
            points.Add($"{x:F1},{y:F1}");
        }
        return string.Join(" ", points);
    }

    private class SourceItem
    {
        public string Name { get; set; } = "";
        public string Value { get; set; } = "";
        public string Color { get; set; } = "";
        public int[] ChartData { get; set; } = Array.Empty<int>();
    }

    private class ActivityItem
    {
        public string Avatar { get; set; } = "";
        public string Date { get; set; } = "";
        public string Text { get; set; } = "";
    }

    private class TransactionItem
    {
        public string OrderId { get; set; } = "";
        public string Date { get; set; } = "";
        public string BillingName { get; set; } = "";
        public string Total { get; set; } = "";
        public string Status { get; set; } = "";
        public string StatusClass { get; set; } = "";
    }
}

