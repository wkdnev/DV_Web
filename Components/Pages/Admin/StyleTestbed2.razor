        </div>
        <div class="chart-body">
            <div class="chart-container">
                @for (int i = 0; i < 12; i++)
                {
                    int height = revenueData[i];
                    <div class="chart-bar-group">
                        <div class="chart-bar-wrapper">
                            <div class="chart-bar blue" style="height: @(height)%"></div>
                        </div>
                        <div class="chart-line-point" style="bottom: @(lineData[i])%"></div>
                    </div>
                }
                <svg class="chart-line-svg" preserveAspectRatio="none">
                    <polyline points="@GetLinePoints()" fill="none" stroke="#10b981" stroke-width="2"/>
                </svg>
            </div>
            <div class="chart-labels">
                @foreach (var month in new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" })
                {
                    <span class="chart-label">@month</span>
                }
            </div>
        </div>
        <div class="chart-footer">
            <div class="chart-stat">
                <span class="chart-stat-label">This month</span>
                <span class="chart-stat-value">$12,253 <span class="stat-change-sm green">+2.2 %</span></span>
            </div>
            <div class="chart-stat">
                <span class="chart-stat-label">This Year</span>
                <span class="chart-stat-value">$ 34,254 <span class="stat-change-sm green">+4.5 %</span></span>
            </div>
            <div class="chart-stat">
                <span class="chart-stat-label">Previous Year</span>
