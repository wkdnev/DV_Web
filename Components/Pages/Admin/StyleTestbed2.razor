                    <span class="sources-title">User Sources</span>
                    <span class="sources-value">$ 7652</span>
                    <span class="sources-change green">+2 %</span>
                </div>
                @foreach (var source in sources)
                {
                    <div class="source-item">
                        <div class="source-info">
                            <span class="source-dot" style="background-color: @source.Color"></span>
                            <span class="source-name">@source.Name</span>
                        </div>
                        <div class="source-chart">
                            @foreach (var point in source.ChartData)
                            {
                                <span class="mini-chart-point" style="height: @(point)%"></span>
                            }
                        </div>
                        <span class="source-value">$ @source.Value</span>
                    </div>
                }
                <button class="lgreeny-btn-primary">View more</button>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="lgreeny-panel">
            <div class="panel-header">
                <h3 class="panel-title">Recent Activity Feed</h3>
                <span class="panel-more">â‹¯</span>
            </div>
            <div class="panel-body">
                @foreach (var activity in activities)
                {
                    <div class="activity-item">
                        <div class="activity-avatar">@activity.Avatar</div>
                        <div class="activity-content">
                            <div class="activity-date">@activity.Date</div>
                            <div class="activity-text">@activity.Text</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Revenue by Locations -->
        <div class="lgreeny-panel">
            <div class="panel-header">
                <h3 class="panel-title">Revenue by Locations</h3>
                <span class="panel-more">â‹¯</span>
            </div>
            <div class="panel-body">
                <div class="map-placeholder">
                    <svg viewBox="0 0 300 150" class="usa-map">
                        <text x="150" y="75" text-anchor="middle" fill="#94a3b8" font-size="14">US Map Visualization</text>
                        <circle cx="80" cy="60" r="3" fill="#3b82f6"/>
                        <circle cx="120" cy="70" r="3" fill="#3b82f6"/>
                        <circle cx="200" cy="65" r="3" fill="#3b82f6"/>
                        <circle cx="240" cy="75" r="3" fill="#3b82f6"/>
                    </svg>
                </div>
                <div class="location-stats">
                    <div class="location-item">
                        <span class="location-name">California</span>
                        <span class="location-value">$ 2542</span>
                    </div>
                    <div class="location-item">
                        <span class="location-name">Montana</span>
                        <span class="location-value">$ 2196</span>
                    </div>
                    <div class="location-item">
