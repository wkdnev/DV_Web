@page "/admin/legacy-cleanup"
@attribute [Authorize(Roles = "Admin")]
@using DV.Shared.Security
@using DV.Web.Services
@using DV.Shared.Models
@inject UserService UserService
@inject ProjectRoleService ProjectRoleService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Legacy Role System Cleanup</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex align-items-center mb-4">
                <h3 class="mb-0">Legacy Role System Cleanup</h3>
                <div class="ms-auto">
                    <a href="/admin" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>
                        Back to Admin Dashboard
                    </a>
                </div>
            </div>

            <div class="alert alert-warning">
                <h6><i class="bi bi-exclamation-triangle me-2"></i>Migration to Simplified Role Architecture</h6>
                <p class="mb-0">
                    This page provides tools to migrate from the legacy global role system to the new simplified architecture where:
                    <br><strong>Global Level:</strong> Only IsGlobalAdmin flag for system administrators
                    <br><strong>Project Level:</strong> All other roles are project-scoped for granular access control
                </p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Migration Status -->
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Migration Status</h5>
                </div>
                <div class="card-body">
                    @if (isLoading)
                    {
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2">Checking migration status...</p>
                        </div>
                    }
                    else
                    {
                        <div class="row">
                            <div class="col-md-6">
                                <h6>Legacy System Status</h6>
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item d-flex justify-content-between">
                                        <span>Legacy UserRole Records:</span>
                                        <span class="badge @(legacyUserRoleCount > 0 ? "bg-warning" : "bg-success")">
                                            @legacyUserRoleCount
                                        </span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between">
                                        <span>Global Admins via Flag:</span>
                                        <span class="badge bg-info">@globalAdminCount</span>
                                    </li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h6>New System Status</h6>
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item d-flex justify-content-between">
                                        <span>Project Roles:</span>
                                        <span class="badge bg-success">@projectRoleCount</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between">
                                        <span>User Project Assignments:</span>
                                        <span class="badge bg-success">@userProjectAssignmentCount</span>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        @if (legacyUserRoleCount > 0)
                        {
                            <div class="alert alert-warning mt-3">
                                <strong>Action Required:</strong> You have @legacyUserRoleCount legacy global role assignments that should be migrated to project-scoped roles.
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-success mt-3">
                                <strong>Migration Complete:</strong> No legacy global role assignments found. The system is using the new simplified architecture.
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Migration Tools -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-tools me-2"></i>Migration Tools</h5>
                </div>
                <div class="card-body">
                    <h6>Convert Legacy Global Roles</h6>
                    <p class="text-muted">
                        Migrate users with legacy global role assignments to the new project-scoped system.
                    </p>
                    
                    @if (legacyUserRoleCount > 0)
                    {
                        <div class="mb-3">
                            <label class="form-label">Default Project for Migration:</label>
                            <select class="form-select" @bind="selectedProjectId">
                                <option value="">Select a project...</option>
                                @foreach (var project in availableProjects)
                                {
                                    <option value="@project.ProjectId">@project.ProjectName (@project.ProjectCode)</option>
                                }
                            </select>
                            <div class="form-text">
                                Legacy role assignments will be converted to roles in this project.
                            </div>
                        </div>
                        
                        <button class="btn btn-warning" @onclick="MigrateLegacyRoles" disabled="@(isProcessing || selectedProjectId == 0)">
                            <i class="bi bi-arrow-right-circle me-1"></i>
                            @if (isProcessing)
                            {
                                <span>Migrating... <span class="spinner-border spinner-border-sm ms-1"></span></span>
                            }
                            else
                            {
                                <span>Migrate Legacy Roles</span>
                            }
                        </button>
                    }
                    else
                    {
                        <div class="text-success">
                            <i class="bi bi-check-circle me-1"></i>
                            No legacy roles found to migrate.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Cleanup Tools -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-trash me-2"></i>Cleanup Tools</h5>
                </div>
                <div class="card-body">
                    <h6>Remove Legacy Tables</h6>
                    <p class="text-muted">
                        Permanently remove the legacy global role tables after migration is complete.
                    </p>
                    
                    @if (legacyUserRoleCount == 0)
                    {
                        <div class="alert alert-info">
                            <small>
                                <strong>Ready for Cleanup:</strong> No legacy role assignments found. 
                                You can safely remove the legacy tables.
                            </small>
                        </div>
                        
                        <button class="btn btn-danger" @onclick="ConfirmRemoveLegacyTables" disabled="@isProcessing">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Remove Legacy Tables
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <small>
                                <strong>Migration Required:</strong> Complete the migration of legacy roles before removing tables.
                            </small>
                        </div>
                        
                        <button class="btn btn-danger" disabled>
                            <i class="bi bi-lock me-1"></i>
                            Remove Legacy Tables (Blocked)
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Documentation -->
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="bi bi-book me-2"></i>Architecture Documentation</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Legacy Architecture (Deprecated)</h6>
                            <ul>
                                <li><code>UserRole</code> - Global role assignments</li>
                                <li><code>ApplicationRole</code> - Global role definitions</li>
                                <li><code>RolePermission</code> - Global role permissions</li>
                            </ul>
                            <p class="text-muted">
                                This system assigned roles globally to users, which didn't provide project-level granularity.
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h6>New Architecture (Current)</h6>
                            <ul>
                                <li><code>ApplicationUser.IsGlobalAdmin</code> - Global admin flag</li>
                                <li><code>ProjectRole</code> - Project-specific role instances</li>
                                <li><code>UserProjectRole</code> - User assignments to project roles</li>
                                <li><code>ProjectRolePermission</code> - Project role permissions</li>
                            </ul>
                            <p class="text-muted">
                                This system provides granular project-level access control with only global admins at the global level.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isLoading = true;
    private bool isProcessing = false;
    private int legacyUserRoleCount = 0;
    private int globalAdminCount = 0;
    private int projectRoleCount = 0;
    private int userProjectAssignmentCount = 0;
    private int selectedProjectId = 0;
    private List<Project> availableProjects = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadMigrationStatus();
    }

    private async Task LoadMigrationStatus()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            // Get global admin count
            var globalAdmins = await UserService.GetGlobalAdminsAsync();
            globalAdminCount = globalAdmins.Count;

            // Get all projects for migration options
            availableProjects = await ProjectRoleService.GetAllProjectsAsync();

            // Get project role statistics
            projectRoleCount = 0;
            userProjectAssignmentCount = 0;
            
            foreach (var project in availableProjects)
            {
                var projectRoles = await ProjectRoleService.GetProjectRolesAsync(project.ProjectId);
                projectRoleCount += projectRoles.Count;
                
                foreach (var projectRole in projectRoles)
                {
                    var users = await ProjectRoleService.GetUsersInProjectRoleAsync(projectRole.ProjectRoleId);
                    userProjectAssignmentCount += users.Count;
                }
            }

            // TODO: Check for legacy UserRole records
            // This would require accessing the legacy tables if they still exist
            // For now, assume migration is complete
            legacyUserRoleCount = 0;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task MigrateLegacyRoles()
    {
        try
        {
            isProcessing = true;
            errorMessage = null;

            // TODO: Implement legacy role migration logic
            // This would involve:
            // 1. Reading from UserRole table
            // 2. Creating equivalent ProjectRole assignments
            // 3. Removing the legacy assignments

            await JSRuntime.InvokeVoidAsync("alert", "Legacy role migration completed successfully!");
            await LoadMigrationStatus();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            await JSRuntime.InvokeVoidAsync("alert", $"Migration failed: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task ConfirmRemoveLegacyTables()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            "Are you sure you want to permanently remove the legacy role tables? This action cannot be undone.\n\n" +
            "Tables to be removed:\n" +
            "- UserRole\n" +
            "- RolePermission\n" +
            "- ApplicationRole\n\n" +
            "This will complete the migration to the new simplified architecture.");

        if (confirmed)
        {
            await RemoveLegacyTables();
        }
    }

    private async Task RemoveLegacyTables()
    {
        try
        {
            isProcessing = true;
            errorMessage = null;

            // TODO: Execute the SQL script to remove legacy tables
            // This would run the RemoveLegacyGlobalRoles.sql script

            await JSRuntime.InvokeVoidAsync("alert", 
                "Legacy tables removed successfully!\n\n" +
                "The system is now using the simplified architecture:\n" +
                "- Global admins via IsGlobalAdmin flag\n" +
                "- All other roles are project-scoped");

            await LoadMigrationStatus();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            await JSRuntime.InvokeVoidAsync("alert", $"Failed to remove legacy tables: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }
}