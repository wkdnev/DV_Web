@* 
   ============================================================================
   ViewPdf.razor - PDF Viewer Component for Document Viewer Application
   ============================================================================
   
   Purpose: Displays a PDF document in an iframe for viewing. This component 
   fetches the document metadata from the database and ensures the document is 
   of type "PDF" before rendering the viewer. If the document is not found or 
   is not a PDF, appropriate messages are displayed.
   
   Created: [Date]
   Last Updated: [Date]
   
   Dependencies:
   - DocumentRepository: Handles database interactions for fetching document metadata.
   - Document: Represents the document model with metadata properties.
   - LayoutSelector: Provides layout selection for the component.
   - Bootstrap 5.x for styling.
*@

@page "/viewpdf/{Token}"
@page "/viewpdf/{Schema}/{Token}"
@* Defines the route for this page with schema and document ID parameters *@

@using DV.Shared.Models
@using DV.Web.Services
@using DV.Shared.Security
@using DV.Shared.Constants
@using DV.Web.Components.Layout
@using DV.Web.Components.Documents
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@* Imports the necessary models, services, and security components *@

@layout MinimalLayout
@* Use MinimalLayout to avoid double headers since LayoutSelector is used below *@

@inject DocumentRepository Repo
@inject UserService UserService
@inject AuthenticationStateProvider AuthenticationStateProvider
@* Injects the services for database operations, user management, and authentication *@

@attribute [Authorize]
@rendermode InteractiveServer
@* Enforces authorization policy and sets the render mode to InteractiveServer *@

<PageTitle>PDF Viewer</PageTitle> @* Sets the page title to "PDF Viewer" *@

<LayoutSelector>
    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-3">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(accessError))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Access Denied</strong>
            <p class="mb-0">@accessError</p>
        </div>
    }
    else if (doc is null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-file-x me-2"></i>
            <strong>Document Not Found</strong>
            <p class="mb-0">The requested PDF document could not be found.</p>
        </div>
    }
    else if (!string.Equals(doc.DocumentType, "PDF", StringComparison.OrdinalIgnoreCase))
    {
        <div class="alert alert-warning">
            <i class="bi bi-file-earmark me-2"></i>
            <strong>Invalid Document Type</strong>
            <p class="mb-0">This document is not a PDF.</p>
        </div>
    }
    else
    {
        @* =================================================================
          Document Display
          =================================================================
          Purpose: Displays the PDF document using PDF.js via BlobDocumentViewer.
        *@
                @if (doc.DocumentType!.Equals("PDF", StringComparison.OrdinalIgnoreCase))
                {
                    @if (pages != null && pages.Any() && pages.First().StorageType == 1)
                    {
                        @* BLOB storage - viewer fetches from /api/DocumentBlob/page/{pageId} *@
                        <BlobDocumentViewer DocumentId="@doc.DocumentId" SchemaName="@doc.SchemaName" />
                    }
                    else
                    {
                        @* File-system storage - pass the legacy PDF URL to the viewer *@
                        <BlobDocumentViewer DocumentId="@doc.DocumentId" SchemaName="@doc.SchemaName" PdfUrl="@($"/api/pdf-view/{doc.DocumentId}")" />
                    }
                }
                else
                {
                    <div class="alert alert-warning m-3">
                        <i class="bi bi-file-earmark me-2"></i>
                        <strong>Unsupported Document Type</strong>
                        <p class="mb-0">This document is not a PDF and cannot be displayed in the PDF viewer.</p>
                    </div>
                }
    }
</LayoutSelector>

@* ============================================================================
   Code-Behind Logic for the ViewPdf Page
   ============================================================================ *@
@code {
    [Parameter] public string Token { get; set; } = null!; @* Opaque document token parameter *@
    [Parameter] public string? Schema { get; set; }
    Document? doc; @* Holds the document metadata *@
    List<DocumentPage>? pages; @* Holds the document pages to check storage type *@

    private string? currentUsername;
    private ApplicationUser? currentUser;
    private bool isLoading = true;
    private string? accessError;

    @* ========================================================================
       OnParametersSetAsync
       ========================================================================
       Purpose: Fetches the document metadata from the database when the 
       parameters (Database and DocumentId) are set.
    *@
    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        accessError = null;
        
        try
        {
            // Get current user
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            currentUsername = authState.User.Identity?.Name;

            if (string.IsNullOrEmpty(currentUsername))
            {
                accessError = "You must be authenticated to view documents.";
                return;
            }

            currentUser = await UserService.GetUserByUsernameAsync(currentUsername);
            if (currentUser == null)
            {
                accessError = "User not found in the system.";
                return;
            }

            // Resolve the token to a document
            doc = await Repo.GetDocumentByTokenAsync(Token);

            if (doc == null)
            {
                // Document not found - this will be handled by the UI
                return;
            }

            // Load document pages to check storage type
            pages = await Repo.GetDocumentPagesAsync("DefaultConnection", doc.SchemaName!, doc.DocumentId);

            // Validate project access (Strict AD Group Check)
            // Permission logic relies strictly on AD Group Claims matching Project Read/Edit Principal
            // OR checks for Global Admin role
            bool isGlobalAdmin = authState.User.IsInRole(Roles.GlobalAdminGroup) || authState.User.HasClaim(c => (c.Type == "groups" || c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/groups") && c.Value == Roles.GlobalAdminGroup);
            bool hasGroupAccess = doc.ProjectId.HasValue && await Repo.HasProjectAccessAsync(authState.User, doc.ProjectId.Value);

            if (!doc.ProjectId.HasValue || (!isGlobalAdmin && !hasGroupAccess))
            {
                accessError = "You do not have permission to view documents from this project. Please contact your administrator for access.";
                return;
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error loading PDF document: {ex.Message}");
            accessError = "An error occurred while loading the document. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }
}