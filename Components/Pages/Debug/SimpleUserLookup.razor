#if DEBUG
@page "/debug/simple-user-lookup"
@using DV.Web.Services
@using DV.Shared.Security
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject IServiceProvider ServiceProvider
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Simple User Lookup Test</PageTitle>

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Simple User Lookup Test</h4>
            <small>Basic test to verify database connectivity and user lookup</small>
        </div>
        <div class="card-body">
            @if (isLoading)
            {
                <div class="text-center">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Testing user lookup...</p>
                </div>
            }
            else
            {
                <div class="row">
                    <div class="col-md-6">
                        <h5>Authentication Test</h5>
                        <table class="table table-sm">
                            <tr>
                                <td><strong>Authenticated:</strong></td>
                                <td><span class="badge @(isAuthenticated ? "bg-success" : "bg-danger")">@(isAuthenticated ? "Yes" : "No")</span></td>
                            </tr>
                            <tr>
                                <td><strong>Username:</strong></td>
                                <td><code>@rawUsername</code></td>
                            </tr>
                        </table>
                    </div>
                    
                    <div class="col-md-6">
                        <h5>Database Test</h5>
                        <table class="table table-sm">
                            <tr>
                                <td><strong>User Found:</strong></td>
                                <td><span class="badge @(foundUser != null ? "bg-success" : "bg-danger")">@(foundUser != null ? "Yes" : "No")</span></td>
                            </tr>
                            @if (foundUser != null)
                            {
                                <tr>
                                    <td><strong>User ID:</strong></td>
                                    <td>@foundUser.UserId</td>
                                </tr>
                                <tr>
                                    <td><strong>Username:</strong></td>
                                    <td><code>@foundUser.Username</code></td>
                                </tr>
                                <tr>
                                    <td><strong>IsGlobalAdmin:</strong></td>
                                    <td><span class="badge @(foundUser.IsGlobalAdmin == true ? "bg-success" : "bg-secondary")">@(foundUser.IsGlobalAdmin?.ToString() ?? "NULL")</span></td>
                                </tr>
                            }
                        </table>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-12">
                        <h5>All Users in Database</h5>
                        @if (allUsers.Any())
                        {
                            <table class="table table-striped table-sm">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Username</th>
                                        <th>Display Name</th>
                                        <th>IsGlobalAdmin</th>
                                        <th>Active</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in allUsers)
                                    {
                                        <tr class="@(user.Username == rawUsername ? "table-warning" : "")">
                                            <td>@user.UserId</td>
                                            <td><code>@user.Username</code></td>
                                            <td>@user.DisplayName</td>
                                            <td>
                                                <span class="badge @(user.IsGlobalAdmin == true ? "bg-success" : "bg-secondary")">
                                                    @(user.IsGlobalAdmin?.ToString() ?? "NULL")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge @(user.IsActive ? "bg-success" : "bg-danger")">
                                                    @(user.IsActive ? "Yes" : "No")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="alert alert-warning">No users found in database!</div>
                        }
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-12">
                        <h5>Manual Role Check</h5>
                        @if (foundUser != null)
                        {
                            <div class="alert alert-info">
                                <strong>Testing roles for User ID @foundUser.UserId:</strong>
                                <br/>Roles found: @manualRoleCount
                                @if (manualRoleCount > 0)
                                {
                                    <ul class="mt-2 mb-0">
                                        @foreach (var role in manualRoles)
                                        {
                                            <li><strong>@role.Name</strong> (ID: @role.RoleId) - @role.Description</li>
                                        }
                                    </ul>
                                }
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger mt-3">
                        <strong>Error:</strong> @errorMessage
                    </div>
                }

                <div class="mt-3">
                    <button class="btn btn-primary me-2" @onclick="RunTest">
                        <i class="bi bi-arrow-clockwise me-1"></i>
                        Refresh Test
                    </button>
                    <button class="btn btn-secondary" @onclick="LogDetails">
                        <i class="bi bi-terminal me-1"></i>
                        Log to Console
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool isLoading = true;
    private bool isAuthenticated = false;
    private string? rawUsername;
    private ApplicationUser? foundUser;
    private List<ApplicationUser> allUsers = new();
    private List<ApplicationRole> manualRoles = new();
    private int manualRoleCount = 0;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await RunTest();
    }

    private async Task RunTest()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            foundUser = null;
            allUsers.Clear();
            manualRoles.Clear();
            manualRoleCount = 0;

            // Step 1: Get authentication
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
            rawUsername = authState.User.Identity?.Name;

            if (!isAuthenticated || string.IsNullOrEmpty(rawUsername))
            {
                errorMessage = "Not authenticated or no username";
                return;
            }

            // Step 2: Test database connectivity by getting all users
            using (var scope = ServiceProvider.CreateScope())
            {
                var userService = scope.ServiceProvider.GetRequiredService<UserService>();
                allUsers = await userService.GetAllUsersAsync();
            }

            // Step 3: Try to find the specific user
            using (var scope = ServiceProvider.CreateScope())
            {
                var userService = scope.ServiceProvider.GetRequiredService<UserService>();
                foundUser = await userService.GetUserByUsernameAsync(rawUsername);
            }

            // Step 4: If user found, get their roles
            if (foundUser != null)
            {
                using (var scope = ServiceProvider.CreateScope())
                {
                    var userService = scope.ServiceProvider.GetRequiredService<UserService>();
                    manualRoles = await userService.GetUserRolesAsync(foundUser.UserId);
                    manualRoleCount = manualRoles.Count;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LogDetails()
    {
        await JSRuntime.InvokeVoidAsync("console.log", "=== SIMPLE USER LOOKUP TEST ===");
        await JSRuntime.InvokeVoidAsync("console.log", $"Raw Username: {rawUsername}");
        await JSRuntime.InvokeVoidAsync("console.log", $"Found User: {foundUser?.Username} (ID: {foundUser?.UserId})");
        await JSRuntime.InvokeVoidAsync("console.log", $"IsGlobalAdmin: {foundUser?.IsGlobalAdmin}");
        await JSRuntime.InvokeVoidAsync("console.log", $"Total Users in DB: {allUsers.Count}");
        await JSRuntime.InvokeVoidAsync("console.log", $"Manual Roles Count: {manualRoleCount}");

        foreach (var user in allUsers)
        {
            await JSRuntime.InvokeVoidAsync("console.log", $"DB User: {user.Username} (ID: {user.UserId}, GlobalAdmin: {user.IsGlobalAdmin})");
        }

        foreach (var role in manualRoles)
        {
            await JSRuntime.InvokeVoidAsync("console.log", $"Role: {role.Name} (ID: {role.RoleId})");
        }

        if (!string.IsNullOrEmpty(errorMessage))
        {
            await JSRuntime.InvokeVoidAsync("console.error", $"Error: {errorMessage}");
        }

        await JSRuntime.InvokeVoidAsync("console.log", "=== END TEST ===");
    }
}
#endif
