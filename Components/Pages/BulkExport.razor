    .be-btn.primary { background: var(--accent); color: #fff; }
    .be-btn.primary:hover { background: var(--accent-hover); }
    .be-btn.primary:disabled { opacity: .5; cursor: not-allowed; }

    .be-btn.secondary {
        background: transparent; color: var(--text-secondary);
        border: 1px solid var(--border);
    }

    .be-btn.secondary:hover { border-color: var(--text-muted); color: var(--text); }

    .be-btn.danger-outline {
        background: transparent; color: var(--red);
        border: 1px solid var(--red);
    }

    .be-btn.danger-outline:hover { background: rgba(248,81,73,.1); }
    .be-btn.danger-outline:disabled { opacity: .5; cursor: not-allowed; }

    /* ── Form Fields ── */
    .be-field { margin-bottom: 1rem; }

