@page "/editor/files/add"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using DV.Shared.Models
@using DV.Web.Services
@using DV.Shared.Security
@using DV.Web.Components.Layout
@using DV.Web.Data
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IDbContextFactory<AppDbContext> DbContextFactory
@inject DocumentUploadService DocumentUploadService
@inject ILogger<EditorAddDocument> Logger
@inject IDbContextFactory<SecurityDbContext> SecurityDbContextFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@rendermode InteractiveServer
@attribute [RoleBasedAuthorization("Editor")]

<PageTitle>Add New Document - DocViewer</PageTitle>

<div class="lgreeny-dashboard" style="min-height: 100vh; background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); padding: 2rem;">
    <!-- Page Header -->
    <div style="margin-bottom: 2rem;">
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
            <button class="lgreeny-btn-secondary" @onclick="GoBack" style="padding: 0.5rem 1rem;">
                <Icon Name="arrow-left" Size="16" /> Back
            </button>
            <h2 style="margin: 0; font-size: 2rem; font-weight: 700; color: #166534;">
                <Icon Name="file-plus" Size="32" /> Add New Document
            </h2>
        </div>
        <div style="color: #059669; display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem;">
            <Icon Name="home" Size="14" />
            <span>Home</span>
            <span>â€º</span>
            <span>Editor Dashboard</span>
            <span>â€º</span>
            <span>Files</span>
            <span>â€º</span>
            <span style="font-weight: 500;">Add Document</span>
        </div>
    </div>

    @if (selectedProject == null)
    {
        <div class="lgreeny-panel" style="padding: 3rem; text-align: center;">
            <Icon Name="alert-circle" Size="48" Color="#dc2626" />
            <h3 style="margin-top: 1rem; color: #166534;">No Project Selected</h3>
            <p style="color: #059669; margin-bottom: 1.5rem;">Please select a project from the Editor Dashboard first.</p>
            <button class="lgreeny-btn-primary" @onclick="GoToDashboard">
                <Icon Name="layout-dashboard" Size="16" /> Go to Dashboard
            </button>
        </div>
    }
    else
    {
        <!-- Project Info -->
        <div class="lgreeny-panel" style="margin-bottom: 2rem; padding: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <Icon Name="folder" Size="24" Color="#059669" />
                <div>
                    <h3 style="margin: 0; color: #166534; font-size: 1.25rem;">@selectedProject.ProjectName</h3>
                    <p style="margin: 0; color: #059669; font-size: 0.875rem;">Schema: @selectedProject.SchemaName</p>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div style="background: #d1fae5; border: 2px solid #059669; border-radius: 0.5rem; padding: 1rem; margin-bottom: 1.5rem;">
                <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <Icon Name="check-circle" Size="24" Color="#059669" />
                    <span style="color: #166534; font-weight: 500;">@successMessage</span>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="background: #fee2e2; border: 2px solid #dc2626; border-radius: 0.5rem; padding: 1rem; margin-bottom: 1.5rem;">
                <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <Icon Name="alert-circle" Size="24" Color="#dc2626" />
                    <span style="color: #991b1b; font-weight: 500;">@errorMessage</span>
                </div>
            </div>
        }

        <!-- Document Form -->
        <EditForm Model="@documentModel" OnValidSubmit="@HandleSubmit">
            <DataAnnotationsValidator />

            <div class="lgreeny-panel" style="margin-bottom: 2rem; padding: 2rem;">
                <h3 style="margin: 0 0 1.5rem 0; color: #166534; font-size: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                    <Icon Name="file-text" Size="24" /> Document Information
                </h3>

                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
                    <!-- Document Number -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">
                            Document Number <span style="color: #dc2626;">*</span>
                        </label>
                        <InputText @bind-Value="documentModel.DocumentNumber" class="lgreeny-input" placeholder="Enter document number" />
                        <ValidationMessage For="@(() => documentModel.DocumentNumber)" />
                    </div>

                    <!-- Document Type -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Document Type</label>
                        <InputSelect @bind-Value="documentModel.DocumentType" class="lgreeny-input">
                            <option value="">-- Select Document Type --</option>
                            <option value="PDF">PDF</option>
                            <option value="TIFF">TIFF</option>
                        </InputSelect>
                    </div>

                    <!-- Title -->
                    <div style="grid-column: 1 / -1;">
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Title</label>
                        <InputText @bind-Value="documentModel.Title" class="lgreeny-input" placeholder="Enter document title" />
                    </div>

                    <!-- Author -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Author</label>
                        <InputText @bind-Value="documentModel.Author" class="lgreeny-input" placeholder="Enter author name" />
                    </div>

                    <!-- Status -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Status</label>
                        <InputSelect @bind-Value="documentModel.Status" class="lgreeny-input">
                            <option value="">-- Select Status --</option>
                            <option value="Draft">Draft</option>
                            <option value="Active">Active</option>
                            <option value="Pending">Pending</option>
                            <option value="Archived">Archived</option>
                        </InputSelect>
                    </div>

                    <!-- Classification -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Classification</label>
                        <InputText @bind-Value="documentModel.Classification" class="lgreeny-input" placeholder="Enter classification" />
                    </div>

                    <!-- Document Index -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Document Index</label>
                        <InputText @bind-Value="documentModel.DocumentIndex" class="lgreeny-input" placeholder="Enter document index" />
                    </div>

                    <!-- Memo -->
                    <div style="grid-column: 1 / -1;">
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Memo / Notes</label>
                        <InputTextArea @bind-Value="documentModel.Memo" class="lgreeny-input" rows="3" placeholder="Enter additional notes" />
                    </div>

                    <!-- Document Date -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Document Date</label>
                        <InputDate TValue="DateTime?" @bind-Value="documentModel.DocumentDate" class="lgreeny-input" />
                    </div>

                    <!-- Issue -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Issue</label>
                        <InputText @bind-Value="documentModel.Issue" class="lgreeny-input" placeholder="Issue number" />
                    </div>

                    <!-- Version -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Version</label>
                        <InputText @bind-Value="documentModel.Version" class="lgreeny-input" placeholder="e.g., 1.0" />
                    </div>

                    <!-- Custom text fields (Text01-Text12) -->
                    <div style="grid-column: 1 / -1;">
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Custom Text Fields</label>
                        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem;">
                            <InputText @bind-Value="documentModel.Text01" class="lgreeny-input" placeholder="Text01" />
                            <InputText @bind-Value="documentModel.Text02" class="lgreeny-input" placeholder="Text02" />
                            <InputText @bind-Value="documentModel.Text03" class="lgreeny-input" placeholder="Text03" />
                            <InputText @bind-Value="documentModel.Text04" class="lgreeny-input" placeholder="Text04" />
                            <InputText @bind-Value="documentModel.Text05" class="lgreeny-input" placeholder="Text05" />
                            <InputText @bind-Value="documentModel.Text06" class="lgreeny-input" placeholder="Text06" />
                            <InputText @bind-Value="documentModel.Text07" class="lgreeny-input" placeholder="Text07" />
                            <InputText @bind-Value="documentModel.Text08" class="lgreeny-input" placeholder="Text08" />
                            <InputText @bind-Value="documentModel.Text09" class="lgreeny-input" placeholder="Text09" />
                            <InputText @bind-Value="documentModel.Text10" class="lgreeny-input" placeholder="Text10" />
                            <InputText @bind-Value="documentModel.Text11" class="lgreeny-input" placeholder="Text11" />
                            <InputText @bind-Value="documentModel.Text12" class="lgreeny-input" placeholder="Text12" />
                        </div>
                    </div>

                    <!-- Date fields (Date01-Date04) -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Date01</label>
                        <InputDate TValue="DateTime?" @bind-Value="documentModel.Date01" class="lgreeny-input" />
                    </div>
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Date02</label>
                        <InputDate TValue="DateTime?" @bind-Value="documentModel.Date02" class="lgreeny-input" />
                    </div>
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Date03</label>
                        <InputDate TValue="DateTime?" @bind-Value="documentModel.Date03" class="lgreeny-input" />
                    </div>
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Date04</label>
                        <InputDate TValue="DateTime?" @bind-Value="documentModel.Date04" class="lgreeny-input" />
                    </div>

                    <!-- Boolean fields (Boolean01-Boolean03) -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Boolean01</label>
                        <InputCheckbox @bind-Value="documentModel.Boolean01" />
                    </div>
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Boolean02</label>
                        <InputCheckbox @bind-Value="documentModel.Boolean02" />
                    </div>
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Boolean03</label>
                        <InputCheckbox @bind-Value="documentModel.Boolean03" />
                    </div>

                    <!-- Number fields (Number01-Number03) -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Number01</label>
                        <InputNumber @bind-Value="documentModel.Number01" class="lgreeny-input" />
                    </div>
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Number02</label>
                        <InputNumber @bind-Value="documentModel.Number02" class="lgreeny-input" />
                    </div>
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Number03</label>
                        <InputNumber @bind-Value="documentModel.Number03" class="lgreeny-input" />
                    </div>

                    <!-- Reference fields (OldDM, CM, GM, EM) -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">OldDM</label>
                        <InputNumber @bind-Value="documentModel.OldDM" class="lgreeny-input" />
                    </div>
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">CM</label>
                        <InputNumber @bind-Value="documentModel.CM" class="lgreeny-input" />
                    </div>
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">GM</label>
                        <InputNumber @bind-Value="documentModel.GM" class="lgreeny-input" />
                    </div>
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">EM</label>
                        <InputNumber @bind-Value="documentModel.EM" class="lgreeny-input" />
                    </div>

                    <!-- FilePath -->
                    <div style="grid-column: 1 / -1;">
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">FilePath (document level, optional)</label>
                        <InputText @bind-Value="documentModel.FilePath" class="lgreeny-input" />
                    </div>
                </div>
            </div>
            

            <!-- Storage Type Selection -->
            <div class="lgreeny-panel" style="margin-bottom: 2rem; padding: 2rem;">
                <h3 style="margin: 0 0 1.5rem 0; color: #166534; font-size: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                    <Icon Name="database" Size="24" /> Storage Configuration
                </h3>

                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 1rem;">
                        Select Storage Type <span style="color: #dc2626;">*</span>
                    </label>
                    <div style="display: flex; gap: 1rem;">
                        <label style="display: flex; align-items: center; gap: 0.5rem; padding: 1rem; border: 2px solid @(storageType == StorageType.Blob ? "#059669" : "#d1d5db"); border-radius: 0.5rem; cursor: pointer; background: @(storageType == StorageType.Blob ? "#d1fae5" : "white");">
                            <input type="radio" name="storageType" value="@((int)StorageType.Blob)" checked="@(storageType == StorageType.Blob)" @onchange="@(() => storageType = StorageType.Blob)" />
                            <Icon Name="cloud" Size="20" Color="@(storageType == StorageType.Blob ? "#059669" : "#6b7280")" />
                            <div>
                                <div style="font-weight: 600; color: #166534;">BLOB Storage (Recommended)</div>
                                <div style="font-size: 0.875rem; color: #059669;">Store files in database</div>
                            </div>
                        </label>
                        <label style="display: flex; align-items: center; gap: 0.5rem; padding: 1rem; border: 2px solid @(storageType == StorageType.FilePath ? "#059669" : "#d1d5db"); border-radius: 0.5rem; cursor: pointer; background: @(storageType == StorageType.FilePath ? "#d1fae5" : "white");">
                            <input type="radio" name="storageType" value="@((int)StorageType.FilePath)" checked="@(storageType == StorageType.FilePath)" @onchange="@(() => storageType = StorageType.FilePath)" />
                            <Icon Name="folder" Size="20" Color="@(storageType == StorageType.FilePath ? "#059669" : "#6b7280")" />
                            <div>
                                <div style="font-weight: 600; color: #166534;">File System</div>
                                <div style="font-size: 0.875rem; color: #059669;">Store files on disk</div>
                            </div>
                        </label>
                    </div>
                </div>

                @if (storageType == StorageType.FilePath)
                {
                    <div style="background: #fef3c7; border: 2px solid #f59e0b; border-radius: 0.5rem; padding: 1rem; margin-top: 1rem;">
                        <div style="display: flex; align-items: start; gap: 0.75rem;">
                            <Icon Name="alert-triangle" Size="20" Color="#f59e0b" />
                            <div style="color: #92400e; font-size: 0.875rem;">
                                <strong>Note:</strong> File system storage requires you to specify file paths for each page. BLOB storage is recommended for new documents.
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Document Pages Upload -->
            <div class="lgreeny-panel" style="margin-bottom: 2rem; padding: 2rem;">
                <h3 style="margin: 0 0 1.5rem 0; color: #166534; font-size: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                    <Icon Name="file-text" Size="24" /> Document Pages
                </h3>

                @if (storageType == StorageType.Blob)
                {
                    <!-- BLOB Upload -->
                    <div style="margin-bottom: 1.5rem;">
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">
                            Upload Page Files
                        </label>
                        <InputFile OnChange="@HandleFileSelection" multiple class="lgreeny-input" accept=".pdf,.tif,.tiff,.jpg,.jpeg,.png,.bmp,.gif" />
                        <div style="font-size: 0.875rem; color: #059669; margin-top: 0.5rem;">
                            Supported formats: PDF, TIFF, JPG, PNG, BMP, GIF (Max 50MB per file)
                        </div>
                    </div>

                    @if (selectedFiles.Any())
                    {
                        <div style="background: #f0fdf4; border: 2px solid #059669; border-radius: 0.5rem; padding: 1rem;">
                            <div style="font-weight: 600; color: #166534; margin-bottom: 0.5rem;">Selected Files (@selectedFiles.Count)</div>
                            <ul style="list-style: none; padding: 0; margin: 0;">
                                @foreach (var file in selectedFiles)
                                {
                                    <li style="padding: 0.5rem; border-bottom: 1px solid #d1fae5; display: flex; align-items: center; justify-content: space-between;">
                                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                                            <Icon Name="file" Size="16" Color="#059669" />
                                            <span style="color: #166534;">@file.Name</span>
                                            <span style="color: #059669; font-size: 0.875rem;">(@FormatFileSize(file.Size))</span>
                                        </div>
                                        <button type="button" class="btn" @onclick="() => RemoveFile(file)" 
                                                style="padding: 0.25rem 0.5rem; background: #dc2626; color: white; border: none; border-radius: 0.25rem; cursor: pointer;">
                                            <Icon Name="x" Size="14" />
                                        </button>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                }
                else
                {
                    <!-- File Path Input -->
                    <div>
                        <label style="display: block; font-weight: 600; color: #166534; margin-bottom: 0.5rem;">
                            File Paths (one per line)
                        </label>
                        <InputTextArea @bind-Value="filePathsInput" 
                                       class="lgreeny-input"
                                       rows="6"
                                       placeholder="Enter file paths, one per line:&#10;C:\Documents\page1.tif&#10;C:\Documents\page2.tif" />
                        <div style="font-size: 0.875rem; color: #059669; margin-top: 0.5rem;">
                            Enter the full file path for each page. Each page will be numbered sequentially.
                        </div>
                    </div>
                }
            </div>

            <!-- Action Buttons -->
            <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                <button type="button" class="lgreeny-btn-secondary" @onclick="GoBack" disabled="@isSubmitting">
                    <Icon Name="x" Size="16" /> Cancel
                </button>
                <button type="submit" class="lgreeny-btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span>Creating Document...</span>
                    }
                    else
                    {
                        <span><Icon Name="save" Size="16" /> Create Document</span>
                    }
                </button>
            </div>
        </EditForm>
    }
</div>

<style>
    .lgreeny-input {
        width: 100%;
        padding: 0.75rem;
        border: 2px solid #d1d5db;
        border-radius: 0.5rem;
        font-size: 1rem;
        transition: all 0.2s;
    }

    .lgreeny-input:focus {
        outline: none;
        border-color: #059669;
        box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.1);
    }

    .lgreeny-input:disabled {
        background: #f3f4f6;
        cursor: not-allowed;
    }
</style>

@code {
    private Project? selectedProject = null;
    private DocumentFormModel documentModel = new();
    private StorageType storageType = StorageType.Blob;
    private List<IBrowserFile> selectedFiles = new();
    private string filePathsInput = string.Empty;
    
    private bool isSubmitting = false;
    private string? successMessage = null;
    private string? errorMessage = null;
    private bool hasRendered = false;

    private enum StorageType
    {
        Blob = 1,
        FilePath = 0
    }

    protected override void OnInitialized()
    {
        // Initialize only
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !hasRendered)
        {
            hasRendered = true;
            await LoadSelectedProject();
            StateHasChanged();
        }
    }

    private async Task LoadSelectedProject()
    {
        try
        {
            var projectIdString = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "selectedProjectId");
            
            if (!string.IsNullOrEmpty(projectIdString) && int.TryParse(projectIdString, out int projectId))
            {
                using var context = await DbContextFactory.CreateDbContextAsync();
                selectedProject = await context.Projects
                    .FirstOrDefaultAsync(p => p.ProjectId == projectId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading selected project");
        }
    }

    private void HandleFileSelection(InputFileChangeEventArgs e)
    {
        selectedFiles.Clear();
        foreach (var file in e.GetMultipleFiles(100)) // Max 100 files
        {
            selectedFiles.Add(file);
        }
        errorMessage = null;
    }

    private void RemoveFile(IBrowserFile file)
    {
        selectedFiles.Remove(file);
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private async Task HandleSubmit()
    {
        if (selectedProject == null)
        {
            errorMessage = "No project selected";
            return;
        }

        // Validate input
        if (string.IsNullOrWhiteSpace(documentModel.DocumentNumber))
        {
            errorMessage = "Document Number is required";
            return;
        }

        if (storageType == StorageType.Blob && !selectedFiles.Any())
        {
            errorMessage = "Please select at least one file to upload";
            return;
        }

        if (storageType == StorageType.FilePath && string.IsNullOrWhiteSpace(filePathsInput))
        {
            errorMessage = "Please enter at least one file path";
            return;
        }

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        StateHasChanged();

        try
        {
            using var context = await DbContextFactory.CreateDbContextAsync();
            
            // Resolve current user id for audit fields
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var username = authState.User?.Identity?.Name;
            var currentUserId = 0;
            if (!string.IsNullOrEmpty(username))
            {
                try
                {
                    using var secCtx = await SecurityDbContextFactory.CreateDbContextAsync();
                    var user = await secCtx.Users.FirstOrDefaultAsync(u => u.Username == username);
                    if (user != null)
                        currentUserId = user.UserId;
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Unable to resolve user id for {User}", username);
                }
            }

            // Create the document in the schema
            var documentId = await CreateDocumentInSchemaAsync(context, selectedProject.SchemaName, currentUserId);

            if (storageType == StorageType.Blob)
            {
                // Upload files as BLOB
                int pageNumber = 1;
                foreach (var file in selectedFiles)
                {
                    var formFile = new FormFileWrapper(file);
                    await DocumentUploadService.UploadFileAsync(
                        documentId,
                        pageNumber,
                        formFile,
                        pageReference: null,
                        userId: currentUserId,
                        documentIndex: documentModel.DocumentIndex ?? ""
                    );
                    pageNumber++;
                }
            }
            else
            {
                // Create pages with file paths
                var filePaths = filePathsInput.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
                    .Select(p => p.Trim())
                    .Where(p => !string.IsNullOrEmpty(p))
                    .ToList();

                int pageNumber = 1;
                foreach (var filePath in filePaths)
                {
                    await DocumentUploadService.CreateFilePathPageInSchemaAsync(selectedProject.SchemaName, documentId, pageNumber, filePath, currentUserId, documentModel.DocumentIndex ?? "");
                    pageNumber++;
                }
            }

            successMessage = $"Document created successfully with {(storageType == StorageType.Blob ? selectedFiles.Count : filePathsInput.Split('\n').Length)} page(s)!";
            
            // Reset form after 2 seconds
            await Task.Delay(2000);
            Navigation.NavigateTo("/editor/files");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating document: {ex.Message}";
            Logger.LogError(ex, "Error creating document");
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task<int> CreateDocumentInSchemaAsync(AppDbContext context, string schemaName, int createdBy)
    {
        var sql = $@"
            INSERT INTO [{schemaName}].[Document] 
            (ProjectId, DocumentIndex, DocumentNumber, DocumentType, Title, Author, Status, DocumentStatus, Classification, Issue, Keywords, Memo, FilePath, DocumentDate,
             Text01, Text02, Text03, Text04, Text05, Text06, Text07, Text08, Text09, Text10, Text11, Text12,
             Date01, Date02, Date03, Date04,
             Boolean01, Boolean02, Boolean03,
             Number01, Number02, Number03,
             OldDM, CM, GM, EM,
             Version, CreatedOn, CreatedBy)
            OUTPUT INSERTED.DocumentId
            VALUES
            (@p0, @p1, @p2, @p3, @p4, @p5, @p6, @p7, @p8, @p9, @p10, @p11, @p12, @p13,
             @p14, @p15, @p16, @p17, @p18, @p19, @p20, @p21, @p22, @p23, @p24, @p25,
             @p26, @p27, @p28, @p29,
             @p30, @p31, @p32,
             @p33, @p34, @p35,
             @p36, @p37, @p38, @p39,
             @p40, @p41, @p42)";

        // Create parameter array - EF Core handles null values properly when passed as object?
        object?[] parameters = new object?[]
        {
            selectedProject!.ProjectId,                           // @p0
            documentModel.DocumentIndex ?? "",                    // @p1
            documentModel.DocumentNumber ?? "",                   // @p2
            documentModel.DocumentType ?? "Document",             // @p3
            documentModel.Title ?? "",                            // @p4
            documentModel.Author ?? "",                           // @p5
            documentModel.Status ?? "Draft",                      // @p6
            null,                                                 // @p7 - DocumentStatus (not in form)
            documentModel.Classification,                         // @p8
            documentModel.Issue,                                  // @p9
            documentModel.Keywords,                               // @p10
            documentModel.Memo,                                   // @p11
            documentModel.FilePath,                               // @p12
            documentModel.DocumentDate,                           // @p13
            documentModel.Text01,                                 // @p14
            documentModel.Text02,                                 // @p15
            documentModel.Text03,                                 // @p16
            documentModel.Text04,                                 // @p17
            documentModel.Text05,                                 // @p18
            documentModel.Text06,                                 // @p19
            documentModel.Text07,                                 // @p20
            documentModel.Text08,                                 // @p21
            documentModel.Text09,                                 // @p22
            documentModel.Text10,                                 // @p23
            documentModel.Text11,                                 // @p24
            documentModel.Text12,                                 // @p25
            documentModel.Date01,                                 // @p26
            documentModel.Date02,                                 // @p27
            documentModel.Date03,                                 // @p28
            documentModel.Date04,                                 // @p29
            documentModel.Boolean01,                              // @p30
            documentModel.Boolean02,                              // @p31
            documentModel.Boolean03,                              // @p32
            documentModel.Number01,                               // @p33
            documentModel.Number02,                               // @p34
            documentModel.Number03,                               // @p35
            documentModel.OldDM,                                  // @p36
            documentModel.CM,                                     // @p37
            documentModel.GM,                                     // @p38
            documentModel.EM,                                     // @p39
            documentModel.Version,                                // @p40
            DateTime.UtcNow,                                      // @p41 - CreatedOn
            createdBy                                             // @p42 - CreatedBy
        };

        var result = await context.Database.SqlQueryRaw<int>(sql, parameters!).ToListAsync();

        return result.FirstOrDefault();
    }

    

