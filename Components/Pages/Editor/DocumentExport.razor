@page "/editor/export"
@attribute [RoleBasedAuthorization("Editor")]
@using DV.Web.Services
@using DV.Shared.Models
@using DV.Web.Components.Layout
@using Microsoft.EntityFrameworkCore
@using System.IO
@using System.IO.Compression
@using System.Text
@using System.Text.Json
@inject DocumentRepository DocumentRepository
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject IDbContextFactory<SecurityDbContext> SecurityDbContextFactory
@inject IDbContextFactory<AppDbContext> DbContextFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<DocumentExport> Logger
@rendermode InteractiveServer

<PageTitle>Bulk Export - Editor</PageTitle>

<div class="lgreeny-dashboard">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <div>
            <h2 style="margin: 0; color: #1e293b; font-size: 1.75rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;">
                <Icon Name="download" Size="28" /> Bulk Document Export
            </h2>
            <p style="margin: 0.5rem 0 0 0; color: #64748b; font-size: 0.875rem;">Export documents with metadata as a ZIP archive</p>
        </div>
        <button class="lgreeny-btn-secondary" style="width: auto;" @onclick="GoBackToDashboard">
            <Icon Name="arrow-left" Size="16" /> Back to Dashboard
        </button>
    </div>

    <!-- Project/Schema Selection -->
    <div class="lgreeny-panel" style="margin-bottom: 1.5rem;">
        <div class="panel-header">
            <h3 class="panel-title"><Icon Name="folder" Size="20" /> Select Source Project / Schema</h3>
        </div>
        <div class="panel-body">
            @if (isLoadingProjects)
            {
                <div style="text-align: center; padding: 2rem;">
                    <div style="color: #3b82f6; font-size: 2rem;"><Icon Name="clock" Size="32" /></div>
                    <p style="color: #64748b; margin-top: 1rem;">Loading your projects...</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(projectErrorMessage))
            {
                <div style="padding: 1rem; background: #fee2e2; border: 1px solid #fecaca; border-radius: 0.5rem; color: #991b1b;">
                    <Icon Name="alert-circle" Size="16" /> @projectErrorMessage
                </div>
            }
            else if (allProjects == null || !allProjects.Any())
            {
                <div style="padding: 2rem; text-align: center; background: #fef3c7; border: 1px solid #fde047; border-radius: 0.5rem;">
                    <div style="font-size: 2rem; margin-bottom: 1rem;"><Icon Name="folder" Size="40" /></div>
                    <h4 style="color: #1e293b; margin-bottom: 0.5rem;">No Projects Available</h4>
                    <p style="color: #64748b;">You don't have Editor access to any projects yet.</p>
                </div>
            }
            else
            {
                <div style="display: grid; gap: 1rem;">
                    <div>
                        <label style="display: block; font-weight: 600; color: #1e293b; margin-bottom: 0.5rem;">
                            Select Project <span style="color: #dc2626;">*</span>
                        </label>
                        <select @bind="selectedProjectId" @bind:after="OnProjectSelected" class="lgreeny-input">
                            <option value="0">-- Select a Project --</option>
                            @foreach (var project in allProjects)
                            {
                                <option value="@project.ProjectId">@project.ProjectName (@project.SchemaName)</option>
                            }
                        </select>
                    </div>
                    
                    @if (selectedProjectId > 0 && selectedProject != null)
                    {
                        <div style="padding: 0.75rem; background: #dbeafe; border-radius: 0.375rem; border: 1px solid #93c5fd;">
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <span style="color: #1e40af; font-weight: 600;">Selected:</span>
                                <span style="color: #1e293b;">@selectedProject.ProjectName</span>
                                <span style="color: #64748b; font-size: 0.875rem;">Schema: @selectedProject.SchemaName</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @if (selectedProjectId > 0 && selectedProject != null)
    {
        <!-- Export Configuration -->
        <div class="lgreeny-panel" style="margin-bottom: 1.5rem;">
            <div class="panel-header">
                <h3 class="panel-title"><Icon Name="filter" Size="20" /> Export Options</h3>
            </div>
            <div class="panel-body">
                <div style="background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 0.5rem; padding: 1rem; margin-bottom: 1.5rem;">
                    <div style="display: flex; align-items: start; gap: 0.75rem;">
                        <Icon Name="info" Size="24" Color="#0369a1" />
                        <div style="flex: 1;">
                            <h4 style="margin: 0 0 0.5rem 0; color: #0c4a6e; font-weight: 600; font-size: 0.875rem;">How Bulk Export Works</h4>
                            <ul style="margin: 0; padding-left: 1.25rem; color: #0c4a6e; font-size: 0.875rem; line-height: 1.6;">
                                <li>Choose to export all documents or filter by criteria</li>
                                <li>Documents are packaged in a ZIP archive with their metadata</li>
                                <li>Metadata is included as JSON and CSV files in the archive</li>
                                <li>Original file names and structure are preserved</li>
                                <li>Large exports may take time to process</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Export Mode Selection -->
                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-weight: 600; color: #1e293b; margin-bottom: 0.75rem;">
                        Export Mode <span style="color: #dc2626;">*</span>
                    </label>
                    <div style="display: grid; gap: 1rem;">
                        <label style="display: flex; align-items: start; gap: 0.75rem; padding: 1rem; border: 2px solid @(exportMode == ExportMode.FullExport ? "#3b82f6" : "#e2e8f0"); border-radius: 0.5rem; cursor: pointer; background: @(exportMode == ExportMode.FullExport ? "#eff6ff" : "white"); transition: all 0.2s;">
                            <input type="radio" 
                                   name="exportMode" 
                                   value="@ExportMode.FullExport" 
                                   checked="@(exportMode == ExportMode.FullExport)"
                                   @onchange="@(() => exportMode = ExportMode.FullExport)"
                                   style="margin-top: 0.25rem;" />
                            <div style="flex: 1;">
                                <div style="font-weight: 600; color: #1e293b; margin-bottom: 0.25rem;">
                                    <Icon Name="database" Size="16" /> Full Export
                                </div>
                                <div style="color: #64748b; font-size: 0.875rem;">
                                    Export all documents from this project/schema
                                </div>
                            </div>
                        </label>

                        <label style="display: flex; align-items: start; gap: 0.75rem; padding: 1rem; border: 2px solid @(exportMode == ExportMode.FilteredExport ? "#3b82f6" : "#e2e8f0"); border-radius: 0.5rem; cursor: pointer; background: @(exportMode == ExportMode.FilteredExport ? "#eff6ff" : "white"); transition: all 0.2s;">
                            <input type="radio" 
                                   name="exportMode" 
                                   value="@ExportMode.FilteredExport" 
                                   checked="@(exportMode == ExportMode.FilteredExport)"
                                   @onchange="@(() => exportMode = ExportMode.FilteredExport)"
                                   style="margin-top: 0.25rem;" />
                            <div style="flex: 1;">
                                <div style="font-weight: 600; color: #1e293b; margin-bottom: 0.25rem;">
                                    <Icon Name="filter" Size="16" /> Filtered Export
                                </div>
                                <div style="color: #64748b; font-size: 0.875rem;">
                                    Apply filters to select specific documents
                                </div>
                            </div>
                        </label>
                    </div>
                </div>

                @if (exportMode == ExportMode.FilteredExport)
                {
                    <!-- Filter Options -->
                    <div style="padding: 1.5rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.5rem;">
                        <h4 style="margin: 0 0 1rem 0; color: #1e293b; font-weight: 600; display: flex; align-items: center; gap: 0.5rem;">
                            <Icon Name="sliders" Size="18" /> Filter Criteria
                        </h4>
                        
                        <div style="display: grid; gap: 1rem;">
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                <div>
                                    <label style="display: block; font-weight: 500; color: #334155; margin-bottom: 0.5rem;">
                                        Document Type
                                    </label>
                                    <input type="text" @bind="filterDocumentType" class="lgreeny-input" placeholder="e.g., Technical Drawing" />
                                </div>
                                <div>
                                    <label style="display: block; font-weight: 500; color: #334155; margin-bottom: 0.5rem;">
                                        Author
                                    </label>
                                    <input type="text" @bind="filterAuthor" class="lgreeny-input" placeholder="Author name" />
                                </div>
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                <div>
                                    <label style="display: block; font-weight: 500; color: #334155; margin-bottom: 0.5rem;">
                                        Keywords (contains)
                                    </label>
                                    <input type="text" @bind="filterKeywords" class="lgreeny-input" placeholder="Search keywords" />
                                </div>
                                <div>
                                    <label style="display: block; font-weight: 500; color: #334155; margin-bottom: 0.5rem;">
                                        Classification
                                    </label>
                                    <input type="text" @bind="filterClassification" class="lgreeny-input" placeholder="e.g., Confidential" />
                                </div>
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                <div>
                                    <label style="display: block; font-weight: 500; color: #334155; margin-bottom: 0.5rem;">
                                        Date From
                                    </label>
                                    <input type="date" @bind="filterDateFrom" class="lgreeny-input" />
                                </div>
                                <div>
                                    <label style="display: block; font-weight: 500; color: #334155; margin-bottom: 0.5rem;">
                                        Date To
                                    </label>
                                    <input type="date" @bind="filterDateTo" class="lgreeny-input" />
                                </div>
                            </div>

                            <div style="display: flex; gap: 0.75rem; justify-content: flex-end;">
                                <button class="lgreeny-btn-secondary" @onclick="ClearFilters" style="width: auto;">
                                    <Icon Name="x" Size="16" /> Clear Filters
                                </button>
                                <button class="lgreeny-btn-primary" @onclick="ApplyFilters" disabled="@isLoadingDocuments" style="width: auto;">
                                    <Icon Name="search" Size="16" /> Apply Filters
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @if (!isLoadingDocuments && documentsToExport.Any())
                {
                    <div style="margin-top: 1.5rem; padding: 1rem; background: #d1fae5; border: 1px solid #6ee7b7; border-radius: 0.5rem;">
                        <div style="display: flex; align-items: center; gap: 0.5rem; color: #065f46;">
                            <Icon Name="check-circle" Size="20" Color="#065f46" />
                            <span style="font-weight: 600;">@documentsToExport.Count document(s) ready for export</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        @if (documentsToExport.Any())
        {
            <!-- Documents Preview -->
            <div class="lgreeny-panel" style="margin-bottom: 1.5rem;">
                <div class="panel-header">
                    <h3 class="panel-title"><Icon Name="file" Size="20" /> Documents to Export (@documentsToExport.Count)</h3>
                </div>
                <div class="panel-body">
                    <div style="max-height: 400px; overflow-y: auto; border: 1px solid #e2e8f0; border-radius: 0.5rem;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <thead style="background: #f8fafc; position: sticky; top: 0; z-index: 1;">
                                <tr>
                                    <th style="padding: 0.75rem; text-align: left; font-weight: 600; color: #1e293b; border-bottom: 2px solid #e2e8f0;">Document Number</th>
                                    <th style="padding: 0.75rem; text-align: left; font-weight: 600; color: #1e293b; border-bottom: 2px solid #e2e8f0;">Title</th>
                                    <th style="padding: 0.75rem; text-align: left; font-weight: 600; color: #1e293b; border-bottom: 2px solid #e2e8f0;">Type</th>
                                    <th style="padding: 0.75rem; text-align: left; font-weight: 600; color: #1e293b; border-bottom: 2px solid #e2e8f0;">Author</th>
                                    <th style="padding: 0.75rem; text-align: left; font-weight: 600; color: #1e293b; border-bottom: 2px solid #e2e8f0;">Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in documentsToExport.Take(100))
                                {
                                    <tr style="border-bottom: 1px solid #e2e8f0;">
                                        <td style="padding: 0.75rem; color: #3b82f6; font-family: monospace;">@doc.DocumentNumber</td>
                                        <td style="padding: 0.75rem; color: #1e293b;">@(doc.Title ?? "-")</td>
                                        <td style="padding: 0.75rem; color: #64748b;">@(doc.DocumentType ?? "-")</td>
                                        <td style="padding: 0.75rem; color: #64748b;">@(doc.Author ?? "-")</td>
                                        <td style="padding: 0.75rem; color: #64748b;">@(doc.DocumentDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                    </tr>
                                }
                                @if (documentsToExport.Count > 100)
                                {
                                    <tr>
                                        <td colspan="5" style="padding: 0.75rem; text-align: center; color: #64748b; font-style: italic; background: #f8fafc;">
                                            ... and @(documentsToExport.Count - 100) more documents
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Export Action -->
            <div class="lgreeny-panel">
                <div class="panel-body">
                    @if (!string.IsNullOrEmpty(exportErrorMessage))
                    {
                        <div style="padding: 1rem; background: #fee2e2; border: 1px solid #fecaca; border-radius: 0.5rem; margin-bottom: 1rem; color: #991b1b;">
                            <Icon Name="alert-circle" Size="16" /> @exportErrorMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(exportSuccessMessage))
                    {
                        <div style="padding: 1rem; background: #d1fae5; border: 1px solid #6ee7b7; border-radius: 0.5rem; margin-bottom: 1rem; color: #065f46;">
                            <Icon Name="check-circle" Size="16" /> @exportSuccessMessage
                        </div>
                    }

                    @if (isExporting)
                    {
                        <div style="padding: 2rem; text-align: center;">
                            <div style="color: #14b8a6; font-size: 3rem; margin-bottom: 1rem;"><Icon Name="loader" Size="48" Color="#14b8a6" /></div>
                            <h3 style="color: #1e293b; margin-bottom: 0.5rem;">Preparing Export...</h3>
                            <p style="color: #64748b;">Processing @exportProgress / @documentsToExport.Count documents</p>
                            <div style="width: 100%; max-width: 600px; margin: 1rem auto; background: #e5e7eb; border-radius: 0.5rem; height: 0.5rem; overflow: hidden;">
                                <div style="width: @((exportProgress * 100.0 / documentsToExport.Count))%; background: #14b8a6; height: 100%; transition: width 0.3s;"></div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div style="display: flex; gap: 1rem; justify-content: space-between; align-items: center;">
                            <div>
                                <h4 style="margin: 0 0 0.25rem 0; color: #1e293b;">Ready to export @documentsToExport.Count document(s)</h4>
                                <p style="margin: 0; color: #64748b; font-size: 0.875rem;">
                                    Documents will be packaged as a ZIP file with metadata from: <strong>@selectedProject.ProjectName</strong>
                                </p>
                            </div>
                            <button class="lgreeny-btn-primary" 
                                    @onclick="StartBulkExport" 
                                    disabled="@(!documentsToExport.Any())"
                                    style="padding: 1rem 2rem; font-size: 1rem;">
                                <Icon Name="download" Size="16" /> Start Export
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

<style>
    .lgreeny-dashboard {
        max-width: 1400px;
        margin: 0 auto;
        padding: 1.5rem;
    }

    .lgreeny-panel {
        background: white;
        border-radius: 0.75rem;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
        border: 1px solid #e2e8f0;
    }

    .lgreeny-btn-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
        border: none;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        width: 100%;
    }

    .lgreeny-btn-primary:hover:not(:disabled) {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.3);
        transform: translateY(-1px);
    }

    .lgreeny-btn-primary:disabled {
        background: #e2e8f0;
        color: #94a3b8;
        cursor: not-allowed;
    }

    .lgreeny-btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        background: white;
        color: #64748b;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        width: 100%;
    }

    .lgreeny-btn-secondary:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: #475569;
    }

    .lgreeny-input {
        width: 100%;
        padding: 0.75rem;
