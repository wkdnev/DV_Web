@code {
    // Project selection
    private int selectedProjectId = 0;
    private Project? selectedProject;
    private IEnumerable<Project>? allProjects;
    private bool isLoadingProjects = false;
    private string? projectErrorMessage;

    // Export configuration
    private ExportMode exportMode = ExportMode.FullExport;
    private List<Document> documentsToExport = new();
    private bool isLoadingDocuments = false;

    // Filters
    private string filterDocumentType = string.Empty;
    private string filterAuthor = string.Empty;
    private string filterKeywords = string.Empty;
    private string filterClassification = string.Empty;
    private DateTime? filterDateFrom;
    private DateTime? filterDateTo;

    // Export process
    private bool isExporting = false;
    private int exportProgress = 0;
    private string? exportErrorMessage;
    private string? exportSuccessMessage;

    private enum ExportMode
    {
        FullExport,
        FilteredExport
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        isLoadingProjects = true;
        projectErrorMessage = null;

        try
        {
            // Get the current authenticated user
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var username = authState.User?.Identity?.Name;
            
            if (string.IsNullOrEmpty(username))
            {
                projectErrorMessage = "No authenticated user found";
                allProjects = Enumerable.Empty<Project>();
                return;
            }

            using var securityContext = await SecurityDbContextFactory.CreateDbContextAsync();
            
            // Get the user
            var user = await securityContext.Users
                .FirstOrDefaultAsync(u => u.Username == username);
            
            if (user == null)
            {
                projectErrorMessage = $"User not found: {username}";
                allProjects = Enumerable.Empty<Project>();
                return;
            }

            // Get project IDs where the user has the Editor role
            var editorProjectIds = await securityContext.UserProjectRoles
                .Where(upr => upr.UserId == user.UserId && upr.IsActive)
                .Include(upr => upr.ProjectRole)
                    .ThenInclude(pr => pr!.ApplicationRole)
                .Where(upr => upr.ProjectRole!.ApplicationRole!.Name == "Editor")
                .Select(upr => upr.ProjectRole!.ProjectId)
                .Distinct()
                .ToListAsync();
            
            if (editorProjectIds.Count == 0)
            {
                projectErrorMessage = "No projects available. You do not have Editor role assignments for any projects.";
                allProjects = Enumerable.Empty<Project>();
                return;
            }

            // Get the actual Project entities from AppDbContext
            using var appContext = await DbContextFactory.CreateDbContextAsync();
            allProjects = await appContext.Projects
                .Where(p => editorProjectIds.Contains(p.ProjectId))
                .OrderBy(p => p.ProjectName)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            projectErrorMessage = $"Error loading projects: {ex.Message}";
            allProjects = Enumerable.Empty<Project>();
            Logger.LogError(ex, "Error loading projects for bulk export");
        }
        finally
        {
            isLoadingProjects = false;
        }
    }

    private async Task OnProjectSelected()
    {
        if (selectedProjectId > 0)
        {
            selectedProject = allProjects?.FirstOrDefault(p => p.ProjectId == selectedProjectId);
            await LoadDocuments();
        }
        else
        {
            selectedProject = null;
            documentsToExport.Clear();
        }
    }

    private async Task LoadDocuments()
    {
        if (selectedProjectId == 0 || selectedProject == null) return;

        isLoadingDocuments = true;
        exportErrorMessage = null;

        try
        {
            using var appContext = await DbContextFactory.CreateDbContextAsync();
            var schemaName = selectedProject.SchemaName;

            if (string.IsNullOrEmpty(schemaName))
            {
                exportErrorMessage = "Project schema not configured.";
                return;
            }

            // Build SQL query for the specific schema
            var sql = $"SELECT * FROM [{schemaName}].[Document] WHERE ProjectId = {{0}}";
            var parameters = new List<object> { selectedProjectId };

            // Apply filters if in filtered mode
            if (exportMode == ExportMode.FilteredExport)
            {
                if (!string.IsNullOrWhiteSpace(filterDocumentType))
                {
                    sql += $" AND DocumentType LIKE {{{parameters.Count}}}";
                    parameters.Add($"%{filterDocumentType}%");
                }

                if (!string.IsNullOrWhiteSpace(filterAuthor))
                {
                    sql += $" AND Author LIKE {{{parameters.Count}}}";
                    parameters.Add($"%{filterAuthor}%");
                }

                if (!string.IsNullOrWhiteSpace(filterKeywords))
                {
                    sql += $" AND Keywords LIKE {{{parameters.Count}}}";
                    parameters.Add($"%{filterKeywords}%");
                }

                if (!string.IsNullOrWhiteSpace(filterClassification))
                {
                    sql += $" AND Classification LIKE {{{parameters.Count}}}";
                    parameters.Add($"%{filterClassification}%");
                }

                if (filterDateFrom.HasValue)
                {
                    sql += $" AND DocumentDate >= {{{parameters.Count}}}";
                    parameters.Add(filterDateFrom.Value);
                }

                if (filterDateTo.HasValue)
                {
                    sql += $" AND DocumentDate <= {{{parameters.Count}}}";
                    parameters.Add(filterDateTo.Value);
                }
            }

            sql += " ORDER BY DocumentNumber";

            documentsToExport = await appContext.Database
                .SqlQueryRaw<Document>(sql, parameters.ToArray())
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading documents from schema {SchemaName}", selectedProject?.SchemaName);
            exportErrorMessage = $"Failed to load documents: {ex.Message}";
            documentsToExport = new List<Document>();
        }
        finally
        {
            isLoadingDocuments = false;
        }
    }

    private async Task ApplyFilters()
    {
        await LoadDocuments();
    }

    private async Task ClearFilters()
    {
        filterDocumentType = string.Empty;
        filterAuthor = string.Empty;
        filterKeywords = string.Empty;
        filterClassification = string.Empty;
        filterDateFrom = null;
        filterDateTo = null;
        await LoadDocuments();
    }

    private async Task StartBulkExport()
    {
        if (!documentsToExport.Any()) return;

        isExporting = true;
        exportProgress = 0;
        exportErrorMessage = null;
        exportSuccessMessage = null;

        try
        {
            // Create temporary directory for export
            var tempPath = Path.Combine(Path.GetTempPath(), $"DocExport_{Guid.NewGuid()}");
            Directory.CreateDirectory(tempPath);

            try
            {
                // Create metadata files
                await CreateMetadataFiles(tempPath);

                // Copy document files
                var documentsPath = Path.Combine(tempPath, "Documents");
                Directory.CreateDirectory(documentsPath);

                var copiedCount = 0;
                var skippedCount = 0;
                var missingCount = 0;

                using var appContext = await DbContextFactory.CreateDbContextAsync();
                var schemaName = selectedProject!.SchemaName;

                foreach (var doc in documentsToExport)
                {
                    exportProgress++;
                    StateHasChanged();

                    try
                    {
                        // First, try to get pages from blob storage
                        var pagesSql = $"SELECT * FROM [{schemaName}].[DocumentPage] WHERE DocumentId = {{0}} ORDER BY PageNumber";
                        var pages = await appContext.Database
                            .SqlQueryRaw<DocumentPage>(pagesSql, doc.DocumentId)
                            .ToListAsync();

                        if (pages.Any())
                        {
                            // Export each page as a separate file
                            foreach (var page in pages)
                            {
                                if (page.FileContent != null && page.FileContent.Length > 0)
                                {
                                    var extension = !string.IsNullOrEmpty(page.FileType) ? page.FileType.TrimStart('.') : 
                                                    !string.IsNullOrEmpty(page.FileName) ? Path.GetExtension(page.FileName).TrimStart('.') : "bin";
                                    
                                    var fileName = pages.Count > 1 
                                        ? $"{doc.DocumentNumber}_Page{page.PageNumber:D3}.{extension}"
                                        : $"{doc.DocumentNumber}.{extension}";
                                    
                                    var destPath = Path.Combine(documentsPath, fileName);
                                    await File.WriteAllBytesAsync(destPath, page.FileContent);
                                    copiedCount++;
                                    Logger.LogInformation("Exported blob for document {DocumentNumber}, page {PageNumber}", 
                                        doc.DocumentNumber, page.PageNumber);
                                }
                                else if (!string.IsNullOrEmpty(page.FilePath) && File.Exists(page.FilePath))
                                {
                                    // Fallback to file path if no blob data
                                    var fileName = pages.Count > 1 
                                        ? $"{doc.DocumentNumber}_Page{page.PageNumber:D3}{Path.GetExtension(page.FilePath)}"
                                        : $"{doc.DocumentNumber}{Path.GetExtension(page.FilePath)}";
                                    
                                    var destPath = Path.Combine(documentsPath, fileName);
                                    File.Copy(page.FilePath, destPath, true);
                                    copiedCount++;
                                    Logger.LogInformation("Copied file for document {DocumentNumber}, page {PageNumber}", 
                                        doc.DocumentNumber, page.PageNumber);
                                }
                            }
                        }
                        else if (!string.IsNullOrEmpty(doc.FilePath) && File.Exists(doc.FilePath))
                        {
                            // Fallback to document-level FilePath if no pages
                            var fileName = Path.GetFileName(doc.FilePath);
                            var destPath = Path.Combine(documentsPath, $"{doc.DocumentNumber}_{fileName}");
                            File.Copy(doc.FilePath, destPath, true);
                            copiedCount++;
                            Logger.LogInformation("Copied file from document FilePath: {FilePath}", doc.FilePath);
                        }
                        else
                        {
                            Logger.LogWarning("Document {DocumentNumber} has no pages or file data", doc.DocumentNumber);
                            skippedCount++;
                        }
                    }
                    catch (Exception ex)
                    {
                        Logger.LogError(ex, "Error exporting document {DocumentNumber}", doc.DocumentNumber);
                        skippedCount++;
                    }

                    // Small delay for UI update
                    if (exportProgress % 10 == 0)
                    {
                        await Task.Delay(50);
                    }
                }

                Logger.LogInformation("Export summary: Copied={Copied}, Missing={Missing}, Skipped={Skipped}", 
                    copiedCount, missingCount, skippedCount);

                // Create ZIP file
                var zipFileName = $"{selectedProject!.ProjectName.Replace(" ", "_")}_Export_{DateTime.Now:yyyyMMdd_HHmmss}.zip";
                var zipPath = Path.Combine(Path.GetTempPath(), zipFileName);

                if (File.Exists(zipPath))
                {
                    File.Delete(zipPath);
                }

                ZipFile.CreateFromDirectory(tempPath, zipPath);

                // Trigger download using inline JavaScript
                var zipBytes = await File.ReadAllBytesAsync(zipPath);
                var base64 = Convert.ToBase64String(zipBytes);
                
                var downloadScript = $@"
                    (function() {{
                        const byteCharacters = atob('{base64}');
                        const byteNumbers = new Array(byteCharacters.length);
                        for (let i = 0; i < byteCharacters.length; i++) {{
                            byteNumbers[i] = byteCharacters.charCodeAt(i);
                        }}
                        const byteArray = new Uint8Array(byteNumbers);
                        const blob = new Blob([byteArray], {{ type: 'application/zip' }});
                        const url = window.URL.createObjectURL(blob);
                        const link = document.createElement('a');
                        link.href = url;
                        link.download = '{zipFileName}';
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        window.URL.revokeObjectURL(url);
                    }})();
                ";
                
                await JSRuntime.InvokeVoidAsync("eval", downloadScript);

                exportSuccessMessage = $"Successfully exported {documentsToExport.Count} document(s) to {zipFileName}";

                // Cleanup
                File.Delete(zipPath);
            }
            finally
            {
                // Cleanup temp directory
                if (Directory.Exists(tempPath))
                {
                    Directory.Delete(tempPath, true);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during bulk export");
            exportErrorMessage = $"Export failed: {ex.Message}";
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task CreateMetadataFiles(string basePath)
    {
        // Create JSON metadata
        var jsonPath = Path.Combine(basePath, "metadata.json");
        var jsonOptions = new JsonSerializerOptions { WriteIndented = true };
        var jsonContent = JsonSerializer.Serialize(documentsToExport, jsonOptions);
        await File.WriteAllTextAsync(jsonPath, jsonContent);

        // Create CSV metadata
        var csvPath = Path.Combine(basePath, "metadata.csv");
        var csv = new StringBuilder();
        
        // Headers
        csv.AppendLine("DocumentId,ProjectId,DocumentNumber,Title,Author,DocumentDate,DocumentType,Keywords,Classification,Status,Version,FilePath");
        
        // Data
        foreach (var doc in documentsToExport)
        {
            csv.AppendLine($"\"{doc.DocumentId}\",\"{doc.ProjectId}\",\"{EscapeCsv(doc.DocumentNumber)}\",\"{EscapeCsv(doc.Title)}\",\"{EscapeCsv(doc.Author)}\",\"{doc.DocumentDate?.ToString("yyyy-MM-dd")}\",\"{EscapeCsv(doc.DocumentType)}\",\"{EscapeCsv(doc.Keywords)}\",\"{EscapeCsv(doc.Classification)}\",\"{EscapeCsv(doc.Status)}\",\"{EscapeCsv(doc.Version)}\",\"{EscapeCsv(doc.FilePath)}\"");
        }
        
        await File.WriteAllTextAsync(csvPath, csv.ToString());

        // Create README
        var readmePath = Path.Combine(basePath, "README.txt");
        var readme = new StringBuilder();
        readme.AppendLine($"Document Export from {selectedProject!.ProjectName}");
        readme.AppendLine($"Exported: {DateTime.Now:yyyy-MM-dd HH:mm:ss}");
        readme.AppendLine($"Total Documents: {documentsToExport.Count}");
        readme.AppendLine();
        readme.AppendLine("Contents:");
        readme.AppendLine("- Documents/: Exported document files");
        readme.AppendLine("- metadata.json: Document metadata in JSON format");
        readme.AppendLine("- metadata.csv: Document metadata in CSV format");
        readme.AppendLine();
        readme.AppendLine("Export Details:");
        readme.AppendLine($"- Export Mode: {exportMode}");
        readme.AppendLine($"- Project: {selectedProject.ProjectName}");
        readme.AppendLine($"- Schema: {selectedProject.SchemaName}");
        
        await File.WriteAllTextAsync(readmePath, readme.ToString());
    }

    private string EscapeCsv(string? value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        return value.Replace("\"", "\"\"");
    }

    private void GoBackToDashboard()
    {
        Navigation.NavigateTo("/editor/dashboard");
    }
}
