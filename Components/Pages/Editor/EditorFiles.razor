@page "/editor/files"
@attribute [RoleBasedAuthorization("Editor")]
@using DV.Shared.Security
@using DV.Shared.Models
@using DV.Web.Services
@using DV.Web.Components.Layout
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IDbContextFactory<AppDbContext> DbContextFactory
@inject DocumentRepository DocumentRepository
@inject DocumentUploadService DocumentUploadService
@inject IDbContextFactory<SecurityDbContext> SecurityDbContextFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@rendermode InteractiveServer

<PageTitle>Files - Editor Dashboard</PageTitle>

<div class="lgreeny-dashboard">
    <!-- Page Header -->
    <div style="margin-bottom: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h1 style="margin: 0; font-size: 1.75rem; font-weight: 600; color: #1e293b;">Document Files</h1>
                <p style="margin: 0.5rem 0 0 0; font-size: 0.875rem; color: #64748b;">
                    @if (selectedProject != null)
                    {
                        <span>Managing documents in <strong>@selectedProject.ProjectName</strong></span>
                    }
                    else
                    {
                        <span>Browse and manage document files</span>
                    }
                </p>
            </div>
            <button class="lgreeny-btn-secondary" style="width: auto;" @onclick="GoBackToDashboard">
                <span style="display: inline-block; vertical-align: middle; margin-right: 0.25rem;">
                    <Icon Name="arrow-left" Size="16" />
                </span>
                Back to Dashboard
            </button>
        </div>
    </div>

    @if (selectedProject == null)
    {
        <!-- No Project Selected -->
        <div class="lgreeny-panel">
            <div class="panel-body" style="text-align: center; padding: 3rem;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">
                    <Icon Name="folder" Size="64" Color="#94a3b8" />
                </div>
                <h4 style="color: #1e293b; margin-bottom: 0.5rem;">No Project Selected</h4>
                <p style="color: #64748b; max-width: 600px; margin: 0 auto 1.5rem auto;">
                    Please select a project from the Editor Dashboard to view and manage its documents.
                </p>
                <button class="lgreeny-btn-primary" @onclick="GoBackToDashboard">
                    Go to Dashboard
                </button>
            </div>
        </div>
    }
    else
    {
        <!-- Stats Cards -->
        <div class="lgreeny-stats-row" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 1.5rem;">
            <div class="lgreeny-stat-card" style="padding: 0.75rem;">
                <div class="stat-header" style="margin-bottom: 0.5rem;">
                    <span class="stat-title" style="font-size: 0.7rem;">Total Documents</span>
                    <span class="stat-icon blue" style="width: 1.5rem; height: 1.5rem;">
                        <Icon Name="file-text" Size="12" Color="white" />
                    </span>
                </div>
                <div class="stat-value" style="font-size: 1.25rem; margin-bottom: 0.25rem;">@allDocuments.Count</div>
                <div class="stat-change">
                    <span class="stat-period" style="font-size: 0.7rem;">In @selectedProject.ProjectName</span>
                </div>
            </div>

            <div class="lgreeny-stat-card" style="padding: 0.75rem;">
                <div class="stat-header" style="margin-bottom: 0.5rem;">
                    <span class="stat-title" style="font-size: 0.7rem;">Filtered Results</span>
                    <span class="stat-icon teal" style="width: 1.5rem; height: 1.5rem;">
                        <Icon Name="filter" Size="12" Color="white" />
                    </span>
                </div>
                <div class="stat-value" style="font-size: 1.25rem; margin-bottom: 0.25rem;">@filteredDocuments.Count</div>
                <div class="stat-change">
                    <span class="stat-period" style="font-size: 0.7rem;">Showing</span>
                </div>
            </div>

            <div class="lgreeny-stat-card" style="padding: 0.75rem;">
                <div style="display: flex; flex-direction: column; height: 100%; justify-content: space-between;">
                    <div>
                        <div class="stat-header" style="margin-bottom: 0.5rem;">
                            <span class="stat-title" style="font-size: 0.7rem;">Quick Actions</span>
                            <span class="stat-icon purple" style="width: 1.5rem; height: 1.5rem;">
                                <Icon Name="zap" Size="12" Color="white" />
                            </span>
                        </div>
                    </div>
                    <button class="lgreeny-btn-primary" @onclick="AddNewDocument" 
                            style="width: 100%; padding: 0.5rem 1rem; margin-top: 0.5rem; font-size: 0.875rem;">
                        <Icon Name="plus" Size="14" /> Add Document
                    </button>
                </div>
            </div>
        </div>

        <!-- Search Panel -->
        <div class="lgreeny-panel" style="margin-bottom: 1.5rem;">
            <div class="panel-header">
                <div>
                    <h3 class="panel-title" style="display: flex; align-items: center; gap: 0.5rem;">
                        <Icon Name="search" Size="20" />
                        <span>Search & Filter</span>
                    </h3>
                </div>
            </div>
            <div class="panel-body">
                <div style="display: grid; grid-template-columns: 1fr auto; gap: 1rem; align-items: end;">
                    <div>
                        <label style="display: block; font-size: 0.875rem; font-weight: 500; color: #334155; margin-bottom: 0.5rem;">
                            Search Documents
                        </label>
                        <div style="position: relative;">
                            <input type="text" 
                                   class="form-control" 
                                   placeholder="Search by document number, title, author, keywords..." 
                                   @bind="SearchText"
                                   @bind:event="oninput"
                                   style="padding-left: 2.5rem; height: 2.75rem; border: 2px solid #e2e8f0; border-radius: 0.5rem; font-size: 0.875rem;" />
                            <span style="position: absolute; left: 0.875rem; top: 50%; transform: translateY(-50%);">
                                <Icon Name="search" Size="16" Color="#94a3b8" />
                            </span>
                            @if (!string.IsNullOrWhiteSpace(searchText))
                            {
                                <button @onclick="ClearSearch"
                                        style="position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%); padding: 0.375rem 0.75rem; background: #f1f5f9; color: #64748b; border: none; border-radius: 0.375rem; font-size: 0.75rem; cursor: pointer; font-weight: 500;">
                                    <Icon Name="x" Size="14" /> Clear
                                </button>
                            }
                        </div>
                    </div>
                    <button class="lgreeny-btn-primary" style="width: auto; height: 2.75rem;" disabled="@isLoading">
                        <span style="display: inline-block; vertical-align: middle; margin-right: 0.25rem;">
                            <Icon Name="refresh-cw" Size="16" />
                        </span>
                        Refresh
                    </button>
                </div>
                @if (!string.IsNullOrWhiteSpace(searchText))
                {
                    <div style="margin-top: 0.75rem; padding: 0.75rem; background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 0.375rem; font-size: 0.875rem; color: #0c4a6e;">
                        <Icon Name="info" Size="16" Color="#0369a1" />
                        <span style="margin-left: 0.5rem;">
                            Showing <strong>@filteredDocuments.Count</strong> of <strong>@allDocuments.Count</strong> documents matching "<strong>@searchText</strong>"
                        </span>
                    </div>
                }
            </div>
        </div>

        <!-- Documents Table Panel -->
        <div class="lgreeny-panel">
            <div class="panel-header">
                <div>
                    <h3 class="panel-title" style="display: flex; align-items: center; gap: 0.5rem;">
                        <Icon Name="file-text" Size="20" />
                        <span>Documents</span>
                    </h3>
                    <p style="margin: 0.25rem 0 0 0; font-size: 0.875rem; color: #94a3b8;">
                        Showing @filteredDocuments.Count document@(filteredDocuments.Count != 1 ? "s" : "")
                    </p>
                </div>
            </div>
            <div class="panel-body" style="padding: 0;">
                @if (isLoading)
                {
                    <div style="padding: 3rem; text-align: center;">
                        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p style="margin-top: 1rem; color: #64748b;">Loading documents...</p>
                    </div>
                }
                else if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div style="padding: 2rem; margin: 1rem; background: #fee2e2; border: 1px solid #fecaca; border-radius: 0.5rem; color: #991b1b;">
                        <div style="display: flex; align-items: center; gap: 0.75rem;">
                            <Icon Name="alert-triangle" Size="24" Color="#dc2626" />
                            <div>
                                <strong>Error Loading Documents</strong>
                                <p style="margin: 0.25rem 0 0 0;">@errorMessage</p>
                            </div>
                        </div>
                    </div>
                }
                else if (filteredDocuments.Count == 0)
                {
                    <div style="padding: 3rem; text-align: center;">
                        <div style="font-size: 3rem; margin-bottom: 1rem; color: #94a3b8;">
                            <Icon Name="inbox" Size="64" />
                        </div>
                        @if (string.IsNullOrWhiteSpace(searchText))
                        {
                            <h4 style="color: #1e293b; margin-bottom: 0.5rem;">No Documents Found</h4>
                            <p style="color: #64748b;">This project doesn't have any documents yet.</p>
                        }
                        else
                        {
                            <h4 style="color: #1e293b; margin-bottom: 0.5rem;">No Matches Found</h4>
                            <p style="color: #64748b;">No documents match your search criteria. Try a different search term.</p>
                            <button class="lgreeny-btn-secondary" style="margin-top: 1rem;" @onclick="ClearSearch">
                                Clear Search
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div style="max-height: 600px; overflow-y: auto;">
                        <table class="lgreeny-table">
                            <thead style="position: sticky; top: 0; z-index: 10; background: white;">
                                <tr>
                                    <th style="width: 100px;">Document #</th>
                                    <th>Title</th>
                                    <th style="width: 120px;">Type</th>
                                    <th style="width: 150px;">Author</th>
                                    <th style="width: 100px;">Status</th>
                                    <th style="width: 120px;">Created</th>
                                    <th style="width: 80px;">Pages</th>
                                    <th style="width: 200px; text-align: right;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in filteredDocuments)
                                {
                                    <tr>
                                        <td>
                                            <strong style="color: #1e293b; font-family: 'Courier New', monospace; font-size: 0.875rem;">
                                                @doc.DocumentNumber
                                            </strong>
                                        </td>
                                        <td>
                                            <strong style="color: #1e293b;">@doc.Title</strong>
                                            @if (!string.IsNullOrEmpty(doc.Keywords))
                                            {
                                                <br>
                                                <small style="color: #94a3b8;">
                                                    <Icon Name="tag" Size="12" Color="#94a3b8" />
                                                    @doc.Keywords
                                                </small>
                                            }
                                        </td>
                                        <td>
                                            <span style="padding: 0.25rem 0.5rem; background: #dbeafe; color: #1e40af; border-radius: 0.25rem; font-size: 0.75rem; font-weight: 500;">
                                                @doc.DocumentType
                                            </span>
                                        </td>
                                        <td>
                                            <small style="color: #64748b;">@doc.Author</small>
                                        </td>
                                        <td>
                                            <span style="padding: 0.25rem 0.5rem; background: @GetStatusColor(doc.DocumentStatus); border-radius: 0.25rem; font-size: 0.75rem; font-weight: 500;">
                                                @doc.DocumentStatus
                                            </span>
                                        </td>
                                        <td>
                                            <small style="color: #64748b;">@doc.CreatedOn.ToString("MMM dd, yyyy")</small>
                                        </td>
                                        <td style="text-align: center;">
                                            <span style="padding: 0.25rem 0.5rem; background: #f1f5f9; color: #475569; border-radius: 0.25rem; font-size: 0.75rem; font-weight: 600;">
                                                @GetPageCount(doc.DocumentId)
                                            </span>
                                        </td>
                                        <td>
                                            <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                                                <button class="btn btn-sm" 
                                                        style="padding: 0.375rem 0.75rem; background: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe; border-radius: 0.375rem; font-size: 0.75rem; cursor: pointer; font-weight: 500;"
                                                        @onclick="() => ViewDocument(doc)"
                                                        title="View Document">
                                                    <Icon Name="eye" Size="14" /> View
                                                </button>
                                                <button class="btn btn-sm" 
                                                        style="padding: 0.375rem 0.75rem; background: #fef3c7; color: #92400e; border: 1px solid #fde68a; border-radius: 0.375rem; font-size: 0.75rem; cursor: pointer; font-weight: 500;"
                                                        @onclick="() => EditDocument(doc)"
                                                        title="Edit Document">
                                                    <Icon Name="edit" Size="14" /> Edit
                                                </button>
                                                <button class="btn btn-sm" 
                                                        style="padding: 0.375rem 0.75rem; background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; border-radius: 0.375rem; font-size: 0.75rem; cursor: pointer; font-weight: 500;"
                                                        @onclick="() => DeleteDocument(doc)"
                                                        title="Delete Document">
                                                    <Icon Name="trash-2" Size="14" /> Delete
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Delete Confirmation Modal -->
    @if (showDeleteConfirmation)
    {
        <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;">
            <div style="background: white; border-radius: 0.5rem; padding: 2rem; max-width: 500px; width: 90%;">
                <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                    <div style="width: 48px; height: 48px; background: #fee2e2; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                        <Icon Name="alert-triangle" Size="24" Color="#dc2626" />
                    </div>
                    <div>
                        <h3 style="margin: 0; color: #1e293b; font-size: 1.25rem;">Delete Document</h3>
                        <p style="margin: 0.25rem 0 0 0; color: #64748b; font-size: 0.875rem;">This action cannot be undone</p>
                    </div>
                </div>
                
                @if (documentToDelete != null)
                {
                    <div style="padding: 1rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.375rem; margin-bottom: 1.5rem;">
                        <p style="margin: 0; color: #334155; font-size: 0.875rem;">
                            <strong>Document #@documentToDelete.DocumentNumber</strong><br>
                            @documentToDelete.Title
                        </p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(deleteErrorMessage))
                {
                    <div style="padding: 0.75rem; background: #fee2e2; border: 1px solid #fecaca; border-radius: 0.375rem; margin-bottom: 1rem; color: #991b1b; font-size: 0.875rem;">
                        <Icon Name="alert-circle" Size="16" Color="#dc2626" />
                        <span style="margin-left: 0.5rem;">@deleteErrorMessage</span>
                    </div>
                }

                <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                    <button class="lgreeny-btn-secondary" style="width: auto;" @onclick="CancelDelete" disabled="@isDeleting">
                        Cancel
                    </button>
                    <button class="btn" 
                            style="padding: 0.5rem 1.5rem; background: #dc2626; color: white; border: none; border-radius: 0.375rem; font-weight: 500; cursor: pointer;"
                            @onclick="ConfirmDelete"
                            disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span>Deleting...</span>
                        }
                        else
                        {
                            <span><Icon Name="trash-2" Size="16" /> Delete Document</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@* Edit Document Dialog *@
@if (showEditDialog && editingDocument != null)
{
    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;" @onclick="CloseEditDialog">
        <div style="background: white; border-radius: 0.5rem; padding: 2rem; max-width: 900px; width: 90%; max-height: 90vh; overflow-y: auto;" @onclick:stopPropagation>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h3 style="margin: 0; color: #1e293b;">âœï¸ Edit Document Metadata</h3>
                <button @onclick="CloseEditDialog" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #64748b;">âœ–</button>
            </div>

            @if (!string.IsNullOrEmpty(editErrorMessage))
            {
                <div style="padding: 1rem; background: #fee2e2; border: 1px solid #fecaca; border-radius: 0.5rem; margin-bottom: 1rem; color: #991b1b;">
                    âš ï¸ @editErrorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(editSuccessMessage))
            {
                <div style="padding: 1rem; background: #d1fae5; border: 1px solid #a7f3d0; border-radius: 0.5rem; margin-bottom: 1rem; color: #065f46;">
                    âœ… @editSuccessMessage
                </div>
            }

            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
                <!-- Document Number -->
                <div style="grid-column: 1 / -1;">
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                        Document Number *
                    </label>
                    <input type="text" 
                           @bind="editingDocument.DocumentNumber"
                           style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem; font-family: monospace;" />
                </div>

                <!-- Title -->
                <div style="grid-column: 1 / -1;">
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                        Title
                    </label>
                    <input type="text" 
                           @bind="editingDocument.Title"
                           style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                </div>

                <!-- Author -->
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                        Author
                    </label>
                    <input type="text" 
                           @bind="editingDocument.Author"
                           style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                </div>

                <!-- Document Type -->
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                        Document Type
                    </label>
                    <select @bind="editingDocument.DocumentType"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;">
                        <option value="PDF">PDF</option>
                        <option value="TIFF">TIFF</option>
                    </select>
                </div>

                <!-- Status -->
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                        Status
                    </label>
                    <select @bind="editingDocument.DocumentStatus"
                            style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;">
                        <option value="Draft">Draft</option>
                        <option value="Pending">Pending</option>
                        <option value="Active">Active</option>
                        <option value="Archived">Archived</option>
                    </select>
                </div>

                <!-- Classification -->
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                        Classification
                    </label>
                    <input type="text" 
                           @bind="editingDocument.Classification"
                           style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                </div>

                <!-- Keywords -->
                <div style="grid-column: 1 / -1;">
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                        Keywords
                    </label>
                    <input type="text" 
                           @bind="editingDocument.Keywords"
                           placeholder="Comma-separated keywords"
                           style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                </div>

                <!-- Document Index -->
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                        Document Index
                    </label>
                    <input type="text" 
                           @bind="editingDocument.DocumentIndex"
                           style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                </div>

                <!-- Issue -->
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                        Issue
                    </label>
                    <input type="text" 
                           @bind="editingDocument.Issue"
                           style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                </div>

                <!-- Memo -->
                <div style="grid-column: 1 / -1;">
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">
                        Memo
                    </label>
                    <textarea @bind="editingDocument.Memo"
                              rows="3"
                              style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem; resize: vertical;"></textarea>
                </div>

                <!-- Additional Metadata -->
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">File Path</label>
                    <input type="text" @bind="editingDocument.FilePath" style="width: 100%; padding: 0.5rem; border: 1px solid #e2e8f0; border-radius: 0.375rem; font-size: 0.875rem;" />
                </div>

                <div>
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">Document Date</label>
                    <InputDate TValue="DateTime?" @bind-Value="editingDocument.DocumentDate" class="lgreeny-input" />
                </div>

                <!-- Text Fields (Text01-Text12) -->
                <div style="grid-column: 1 / -1;">
                    <label style="display: block; margin-bottom: 0.5rem; color: #1e293b; font-weight: 500; font-size: 0.875rem;">Custom Text Fields</label>
                    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem;">
                        <input type="text" @bind="editingDocument.Text01" class="lgreeny-input" placeholder="Text01" />
                        <input type="text" @bind="editingDocument.Text02" class="lgreeny-input" placeholder="Text02" />
                        <input type="text" @bind="editingDocument.Text03" class="lgreeny-input" placeholder="Text03" />
                        <input type="text" @bind="editingDocument.Text04" class="lgreeny-input" placeholder="Text04" />
                        <input type="text" @bind="editingDocument.Text05" class="lgreeny-input" placeholder="Text05" />
                        <input type="text" @bind="editingDocument.Text06" class="lgreeny-input" placeholder="Text06" />
                        <input type="text" @bind="editingDocument.Text07" class="lgreeny-input" placeholder="Text07" />
                        <input type="text" @bind="editingDocument.Text08" class="lgreeny-input" placeholder="Text08" />
                        <input type="text" @bind="editingDocument.Text09" class="lgreeny-input" placeholder="Text09" />
                        <input type="text" @bind="editingDocument.Text10" class="lgreeny-input" placeholder="Text10" />
