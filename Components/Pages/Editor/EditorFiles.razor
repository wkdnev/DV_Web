    private async Task ConfirmDelete()
    {
        if (documentToDelete == null || selectedProject == null) return;

        try
        {
            isDeleting = true;
            deleteErrorMessage = null;

            using var context = await DbContextFactory.CreateDbContextAsync();
            
            var schemaName = selectedProject.SchemaName;
            var documentId = documentToDelete.DocumentId;

            // Delete document pages first (due to foreign key constraints)
            var deletePagesSQL = $"DELETE FROM [{schemaName}].[DocumentPage] WHERE DocumentId = {{0}}";
            await context.Database.ExecuteSqlRawAsync(deletePagesSQL, documentId);

            // Delete the document
            var deleteDocSQL = $"DELETE FROM [{schemaName}].[Document] WHERE DocumentId = {{0}}";
            await context.Database.ExecuteSqlRawAsync(deleteDocSQL, documentId);

            // Remove from local lists
            allDocuments.Remove(documentToDelete);
            filteredDocuments.Remove(documentToDelete);
            pageCountCache.Remove(documentToDelete.DocumentId);

            // Close modal
            showDeleteConfirmation = false;
            documentToDelete = null;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            deleteErrorMessage = $"Error deleting document: {ex.Message}";
            Console.WriteLine($"Error deleting document: {ex.Message}");
        }
        finally
        {
            isDeleting = false;
        }
    }

