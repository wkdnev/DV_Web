    private bool CanSavePageEdit()
    {
        if (editingPage == null || editPageNumber <= 0)
        {
            return false;
        }

        // Check for duplicate page number (excluding current page)
        if (existingPages != null && existingPages.Any(p => p.PageNumber == editPageNumber && p.PageId != editingPage.PageId))
        {
            return false;
        }

        return true;
    }

    private async Task SavePageChanges()
    {
        if (editingPage == null || selectedProject == null || selectedDocumentForPages == null)
        {
            return;
        }

        isEditingPage = true;
        pageEditErrorMessage = null;
        pageEditSuccessMessage = null;

        try
        {
            using var context = await DbContextFactory.CreateDbContextAsync();

            // If a new file is selected, upload it and update the file-related fields
            if (editPageFile != null)
            {
                // Delete the old page and upload the new one
                var formFile = new FormFileWrapper(editPageFile);
                
                // Delete old page
                var deleteSQL = $"DELETE FROM [{selectedProject.SchemaName}].[DocumentPage] WHERE PageId = {{0}}";
                await context.Database.ExecuteSqlRawAsync(deleteSQL, editingPage.PageId);

                // Upload new page
                var currentUserId = await ResolveCurrentUserIdAsync();
                await DocumentUploadService.UploadFileAsync(
                    selectedDocumentForPages.DocumentId,
                    editPageNumber,
                    formFile,
                    pageReference: string.IsNullOrWhiteSpace(editPageReference) ? null : editPageReference,
                    userId: currentUserId,
                    documentIndex: selectedDocumentForPages.DocumentIndex ?? ""
                );

                pageEditSuccessMessage = "Page updated successfully with new file!";
            }
            else
            {
                // Just update metadata (page number and reference)
                var updateSQL = $@"
                    UPDATE [{selectedProject.SchemaName}].[DocumentPage]
                    SET PageNumber = {{0}}, 
                        PageReference = {{1}},
                        FrameNumber = {{2}},
                        Level1 = {{3}},
                        Level2 = {{4}},
                        Level3 = {{5}},
                        Level4 = {{6}},
                        DiskNumber = {{7}},
                        FileFormat = {{8}},
                        PageSize = {{9}},
                        ModifiedOn = {{10}},
                        ModifiedBy = {{11}}
                    WHERE PageId = {{12}}";

                var currentUserId = await ResolveCurrentUserIdAsync();

                // Create parameter array - EF Core handles null values properly when passed as object?
                object?[] parameters = new object?[]
                {
                    editPageNumber,
                    string.IsNullOrWhiteSpace(editPageReference) ? null : editPageReference,
                    editPageFrameNumber,
                    string.IsNullOrWhiteSpace(editPageLevel1) ? null : editPageLevel1,
                    string.IsNullOrWhiteSpace(editPageLevel2) ? null : editPageLevel2,
                    string.IsNullOrWhiteSpace(editPageLevel3) ? null : editPageLevel3,
                    string.IsNullOrWhiteSpace(editPageLevel4) ? null : editPageLevel4,
                    string.IsNullOrWhiteSpace(editPageDiskNumber) ? null : editPageDiskNumber,
                    editPageFileFormat,
                    string.IsNullOrWhiteSpace(editPagePageSize) ? null : editPagePageSize,
                    DateTime.UtcNow,
                    currentUserId,
                    editingPage.PageId
                };

                await context.Database.ExecuteSqlRawAsync(updateSQL, parameters!);

                pageEditSuccessMessage = "Page details updated successfully!";
            }

            // Reload existing pages
            await LoadExistingPages();

            // Close dialog after a short delay
            await Task.Delay(1500);
            CloseEditPageDialog();
        }
        catch (Exception ex)
        {
            pageEditErrorMessage = $"Error saving page changes: {ex.Message}";
        }
        finally
        {
            isEditingPage = false;
            StateHasChanged();
        }
    }

    private async Task<int> ResolveCurrentUserIdAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var username = authState.User?.Identity?.Name;
            if (!string.IsNullOrEmpty(username))
            {
                using var secCtx = await SecurityDbContextFactory.CreateDbContextAsync();
                var user = await secCtx.Users.FirstOrDefaultAsync(u => u.Username == username);
                if (user != null)
                    return user.UserId;
            }
        }
        catch
        {
            // Ignore and fall through
        }

        return 0;
    }

