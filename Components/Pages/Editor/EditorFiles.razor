@code {
    private Project? selectedProject = null;
    private List<Document> allDocuments = new();
    private List<Document> filteredDocuments = new();
    private Dictionary<int, int> pageCountCache = new();
    
    private string searchText = string.Empty;
    private bool isLoading = true;
    private string? errorMessage = null;
    private bool hasRendered = false;

    // Delete confirmation
    private bool showDeleteConfirmation = false;
    private Document? documentToDelete = null;
    private bool isDeleting = false;
    private string? deleteErrorMessage = null;

    // Edit document
    private bool showEditDialog = false;
    private EditableDocument? editingDocument = null;
    private bool isSaving = false;
    private string? editErrorMessage = null;
    private string? editSuccessMessage = null;

    // Upload pages
    private bool showUploadPagesDialog = false;
    private Document? selectedDocumentForPages = null;
    private int newPageNumber = 1;
    private int suggestedPageNumber = 1;
    private string newPageReference = string.Empty;
    private IBrowserFile? selectedPageFile = null;
    private bool isUploadingPage = false;
    private string? pageUploadErrorMessage = null;
    private string? pageUploadSuccessMessage = null;
    private IEnumerable<DocumentPage>? existingPages = null;
    private bool isLoadingPages = false;

    // Page metadata inputs for upload
    private int? newFrameNumber = null;
    private string? newLevel1 = null;
    private string? newLevel2 = null;
    private string? newLevel3 = null;
    private string? newLevel4 = null;
    private string? newDiskNumber = null;
    private int? newFileFormat = null;
    private string? newPageSize = null;

    // Page edit dialog
    private bool showEditPageDialog = false;
    private DocumentPage? editingPage = null;
    private int editPageNumber = 1;
    private string editPageReference = string.Empty;
    private IBrowserFile? editPageFile = null;
    private bool isEditingPage = false;
    private string? pageEditErrorMessage = null;
    private string? pageEditSuccessMessage = null;
    // Mutable fields for page metadata editing (DocumentPage has init-only properties)
    private int? editPageFrameNumber = null;
    private string? editPageLevel1 = null;
    private string? editPageLevel2 = null;
    private string? editPageLevel3 = null;
    private string? editPageLevel4 = null;
    private string? editPageDiskNumber = null;
    private int? editPageFileFormat = null;
    private string? editPagePageSize = null;

    protected override void OnInitialized()
    {
        // Don't do anything here that requires JSRuntime
        isLoading = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !hasRendered)
        {
            hasRendered = true;
            await LoadSelectedProject();
            if (selectedProject != null)
            {
                await LoadDocuments();
            }
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadSelectedProject()
    {
        try
        {
            // Retrieve the selected project ID from session storage
            var projectIdString = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "selectedProjectId");
            
            if (!string.IsNullOrEmpty(projectIdString) && int.TryParse(projectIdString, out int projectId))
            {
                using var context = await DbContextFactory.CreateDbContextAsync();
                selectedProject = await context.Projects
                    .FirstOrDefaultAsync(p => p.ProjectId == projectId);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading selected project: {ex.Message}");
        }
    }

    private async Task LoadDocuments()
    {
        if (selectedProject == null) return;

        try
        {
            isLoading = true;
            errorMessage = null;
            
            // Use DocumentRepository SearchAsync with project filter (returns all documents when searchTerm is empty)
            var documents = await DocumentRepository.SearchAsync(
                "DefaultConnection", 
                null, // No search term - get all documents
                1, // page
                10000, // pageSize - large number to get all
                selectedProject.ProjectId);

            allDocuments = documents.ToList();

            // Load page counts
            await LoadPageCounts();

            // Apply initial filter
            FilterDocuments();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading documents: {ex.Message}";
            Console.WriteLine($"Error loading documents: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadPageCounts()
    {
        if (selectedProject == null || allDocuments.Count == 0) return;

        try
        {
            pageCountCache.Clear();

            // Use DocumentRepository to get page counts for each document
            foreach (var doc in allDocuments)
            {
                try
                {
                    var pages = await DocumentRepository.GetPagesAsync("DefaultConnection", doc.DocumentId);
                    pageCountCache[doc.DocumentId] = pages.Count();
                }
                catch
                {
                    // If page retrieval fails, default to 0
                    pageCountCache[doc.DocumentId] = 0;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading page counts: {ex.Message}");
        }
    }

    private void FilterDocuments()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredDocuments = allDocuments;
        }
        else
        {
            var search = searchText.ToLower();
            filteredDocuments = allDocuments
                .Where(d => 
                    (d.DocumentNumber != null && d.DocumentNumber.ToLower().Contains(search)) ||
                    (d.Title != null && d.Title.ToLower().Contains(search)) ||
                    (d.Author != null && d.Author.ToLower().Contains(search)) ||
                    (d.Keywords != null && d.Keywords.ToLower().Contains(search)) ||
                    (d.DocumentType != null && d.DocumentType.ToLower().Contains(search)))
                .ToList();
        }
        StateHasChanged();
    }

    private void ClearSearch()
    {
        searchText = string.Empty;
        FilterDocuments();
    }

    private int GetPageCount(int documentId)
    {
        return pageCountCache.TryGetValue(documentId, out int count) ? count : 0;
    }

