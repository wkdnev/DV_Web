    private void OpenManagePagesFromEdit()
    {
        if (editingDocument == null) return;
        
        // Find the document from the filtered list
        var doc = filteredDocuments.FirstOrDefault(d => d.DocumentId == editingDocument.DocumentId);
        
        // If not found in filtered list, search in all documents
        if (doc == null)
        {
            doc = allDocuments.FirstOrDefault(d => d.DocumentId == editingDocument.DocumentId);
        }
        
        // If still not found, create a minimal Document object from editingDocument
        if (doc == null)
        {
            doc = new Document
            {
                DocumentId = editingDocument.DocumentId,
                DocumentNumber = editingDocument.DocumentNumber,
                Title = editingDocument.Title,
                DocumentType = editingDocument.DocumentType,
                DocumentIndex = editingDocument.DocumentIndex
            };
        }
        
        CloseEditDialog();
        UploadPages(doc);
    }

