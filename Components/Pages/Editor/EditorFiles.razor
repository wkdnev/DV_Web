    private async Task LoadExistingPages()
    {
        if (selectedDocumentForPages == null) return;

        try
        {
            isLoadingPages = true;
            existingPages = await DocumentRepository.GetPagesAsync("DefaultConnection", selectedDocumentForPages.DocumentId);
            
            if (existingPages != null && existingPages.Any())
            {
                suggestedPageNumber = existingPages.Max(p => p.PageNumber) + 1;
                newPageNumber = suggestedPageNumber;
            }
            else
            {
                suggestedPageNumber = 1;
                newPageNumber = 1;
            }
        }
        catch (Exception ex)
        {
            pageUploadErrorMessage = $"Error loading pages: {ex.Message}";
        }
        finally
        {
            isLoadingPages = false;
            StateHasChanged();
        }
    }

