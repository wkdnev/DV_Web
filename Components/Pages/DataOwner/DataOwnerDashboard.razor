@page "/dataowner/dashboard"
@attribute [RoleBasedAuthorization("DataOwner")]
@using DV.Shared.Security
@rendermode InteractiveServer

<PageTitle>Data Owner Dashboard</PageTitle>

<div class="container mt-4">
    <h3 class="mb-4">Data Owner Dashboard</h3>
    <div class="card">
        <div class="card-body">
            <p class="text-muted">This is the Data Owner Dashboard. Future data owner options and tools will appear here.</p>
            <ul>
                <li>Data Ownership Reports (coming soon)</li>
                <li>Access Requests (coming soon)</li>
                <li>Data Management Tools (coming soon)</li>
                <li>Other data owner tools...</li>
            </ul>
        </div>
    </div>
</div>
