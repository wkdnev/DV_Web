@page "/auditor/dashboard"
@attribute [Authorize]
@using DV.Web.Services
@using DV.Shared.Security
@using DV.Shared.Models
@inject ProjectRoleService ProjectRoleService
@inject UserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Auditor Dashboard</PageTitle>

<div class="container mt-4">
    <h3 class="mb-4">Auditor Dashboard</h3>
    
    @if (userProjectAccess == null)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
        <p class="text-center">Loading your project access...</p>
    }
    else if (userProjectAccess.Count == 0)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>No Project Access</strong>
            <p class="mb-0">You don't have access to any projects. Please contact your system administrator.</p>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12 mb-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-folder-check me-2"></i>
                            Your Project Access
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var access in userProjectAccess)
                            {
                                <div class="col-md-6 col-lg-4 mb-3">
                                    <div class="card border-primary">
                                        <div class="card-header">
                                            <h6 class="mb-0">@access.Project.ProjectName</h6>
                                            <small class="text-muted">Schema: @access.Project.SchemaName</small>
                                        </div>
                                        <div class="card-body">
                                            <div class="mb-2">
                                                <strong>Your Roles:</strong>
                                            </div>
                                            @foreach (var role in access.ProjectRoles)
                                            {
                                                <span class="badge bg-info me-1 mb-1">@role.ApplicationRole?.Name</span>
                                            }
                                            <div class="mt-3">
                                                <button class="btn btn-sm btn-outline-primary" 
                                                        @onclick="() => ViewProjectDetails(access.Project.ProjectId)">
                                                    <i class="bi bi-eye me-1"></i>
                                                    View Documents
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-clipboard-data me-2"></i>
                            Auditor Tools
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <div class="card h-100 border-success">
                                    <div class="card-body text-center">
                                        <i class="bi bi-file-text text-success mb-2" style="font-size: 2rem;"></i>
                                        <h6>Audit Reports</h6>
                                        <p class="small text-muted">Generate compliance and audit reports</p>
                                        <button class="btn btn-sm btn-success">Generate Report</button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="card h-100 border-warning">
                                    <div class="card-body text-center">
                                        <i class="bi bi-activity text-warning mb-2" style="font-size: 2rem;"></i>
                                        <h6>Activity Logs</h6>
                                        <p class="small text-muted">Review user activity and access logs</p>
                                        <button class="btn btn-sm btn-warning">View Logs</button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="card h-100 border-info">
                                    <div class="card-body text-center">
                                        <i class="bi bi-shield-check text-info mb-2" style="font-size: 2rem;"></i>
                                        <h6>Compliance Checks</h6>
                                        <p class="small text-muted">Run automated compliance checks</p>
                                        <button class="btn btn-sm btn-info">Run Checks</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Services.UserProjectAccess>? userProjectAccess;
    private string? currentUsername;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserProjectAccess();
    }

    private async Task LoadUserProjectAccess()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            currentUsername = authState.User.Identity?.Name;

            if (!string.IsNullOrEmpty(currentUsername))
            {
                var user = await UserService.GetUserByUsernameAsync(currentUsername);
                if (user != null)
                {
                    userProjectAccess = await ProjectRoleService.GetUserProjectAccessAsync(user.UserId);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading user project access: {ex.Message}");
            userProjectAccess = new List<Services.UserProjectAccess>();
        }
    }

    private void ViewProjectDetails(int projectId)
    {
        // Navigate to project-specific document view
        // This would be implemented based on your routing structure
        Console.WriteLine($"Viewing project {projectId} details");
    }
}
